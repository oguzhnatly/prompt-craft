---
const stages = [
  {
    id: 'intent',
    n: '01', name: 'Intent Decomposer',
    tag: 'NLP · Parsing',
    headline: 'Parses what you actually meant, not what you typed.',
    body: 'Your raw input is tokenized and analyzed to extract the primary verb, subject, object, and desired outcome. Intent Decomposer distinguishes between imperative instructions ("build X"), exploratory questions ("how does Y work"), and creative briefs ("write Z in the style of"). This classification routes your request to the appropriate assembly strategy in stage 5.',
    in:  'make a login endpoint with proper error handling',
    out: 'intent: CREATE\ndomain: backend-api\nsubject: authentication-endpoint\nconstraints: implied[security, error-handling, input-validation]',
  },
  {
    id: 'entity',
    n: '02', name: 'Entity Extractor',
    tag: 'NER · Pinning',
    headline: 'Locks every technical term so nothing gets paraphrased away.',
    body: 'Named entity recognition identifies and pins all domain-critical tokens: proper nouns, version numbers, library names, acronyms, quoted strings, and technical identifiers. These entities receive immutable flags so no downstream stage synonymizes, paraphrases, or drops them. What you named is what the model sees.',
    in:  'write a test for the UserAuthService.login() method',
    out: 'PINNED: [UserAuthService] [login()]\ntype: class-ref, method-ref\nimmutable: true\nscope: test-coverage',
  },
  {
    id: 'complexity',
    n: '03', name: 'Complexity Classifier',
    tag: 'Scoring · Routing',
    headline: 'Scores the request on four dimensions and routes accordingly.',
    body: 'Four orthogonal dimensions are scored 0–1: scope, depth, ambiguity, and technicality. The combined score selects one of 12 assembly strategies and determines how much context the Context Engine injects in stage 4. A casual request gets a different treatment than a deep expert-level task.',
    in:  'explain how transformers work',
    out: 'scope: 0.72\ndepth: 0.81\nambiguity: 0.38\ntechnicality: 0.64\nstrategy: pedagogical-depth',
  },
  {
    id: 'context',
    n: '04', name: 'Context Engine',
    tag: 'Context · Memory',
    headline: 'Reads what you are working on and injects it silently.',
    body: 'The Context Engine reads the macOS accessibility layer to determine your active application and selected text, queries the local clipboard history ring for recent content, and applies domain priors derived from your style profile. All injected as structured annotations in the assembly buffer without you writing any of it manually.',
    in:  '(active: Xcode, selection: 42 lines Swift, clipboard: UserDefaults key)',
    out: 'context.lang = swift\ncontext.framework = swiftui\ncontext.recently_edited = UserDefaults\ncontext.scope = mobile-development',
  },
  {
    id: 'assembler',
    n: '05', name: 'Prompt Assembler',
    tag: 'Assembly · Templates',
    headline: 'Builds the final prompt from every upstream signal.',
    body: 'The Assembler takes classified intent, pinned entities, complexity score, and injected context and renders the final prompt using the active style template. Engineering adds role specification, constraint enumeration, format requirements, and test directives. Every template is composable, not static.',
    in:  'pinned entities + intent + context + style=Engineering',
    out: 'You are a senior iOS engineer. Task: refactor selected Swift code using SwiftUI best practices. Constraints: preserve UserDefaults key compatibility, add unit test stubs for each public method. Format: annotated code + change rationale.',
  },
  {
    id: 'execution',
    n: '06', name: 'Model Execution',
    tag: 'Routing · Streaming',
    headline: 'Routes to your provider and streams back without delay.',
    body: 'The assembled prompt routes to your configured endpoint, local Ollama, or a cloud provider via PromptCraft Cloud. Responses stream token by token with timeout handling, retry on transient errors, and request deduplication handled automatically.',
    in:  'assembled prompt to configured provider',
    out: 'provider: Claude 3.5 Sonnet\nlatency: 178ms to first token\nstreaming: active @ 48 tok/s\nstatus: 200 OK',
  },
  {
    id: 'post',
    n: '07', name: 'Post Processor',
    tag: 'Validation · Cleanup',
    headline: 'Strips model artifacts before output reaches you.',
    body: 'The raw response passes through format validation, artifact stripping, verbosity enforcement, and structural cleanup. The result lands in the output area with copy, export, and clear actions ready immediately.',
    in:  'raw model response with preamble + filler',
    out: 'preamble: stripped\nformat: validated\nverbosity: enforced\noutput: ready to copy',
  },
];
---

<section id="pipeline" aria-labelledby="pipeline-heading">
  <div class="wrap">
    <div class="pl-header" data-reveal>
      <span class="eyebrow"><span class="eyebrow-dot"></span>Under the hood</span>
      <h2 id="pipeline-heading" class="pl-h2">The pipeline, in full.</h2>
      <p class="pl-sub">Scroll drives the sequence from 01 to 07 with smooth transitions, and you can always keep scrolling manually.</p>
    </div>
  </div>

  <div id="pl-scroll-wrapper">
    <div id="pl-sticky">

      <div class="pl-ide" id="pl-ide" role="tablist" aria-label="Pipeline stage inspector">

        <div class="pl-stages">
          {stages.map((s, i) => (
            <button
              class={`pl-stage${i === 0 ? ' active' : ''}`}
              id={`pls-tab-${s.id}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`pls-panel-${s.id}`}
              data-idx={i}
              tabindex={i === 0 ? 0 : -1}
            >
              <span class="pls-n mono">{s.n}</span>
              <div class="pls-info">
                <span class="pls-name">{s.name}</span>
                <span class="pls-tag mono">{s.tag}</span>
              </div>
              <div class="pls-indicator" aria-hidden="true"></div>
            </button>
          ))}
        </div>

        <div class="pl-panel-wrap">
          {stages.map((s, i) => (
            <div
              class={`pl-panel${i === 0 ? ' active' : ''}`}
              id={`pls-panel-${s.id}`}
              role="tabpanel"
              aria-labelledby={`pls-tab-${s.id}`}
            >
              <div class="plp-top">
                <span class="plp-n mono">{s.n} / 07</span>
                <h3 class="plp-name">{s.name}</h3>
                <p class="plp-headline">{s.headline}</p>
              </div>
              <p class="plp-body">{s.body}</p>
              <div class="plp-io">
                <div class="plp-io-pane">
                  <span class="plp-io-label mono">input</span>
                  <code class="plp-io-code mono">{s.in}</code>
                </div>
                <div class="plp-io-arrow" aria-hidden="true">
                  <iconify-icon icon="lucide:arrow-down" style="font-size:14px;color:var(--acc);"></iconify-icon>
                </div>
                <div class="plp-io-pane plp-io-out">
                  <span class="plp-io-label mono">output</span>
                  <code class="plp-io-code mono">{s.out}</code>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>

      <div class="pl-progress" aria-hidden="true">
        <div class="pl-progress-track">
          <div class="pl-progress-bar" id="pl-progress-bar"></div>
        </div>
        <span class="pl-progress-label mono" id="pl-progress-label">01 / 07</span>
      </div>
    </div>
  </div>

  <div class="wrap">
    <div class="pl-footer mono" data-reveal>
      <span class="plf-acc">pipeline.execute(input)</span>
      <iconify-icon icon="lucide:arrow-right" style="font-size:12px;vertical-align:middle;" aria-hidden="true"></iconify-icon>
      optimized, model-ready · avg <strong>140ms</strong>
    </div>
  </div>
</section>

<style>
  #pipeline { padding: 72px 0 56px; }

  .pl-header {
    max-width: 620px; margin-bottom: 28px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .pl-h2 {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 700; letter-spacing: -0.05em; line-height: 1.06;
    color: var(--ink);
  }
  .pl-sub { font-size: 15px; color: var(--mid); line-height: 1.7; }

  #pl-scroll-wrapper {
    position: relative;
    height: 95vh;
    margin-bottom: 12px;
  }

  #pl-sticky {
    position: sticky;
    top: 84px;
    width: 100%;
    height: calc(100vh - 120px);
    min-height: calc(100vh - 120px);
    display: flex; flex-direction: column;
    justify-content: center;
  }

  .pl-ide {
    width: 100%;
    min-height: clamp(500px, 68vh, 690px);
    display: grid; grid-template-columns: 300px 1fr;
    border-top: 1px solid var(--bdr);
    border-bottom: 1px solid var(--bdr);
    background: var(--bg);
    overflow: hidden;
  }

  .pl-stages {
    border-right: 1px solid var(--bdr);
    display: flex; flex-direction: column;
    background: var(--bg);
  }
  .pl-stage {
    display: grid; grid-template-columns: 44px 1fr 4px;
    align-items: center; gap: 10px;
    padding: 14px 16px;
    border: none; border-bottom: 1px solid var(--bdr);
    background: var(--bg); text-align: left;
    cursor: pointer;
    transition: background .15s;
    position: relative;
  }
  .pl-stage:last-child { border-bottom: none; }
  .pl-stage:hover { background: var(--bg2); }
  .pl-stage.active { background: var(--bg2); }

  .pls-n { font-size: 10px; font-weight: 600; letter-spacing: 0.08em; color: var(--dim); }
  .pl-stage.active .pls-n { color: var(--acc); }
  .pls-info { display: flex; flex-direction: column; gap: 2px; }
  .pls-name { font-size: 13px; font-weight: 600; color: var(--ink); letter-spacing: -0.015em; }
  .pls-tag  { font-size: 10px; color: var(--dim); letter-spacing: 0.04em; }
  .pls-indicator {
    height: 100%; width: 3px; border-radius: 2px;
    background: transparent;
    position: absolute; left: 0; top: 0; bottom: 0;
    transition: background .2s;
  }
  .pl-stage.active .pls-indicator { background: var(--acc); }

  .pl-panel-wrap {
    position: relative;
    overflow: hidden;
    min-height: 100%;
  }
  .pl-panel {
    position: absolute; inset: 0;
    padding: 38px 44px;
    display: flex; flex-direction: column; gap: 18px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .42s var(--out), transform .42s var(--out);
    pointer-events: none;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .pl-panel::-webkit-scrollbar { display: none; }
  .pl-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .plp-top { display: flex; flex-direction: column; gap: 8px; }
  .plp-n { font-size: 10px; color: var(--dim); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }
  .plp-name { font-size: 24px; font-weight: 700; letter-spacing: -0.035em; color: var(--ink); line-height: 1.2; }
  .plp-headline { font-size: 15px; font-weight: 500; color: var(--acc); line-height: 1.45; }
  .plp-body { font-size: 14px; line-height: 1.8; color: var(--mid); max-width: 640px; }

  .plp-io {
    display: flex; flex-direction: column;
    border: 1px solid var(--bdr); border-radius: 10px;
    overflow: hidden; max-width: 620px;
  }
  .plp-io-pane { padding: 12px 16px; display: flex; flex-direction: column; gap: 5px; }
  .plp-io-out { background: rgba(26,107,64,0.03); }
  .plp-io-label { font-size: 9px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--dim); }
  .plp-io-out .plp-io-label { color: var(--acc); opacity: .7; }
  .plp-io-code { font-size: 12px; line-height: 1.65; color: var(--mid); white-space: pre-wrap; word-break: break-word; }
  .plp-io-out .plp-io-code { color: var(--acc); }
  .plp-io-arrow {
    display: flex; align-items: center; padding: 5px 16px;
    border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr);
    background: var(--bg2);
  }

  .pl-progress {
    margin-top: 10px;
    display: flex; align-items: center; gap: 8px;
    padding: 4px 14px;
  }
  .pl-progress-track {
    flex: 1; height: 8px; background: var(--bdr);
    border-radius: 999px; overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.04);
  }
  .pl-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--acc), var(--acc-hi));
    width: calc(1/7 * 100%);
    border-radius: 999px;
    transition: width .28s var(--out);
  }
  .pl-progress-label {
    font-size: 10px; color: var(--ink2); letter-spacing: 0.08em;
    min-width: 58px;
    text-align: center;
    white-space: nowrap;
    line-height: 1;
    padding: 4px 8px;
    border-radius: 999px;
    background: var(--bg2);
    border: 1px solid var(--bdr);
  }

  .pl-footer {
    font-size: 12px; color: var(--dim);
    padding: 13px 18px; border: 1px solid var(--bdr);
    border-radius: 8px; background: var(--bg2);
    display: inline-flex; gap: 6px; align-items: center;
  }
  .plf-acc { color: var(--acc); }
  .pl-footer strong { color: var(--ink2); }

  @media (max-width: 900px) {
    #pl-scroll-wrapper { height: auto; }
    #pl-sticky {
      position: relative;
      top: auto;
      min-height: auto;
    }
    .pl-ide { grid-template-columns: 1fr; min-height: 520px; }
    .pl-stages { border-right: none; border-bottom: 1px solid var(--bdr); display: grid; grid-template-columns: 1fr 1fr; }
    .pl-panel-wrap { min-height: 380px; }
    .pl-panel { padding: 24px 20px; }
  }
</style>

<script>
  const tabs = Array.from(document.querySelectorAll('.pl-stage'));
  const panels = Array.from(document.querySelectorAll('.pl-panel'));
  const progressBar = document.getElementById('pl-progress-bar');
  const progressLabel = document.getElementById('pl-progress-label');
  const wrapper = document.getElementById('pl-scroll-wrapper');

  const TOTAL = 7;
  const NAV_TOP = 72;
  let currentStage = -1;
  let wheelCooldownUntil = 0;

  function activateStage(index, force = false) {
    const next = Math.max(0, Math.min(TOTAL - 1, index));
    if (!force && next === currentStage) return;
    currentStage = next;

    tabs.forEach((t, i) => {
      const on = i === currentStage;
      t.classList.toggle('active', on);
      t.setAttribute('aria-selected', String(on));
      t.setAttribute('tabindex', on ? '0' : '-1');
    });

    panels.forEach((p, i) => {
      p.classList.toggle('active', i === currentStage);
    });

    if (progressBar) {
      progressBar.style.width = `${((currentStage + 1) / TOTAL) * 100}%`;
    }
    if (progressLabel) {
      progressLabel.textContent = `${String(currentStage + 1).padStart(2, '0')} / 07`;
    }
  }

  function inLockZone() {
    if (!wrapper) return false;
    const rect = wrapper.getBoundingClientRect();
    return rect.top <= NAV_TOP + 8 && rect.bottom >= window.innerHeight * 0.55;
  }

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      activateStage(i);
      if (!wrapper || window.innerWidth < 900) return;

      const totalScroll = Math.max(1, wrapper.offsetHeight - window.innerHeight);
      const segment = totalScroll / (TOTAL - 1);
      const target = wrapper.offsetTop + (segment * i);
      window.scrollTo({ top: Math.max(0, target), behavior: 'smooth' });
    });

    tab.addEventListener('keydown', e => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const n = Math.min(TOTAL - 1, i + 1);
        tabs[n].click();
        tabs[n].focus();
      }
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        const n = Math.max(0, i - 1);
        tabs[n].click();
        tabs[n].focus();
      }
    });
  });

  window.addEventListener('wheel', e => {
    if (window.innerWidth < 900) return;
    if (!inLockZone()) return;

    const abs = Math.abs(e.deltaY);
    if (abs < 8) return;

    const now = performance.now();
    if (now < wheelCooldownUntil) {
      e.preventDefault();
      return;
    }

    const dir = e.deltaY > 0 ? 1 : -1;

    if (dir > 0 && currentStage < TOTAL - 1) {
      e.preventDefault();
      activateStage(currentStage + 1);
      wheelCooldownUntil = now + 320;
      return;
    }

    if (dir < 0 && currentStage > 0) {
      e.preventDefault();
      activateStage(currentStage - 1);
      wheelCooldownUntil = now + 320;
      return;
    }

    // boundary behavior: let normal page scroll happen
  }, { passive: false });

  // touch support for locked stepping
  let touchStartY = 0;
  window.addEventListener('touchstart', e => {
    if (window.innerWidth < 900) return;
    if (!inLockZone()) return;
    touchStartY = e.touches[0]?.clientY || 0;
  }, { passive: true });

  window.addEventListener('touchmove', e => {
    if (window.innerWidth < 900) return;
    if (!inLockZone()) return;

    const y = e.touches[0]?.clientY || 0;
    const delta = touchStartY - y;
    if (Math.abs(delta) < 14) return;

    const now = performance.now();
    if (now < wheelCooldownUntil) {
      e.preventDefault();
      return;
    }

    const dir = delta > 0 ? 1 : -1;

    if (dir > 0 && currentStage < TOTAL - 1) {
      e.preventDefault();
      activateStage(currentStage + 1);
      wheelCooldownUntil = now + 340;
      touchStartY = y;
      return;
    }

    if (dir < 0 && currentStage > 0) {
      e.preventDefault();
      activateStage(currentStage - 1);
      wheelCooldownUntil = now + 340;
      touchStartY = y;
      return;
    }

    // boundary behavior: allow native scroll
  }, { passive: false });

  // keep default state sane when user goes above section
  window.addEventListener('scroll', () => {
    if (!wrapper) return;
    if (window.innerWidth < 900) return;

    const y = window.scrollY;
    if (y < wrapper.offsetTop - window.innerHeight * 0.35 && currentStage !== 0) {
      activateStage(0, true);
    }
  }, { passive: true });

  activateStage(0, true);
</script>
