---
const stages = [
  {
    step: '01',
    name: 'Intent Decomposer',
    desc: 'Parses raw input into distinct action intents. Separates emotional noise and urgency from task logic. Compound requests split into independent directives.',
    output: 'intents[], urgency_level, cleaned_input',
    color: '#00E5A0',
    icon: `<path d="M4 6h16M4 12h10M4 18h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    step: '02',
    name: 'Entity Extractor',
    desc: 'Finds persons, projects, environments, technical terms, temporal markers, and organizations. Builds structured metadata for context injection.',
    output: 'entities{persons, projects, envs, terms, orgs}',
    color: '#818CF8',
    icon: `<circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M3 21v-2a7 7 0 0114 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    step: '03',
    name: 'Complexity Classifier',
    desc: 'Computes ambiguity score and maps input to one of four tiers. Complexity comes from task load, not template habit. Simple stays simple.',
    output: 'tier(1-4), ambiguity_score, context_signals[]',
    color: '#C084FC',
    icon: `<path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14l3.5 3.5M14 21l7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    step: '04',
    name: 'Context Engine',
    desc: 'Retrieves semantic matches from your context store. Injects learned project details into existing sentences instead of appending new sections.',
    output: 'context_block, injected_entities[], clusters[]',
    color: '#FCD34D',
    icon: `<circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    step: '05',
    name: 'Prompt Assembler',
    desc: 'Builds system and user messages with tier calibration, context injection, and tier-matched few-shot examples. Structure is earned, never assumed.',
    output: 'system_message, user_message, token_budget',
    color: '#F472B6',
    icon: `<rect x="3" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><rect x="14" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><rect x="3" y="14" width="7" height="7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M17.5 14v7M14 17.5h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    step: '06',
    name: 'Model Execution',
    desc: 'Routes assembled messages to your configured provider. Supports Claude, GPT-4o, DeepSeek V3, and local Ollama. Zero configuration required for Cloud users.',
    output: 'raw_response, provider, model, tokens_used',
    color: '#FB923C',
    icon: `<path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M13 2v7h7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  },
  {
    step: '07',
    name: 'Post Processor',
    desc: 'Enforces word budget, removes forbidden structure in simple tiers, blocks meta leakage. The output has exactly the complexity the task earned.',
    output: 'final_directive, compression_applied, clean',
    color: '#00E5A0',
    icon: `<path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];
---

<section id="pipeline" class="pipeline-section ambient-top">
  <div class="container">

    <div class="pipeline-header">
      <div class="section-tag reveal">
        <span class="mono">Recursive Meta Prompt Architecture</span>
      </div>
      <h2 class="section-title reveal reveal-d1">
        Seven stages.<br />
        <span class="gradient-text">Zero guesswork.</span>
      </h2>
      <p class="section-desc reveal reveal-d2">
        Every optimization follows a deterministic pipeline.
        Understanding happens before generation. Complexity is measured, not assumed.
      </p>
    </div>

    <div class="pipeline-list">
      {stages.map((stage, i) => (
        <div class="pipeline-item reveal" data-reveal-delay={String((i % 4) + 1)}>

          <!-- Step badge + connector -->
          <div class="step-col">
            <div class="step-badge" style={`border-color: ${stage.color}35; background: ${stage.color}10; color: ${stage.color}`}>
              {stage.step}
            </div>
            {i < stages.length - 1 && (
              <div class="step-connector" style={`background: linear-gradient(180deg, ${stage.color}40, ${stages[i+1].color}20)`}></div>
            )}
          </div>

          <!-- Content -->
          <div class="item-content">
            <div class="item-header">
              <div class="item-icon" style={`border-color: ${stage.color}25; background: ${stage.color}08`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" set:html={stage.icon} style={`color: ${stage.color}`} />
              </div>
              <div>
                <h3 class="item-name">{stage.name}</h3>
                <code class="item-output mono">{stage.output}</code>
              </div>
            </div>
            <p class="item-desc">{stage.desc}</p>
          </div>

          <!-- Stage number accent -->
          <div class="item-accent mono" style={`color: ${stage.color}15`}>{stage.step}</div>
        </div>
      ))}
    </div>

    <!-- Design principles -->
    <div class="principles reveal">
      {[
        { title: 'Complexity earned, not assumed', desc: 'Simple inputs stay compact. Structure appears only when task load demands it.', icon: '◈' },
        { title: 'Context adds precision, not length', desc: 'Learned entities inject into existing sentences. Output length stays constant.', icon: '◎' },
        { title: 'Emotional noise, filtered', desc: 'Urgency preserved as signal. Profanity and frustration stripped before analysis.', icon: '◉' },
      ].map(p => (
        <div class="principle-card">
          <span class="principle-icon mono">{p.icon}</span>
          <h4 class="principle-title">{p.title}</h4>
          <p class="principle-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pipeline-section {
    padding: 120px 24px;
    background: var(--base);
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .pipeline-header {
    max-width: 640px;
    margin-bottom: 72px;
  }

  .section-tag {
    display: inline-flex;
    font-size: 11px;
    color: var(--teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 24px;
    padding: 5px 12px;
    border: 1px solid rgba(0,229,160,0.18);
    border-radius: 100px;
    background: rgba(0,229,160,0.05);
  }

  .section-title {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 20px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--teal), #818CF8);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .section-desc {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .pipeline-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pipeline-item {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 24px;
    padding: 28px 28px 28px 0;
    border-bottom: 1px solid var(--border);
    position: relative;
    transition: background 0.3s;
    cursor: default;
  }

  .pipeline-item:last-child { border-bottom: none; }

  .pipeline-item:hover {
    background: rgba(255,255,255,0.015);
    border-radius: 12px;
  }

  .step-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .step-badge {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .pipeline-item:hover .step-badge {
    transform: scale(1.1);
    box-shadow: 0 0 20px currentColor;
  }

  .step-connector {
    width: 1px;
    flex: 1;
    min-height: 20px;
    margin-top: 6px;
  }

  .item-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .item-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .item-icon {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s;
  }

  .pipeline-item:hover .item-icon { transform: rotate(5deg); }

  .item-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .item-output {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .item-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 580px;
  }

  .item-accent {
    font-size: 80px;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
    align-self: center;
    user-select: none;
  }

  .principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 64px;
  }

  .principle-card {
    padding: 24px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--surface);
    position: relative;
    transition: border-color 0.3s, transform 0.3s;
  }

  .principle-card:hover {
    border-color: rgba(0,229,160,0.2);
    transform: translateY(-4px);
  }

  .principle-icon {
    display: block;
    font-size: 20px;
    color: var(--teal);
    margin-bottom: 14px;
  }

  .principle-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .principle-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .principles { grid-template-columns: 1fr; }
    .item-accent { display: none; }
  }
</style>
