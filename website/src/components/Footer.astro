---
const yr = new Date().getFullYear();
---
<footer id="site-footer" role="contentinfo">
  <div class="wrap ft-inner">

    <div class="ft-top">
      <div class="ft-brand">
        <a href="/" class="ft-logo" aria-label="PromptCraft">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="2.8" fill="var(--acc)"/>
            <path d="M12 2v8M12 14v8M2 12h8M14 12h8" stroke="var(--acc)" stroke-width="2.2" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="7" stroke="var(--acc)" stroke-width="0.8" opacity=".2" stroke-dasharray="2.5 3.5"/>
          </svg>
          <span>PromptCraft</span>
        </a>
        <p class="ft-tagline">
          Precision prompt engineering, running silently in your menu bar.
          Built for macOS. Runs everywhere you work.
        </p>
      </div>

      <div class="ft-cols">
        <div class="ft-col">
          <span class="ft-col-hd mono">Product</span>
          <a href="/download">Download</a>
          <a href="/#pipeline">How it works</a>
          <a href="/#features">Features</a>
          <a href="/pricing">Pricing</a>
          <a href="/docs">Docs</a>
        </div>
        <div class="ft-col">
          <span class="ft-col-hd mono">Support</span>
          <a href="/docs#install">Installation guide</a>
          <a href="/docs#license">License activation</a>
          <a href="/docs#ollama">Ollama setup</a>
          <a href="/docs#cloud">Cloud proxy</a>
          <a href="mailto:hello@promptcraft.app">hello@promptcraft.app</a>
        </div>
        <div class="ft-col">
          <span class="ft-col-hd mono">Legal</span>
          <a href="/privacy">Privacy policy</a>
          <a href="/terms">Terms of service</a>
          <a href="/terms#refunds">Refund policy</a>
        </div>
      </div>
    </div>

    <div class="ft-bottom">
      <p class="ft-req mono">Requires macOS 14 Sonoma · Apple Silicon + Intel · Signed &amp; notarized</p>
      <div class="ft-right">
        <p class="ft-copy">&copy; {yr} PromptCraft. All rights reserved.</p>
        <a href="https://oguzhanatalay.com" target="_blank" rel="noopener" class="ft-author mono">Made by oguzhanatalay.com</a>
      </div>
    </div>

  </div>
</footer>

<style>
  #site-footer {
    background: var(--bg);
    border-top: 1px solid var(--bdr);
    padding: 56px 0 28px;
  }

  .ft-inner { display: flex; flex-direction: column; gap: 48px; }

  .ft-top { display: grid; grid-template-columns: 280px 1fr; gap: 80px; align-items: start; }

  .ft-brand { display: flex; flex-direction: column; gap: 14px; }
  .ft-logo {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 15px; font-weight: 700; letter-spacing: -0.025em; color: var(--ink);
    transition: opacity .15s;
  }
  .ft-logo:hover { opacity: 0.7; }
  .ft-tagline { font-size: 13px; color: var(--dim); line-height: 1.65; }

  .ft-cols { display: flex; gap: 56px; }
  .ft-col  { display: flex; flex-direction: column; gap: 10px; }
  .ft-col-hd { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim); margin-bottom: 4px; }
  .ft-col a  { font-size: 13px; color: var(--mid); transition: color .13s; line-height: 1.3; }
  .ft-col a:hover { color: var(--ink); }

  .ft-bottom {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 20px; border-top: 1px solid var(--bdr);
    flex-wrap: wrap; gap: 8px;
  }
  .ft-req   { font-size: 10px; color: var(--ghost); }
  .ft-right { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
  .ft-copy  { font-size: 11px; color: var(--ghost); }
  .ft-author{ font-size: 11px; color: var(--dim); transition: color .13s; }
  .ft-author:hover { color: var(--ink); }

  @media (max-width: 900px) {
    .ft-top  { grid-template-columns: 1fr; gap: 36px; }
    .ft-cols { gap: 32px; flex-wrap: wrap; }
    .ft-bottom { flex-direction: column; align-items: flex-start; }
    .ft-right  { align-items: flex-start; }
  }
</style>
