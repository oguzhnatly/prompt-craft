---
---
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="fb-logo">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="2" fill="var(--teal-d)"/>
            <line x1="11" y1="2"  x2="11" y2="7"  stroke="var(--teal-d)" stroke-width="1.75" stroke-linecap="round"/>
            <line x1="11" y1="15" x2="11" y2="20" stroke="var(--teal-d)" stroke-width="1.75" stroke-linecap="round"/>
            <line x1="2"  y1="11" x2="7"  y2="11" stroke="var(--teal-d)" stroke-width="1.75" stroke-linecap="round"/>
            <line x1="15" y1="11" x2="20" y2="11" stroke="var(--teal-d)" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
          <span class="syne">Prompt<strong>Craft</strong></span>
        </a>
        <p class="fb-tag mono">Precision prompt engineering for macOS</p>
        <div class="fb-social">
          <a href="https://github.com/oguzhnatly/prompt-craft" target="_blank" rel="noopener" class="fb-soc" aria-label="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.742 0 .267.18.577.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
          </a>
          <a href="https://twitter.com/oguzhnatly" target="_blank" rel="noopener" class="fb-soc" aria-label="Twitter">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="mailto:hello@promptcraft.app" class="fb-soc" aria-label="Email">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>

      <nav class="footer-nav" role="navigation" aria-label="Footer navigation">
        <div class="fn-col">
          <span class="fn-head mono">Product</span>
          <a href="/#architecture">Architecture</a>
          <a href="/#features">Features</a>
          <a href="/pricing">Pricing</a>
          <a href="/download">Download</a>
          <a href="/docs">Documentation</a>
        </div>
        <div class="fn-col">
          <span class="fn-head mono">Developers</span>
          <a href="https://github.com/oguzhnatly/prompt-craft" target="_blank" rel="noopener">GitHub</a>
          <a href="https://github.com/oguzhnatly/prompt-craft/blob/main/docs/RMPA_WHITEPAPER.md" target="_blank" rel="noopener">RMPA Whitepaper</a>
          <a href="/docs">API Reference</a>
          <a href="https://github.com/oguzhnatly/prompt-craft/issues" target="_blank" rel="noopener">Report a Bug</a>
        </div>
        <div class="fn-col">
          <span class="fn-head mono">Legal</span>
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
          <a href="mailto:hello@promptcraft.app">Contact</a>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <span class="mono">© 2026 PromptCraft. All rights reserved.</span>
      <span class="mono fb-build">v1.1.0 · macOS 14+ · Developer ID Signed</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: rgba(255,255,255,0.5);
    padding: 64px 0 32px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 32px;
  }

  /* Brand */
  .footer-brand { display: flex; flex-direction: column; gap: 12px; }
  .fb-logo {
    display: inline-flex; align-items: center; gap: 9px;
    font-family: 'Syne', sans-serif;
    font-size: 16px; font-weight: 500;
    color: rgba(255,255,255,0.9); text-decoration: none;
  }
  .fb-logo strong { font-weight: 800; }
  .fb-tag { font-size: 11px; color: rgba(255,255,255,0.3); letter-spacing: 0.04em; }

  .fb-social { display: flex; gap: 8px; }
  .fb-soc {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px;
    border-radius: 7px;
    color: rgba(255,255,255,0.35);
    border: 1px solid rgba(255,255,255,0.08);
    transition: color .15s, border-color .15s, background .15s;
  }
  .fb-soc:hover {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.06);
  }

  /* Nav */
  .footer-nav { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .fn-col { display: flex; flex-direction: column; gap: 10px; }
  .fn-head {
    font-size: 10px; color: rgba(255,255,255,0.3);
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 4px;
  }
  .fn-col a {
    font-size: 13px; color: rgba(255,255,255,0.45);
    transition: color .15s; line-height: 1;
  }
  .fn-col a:hover { color: rgba(255,255,255,0.85); }

  .footer-bottom {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 11px; color: rgba(255,255,255,0.25);
    letter-spacing: 0.03em;
  }
  .fb-build { color: rgba(255,255,255,0.18); }

  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: 40px; }
    .footer-nav { grid-template-columns: 1fr 1fr; }
    .footer-bottom { flex-direction: column; gap: 6px; text-align: center; }
  }
</style>
