---
// Footer — minimal, precise
---

<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="PromptCraft home">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="2" fill="var(--teal)"/>
          <line x1="12" y1="3" x2="12" y2="9"  stroke="var(--teal)" stroke-width="2" stroke-linecap="round"/>
          <line x1="12" y1="15" x2="12" y2="21" stroke="var(--teal)" stroke-width="2" stroke-linecap="round"/>
          <line x1="3" y1="12" x2="9" y2="12"  stroke="var(--teal)" stroke-width="2" stroke-linecap="round"/>
          <line x1="15" y1="12" x2="21" y2="12" stroke="var(--teal)" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span>Prompt<strong>Craft</strong></span>
      </a>
      <p class="footer-tagline">Precision prompt engineering<br>for macOS menu bar.</p>
      <div class="footer-socials">
        <a href="https://github.com/oguzhnatly/prompt-craft" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-link">
          <svg viewBox="0 0 20 20" fill="none"><path d="M10 2C5.58 2 2 5.58 2 10c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0018 10c0-4.42-3.58-8-8-8z" fill="currentColor"/></svg>
        </a>
        <a href="https://twitter.com/oguzhnatly" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X" class="social-link">
          <svg viewBox="0 0 20 20" fill="none"><path d="M16.9 2.5H12.5l-9 14.5H7.9l9-14.5z M2.5 2.5l15 15" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/></svg>
        </a>
        <a href="mailto:hello@promptcraft.app" aria-label="Email us" class="social-link">
          <svg viewBox="0 0 20 20" fill="none"><rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-nav">
      <div class="footer-col">
        <div class="col-label font-mono">Product</div>
        <a href="/#architecture">Architecture</a>
        <a href="/#features">Features</a>
        <a href="/pricing">Pricing</a>
        <a href="/download">Download</a>
        <a href="/docs">Documentation</a>
      </div>
      <div class="footer-col">
        <div class="col-label font-mono">Developers</div>
        <a href="https://github.com/oguzhnatly/prompt-craft" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://github.com/oguzhnatly/prompt-craft/blob/main/docs/RMPA_WHITEPAPER.md" target="_blank" rel="noopener noreferrer">RMPA Whitepaper</a>
        <a href="https://github.com/oguzhnatly/prompt-craft/releases" target="_blank" rel="noopener noreferrer">Releases</a>
      </div>
      <div class="footer-col">
        <div class="col-label font-mono">Legal</div>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="mailto:hello@promptcraft.app">Contact</a>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <span class="font-mono" style="font-size:11px;color:var(--text-3)">© 2026 PromptCraft. All rights reserved.</span>
      <span class="font-mono" style="font-size:11px;color:var(--text-3)">Built by <a href="https://github.com/oguzhnatly" target="_blank" rel="noopener noreferrer" style="color:var(--teal);text-decoration:none">@oguzhnatly</a> in Lisbon 🇵🇹</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--void);
    padding-top: 60px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px 60px;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 80px;
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text-1);
    font-size: 15px;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  .footer-logo strong { font-weight: 700; }

  .footer-tagline {
    font-size: 13px;
    line-height: 1.65;
    color: var(--text-3);
    margin-bottom: 20px;
  }

  .footer-socials { display: flex; gap: 12px; }
  .social-link {
    width: 32px; height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--text-3);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .social-link:hover {
    border-color: rgba(0,255,178,0.2);
    color: var(--text-1);
    background: rgba(255,255,255,0.03);
  }
  .social-link svg { width: 14px; height: 14px; }

  /* Nav */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .col-label {
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .footer-col a {
    font-size: 13px;
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.2s;
    width: fit-content;
  }
  .footer-col a:hover { color: var(--text-1); }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid var(--border);
  }
  .footer-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 40px; padding: 0 20px 40px; }
    .footer-nav { grid-template-columns: 1fr 1fr; gap: 28px; }
    .footer-bottom-inner { padding: 16px 20px; flex-direction: column; align-items: flex-start; gap: 4px; }
  }
</style>
