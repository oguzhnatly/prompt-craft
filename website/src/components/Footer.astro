---
---

<footer class="relative border-t border-border bg-void">

  <div class="max-w-6xl mx-auto px-6 py-16">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          <div class="w-7 h-7 relative">
            <svg viewBox="0 0 32 32" fill="none" class="w-full h-full">
              <circle cx="16" cy="16" r="14" stroke="#00FFB2" stroke-width="1.5" stroke-dasharray="4 2" opacity="0.4" />
              <line x1="16" y1="4" x2="16" y2="8" stroke="#00FFB2" stroke-width="1.5" />
              <line x1="16" y1="24" x2="16" y2="28" stroke="#00FFB2" stroke-width="1.5" />
              <line x1="4" y1="16" x2="8" y2="16" stroke="#00FFB2" stroke-width="1.5" />
              <line x1="24" y1="16" x2="28" y2="16" stroke="#00FFB2" stroke-width="1.5" />
              <circle cx="16" cy="16" r="3" fill="#00FFB2" opacity="0.9" />
              <circle cx="16" cy="16" r="6" stroke="#00FFB2" stroke-width="1" opacity="0.3" />
            </svg>
          </div>
          <span class="font-mono text-[14px] font-semibold">Prompt<span class="text-teal">Craft</span></span>
        </a>
        <p class="text-[13px] text-ink-secondary leading-relaxed max-w-xs mb-5">
          Stop typing. Start engineering. Transforms casual requests into precision AI directives using Recursive Meta Prompt Architecture.
        </p>
        <div class="flex items-center gap-4">
          <a href="https://github.com/oguzhnatly/prompt-craft" target="_blank" rel="noopener" class="text-ink-muted hover:text-teal transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="https://twitter.com/oguzhnatly" target="_blank" rel="noopener" class="text-ink-muted hover:text-teal transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <div class="font-mono text-[11px] text-teal/60 tracking-widest uppercase mb-5">Product</div>
        <ul class="space-y-3">
          {['Features', 'Pipeline', 'Pricing', 'Download', 'Changelog'].map(item => (
            <li>
              <a href={`/${item.toLowerCase()}`} class="text-[13px] text-ink-secondary hover:text-ink transition-colors">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Developers -->
      <div>
        <div class="font-mono text-[11px] text-teal/60 tracking-widest uppercase mb-5">Developers</div>
        <ul class="space-y-3">
          {[
            { label: 'RMPA Whitepaper', href: '/docs/rmpa' },
            { label: 'Alfred Workflow', href: 'https://github.com/oguzhnatly/prompt-craft', external: true },
            { label: 'Raycast Extension', href: 'https://github.com/oguzhnatly/prompt-craft', external: true },
            { label: 'Quick Start', href: '/docs' },
            { label: 'GitHub', href: 'https://github.com/oguzhnatly/prompt-craft', external: true },
          ].map(item => (
            <li>
              <a
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
                class="text-[13px] text-ink-secondary hover:text-ink transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 border-t border-border gap-4">
      <p class="font-mono text-[11px] text-ink-muted">
        © 2026 PromptCraft · macOS 14+ · Recursive Meta Prompt Architecture v1.1
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="font-mono text-[11px] text-ink-muted hover:text-ink transition-colors">Privacy</a>
        <a href="/terms" class="font-mono text-[11px] text-ink-muted hover:text-ink transition-colors">Terms</a>
        <a href="mailto:hello@promptcraft.app" class="font-mono text-[11px] text-ink-muted hover:text-teal transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
