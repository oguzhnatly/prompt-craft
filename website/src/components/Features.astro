---
const features = [
  {
    icon: `<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'Menu Bar First',
    desc: 'Lives quietly in your menu bar. One keyboard shortcut transforms any selected text. No app switching. No copy-paste loops. Pure keyboard-first flow.',
    tag: 'macOS Native',
  },
  {
    icon: `<path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/>`,
    title: 'Context Memory',
    desc: 'PromptCraft learns your project vocabulary. It knows your codebase names, your environment names, your people. Context engine injects learned details without asking.',
    tag: 'Cloud Feature',
    cloud: true,
  },
  {
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
    title: 'Multi-Provider',
    desc: 'Routes to Claude, GPT-4o, DeepSeek, or your local Ollama instance. Switch providers mid-session without reconfiguring anything. Your prompts, your providers.',
    tag: 'All Tiers',
  },
  {
    icon: `<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>`,
    title: 'Style Engine',
    desc: 'Define custom style presets: concise, detailed, developer mode, executive summary. The Post Processor enforces your style constraints on every output, automatically.',
    tag: 'Customizable',
  },
  {
    icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    title: 'Alfred + Raycast',
    desc: 'Full workflow integration. Trigger optimization from Alfred workflows or Raycast commands. Open source extensions available on GitHub.',
    tag: 'Extensions',
  },
  {
    icon: `<path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
    title: 'Inline Optimize',
    desc: 'Select text in any app, hit the shortcut, get the optimized version in your clipboard instantly. Works in Xcode, VS Code, Terminal, Notion, Linear, everywhere.',
    tag: 'System-wide',
  },
];
---

<section id="features" class="py-32 relative bg-void">

  <!-- Ambient glow -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-teal/20 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-20 text-center" data-reveal>
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-16 h-px bg-teal/30"></div>
        <span class="font-mono text-[11px] text-teal/60 tracking-widest uppercase">Features</span>
        <div class="w-16 h-px bg-teal/30"></div>
      </div>
      <h2 class="text-[52px] font-black tracking-tight text-ink leading-none mb-4">
        Built for the flow state.<br />
        <span class="text-teal">Not for interruptions.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feat, i) => (
        <div
          class="group relative p-6 rounded-xl border border-border bg-panel hover:border-teal/20 hover:bg-panel/80 transition-all duration-300"
          data-reveal
          data-reveal-delay={String((i % 6) + 1)}
        >
          <!-- Top-right corner bracket -->
          <div class="absolute top-4 right-4 w-4 h-4 border-r border-t border-teal/15 group-hover:border-teal/30 transition-colors"></div>

          <!-- Icon -->
          <div class="w-10 h-10 rounded-lg border border-border bg-surface flex items-center justify-center mb-5 group-hover:border-teal/20 transition-colors">
            <svg class="w-5 h-5 text-teal" viewBox="0 0 24 24" fill="none" set:html={feat.icon} />
          </div>

          <!-- Title + tag -->
          <div class="flex items-center gap-3 mb-3">
            <h3 class="font-sans text-[15px] font-semibold text-ink">{feat.title}</h3>
            <span class={`font-mono text-[10px] px-2 py-0.5 rounded tracking-wider ${feat.cloud ? 'bg-teal/10 text-teal border border-teal/20' : 'bg-border text-ink-muted'}`}>
              {feat.tag}
            </span>
          </div>

          <p class="text-[13px] text-ink-secondary leading-relaxed">{feat.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
