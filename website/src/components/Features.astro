---
---

<section id="features" class="features-section grid-bg ambient-top">
  <div class="container">

    <div class="features-header">
      <div class="section-tag reveal">
        <span class="mono">Features</span>
      </div>
      <h2 class="section-title reveal reveal-d1">
        Built for the flow state.<br />
        <span class="gradient-text">Not for interruptions.</span>
      </h2>
    </div>

    <div class="features-grid">

      <!-- Large card: Menu Bar First -->
      <div class="feature-card feature-large reveal">
        <div class="card-inner">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="feature-tag mono">macOS Native</div>
          <h3 class="feature-title">Menu Bar First</h3>
          <p class="feature-desc">
            Lives in your menu bar. One keyboard shortcut. Select text anywhere, press the shortcut,
            get precision back in your clipboard. Works in Xcode, VS Code, Terminal, Notion, Linear — everywhere.
            Zero app switching. Zero workflow interruption.
          </p>
          <!-- Mock menu bar -->
          <div class="mock-menubar">
            <div class="mock-bar mono">
              <span>Fri 14:32</span>
              <span class="mock-icon">⌘⇧P</span>
              <span class="mock-active">●</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Medium card: Context Memory -->
      <div class="feature-card feature-medium reveal reveal-d1">
        <div class="card-inner">
          <div class="feature-icon" style="background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.2);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" style="color:#818CF8">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="feature-tag mono" style="color:#818CF8;border-color:rgba(129,140,248,0.2);background:rgba(129,140,248,0.06)">Cloud Feature</div>
          <h3 class="feature-title">Context Memory</h3>
          <p class="feature-desc">
            PromptCraft learns your codebase. It knows your project names, your environment names,
            your team's vocabulary. Context injects automatically — without you ever adding a word.
          </p>
        </div>
      </div>

      <!-- Medium card: Multi-Provider -->
      <div class="feature-card feature-medium reveal reveal-d2">
        <div class="card-inner">
          <div class="feature-icon" style="background: rgba(251,146,60,0.1); border-color: rgba(251,146,60,0.2);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" style="color:#FB923C">
              <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="feature-tag mono" style="color:#FB923C;border-color:rgba(251,146,60,0.2);background:rgba(251,146,60,0.06)">All Tiers</div>
          <h3 class="feature-title">Any Model</h3>
          <p class="feature-desc">
            Claude, GPT-4o, DeepSeek, or your local Ollama. Switch mid-session.
            Cloud users need zero API keys — the relay handles everything.
          </p>
        </div>
      </div>

      <!-- Small card: Raycast -->
      <div class="feature-card feature-small reveal">
        <div class="card-inner">
          <div class="feature-icon" style="background: rgba(192,132,252,0.1); border-color: rgba(192,132,252,0.2);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="color:#C084FC">
              <path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M13 2v7h7" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="feature-tag mono" style="color:#C084FC;border-color:rgba(192,132,252,0.2);background:rgba(192,132,252,0.06)">Open Source</div>
          <h3 class="feature-title">Alfred + Raycast</h3>
          <p class="feature-desc">Full workflow integration. Trigger from Alfred or Raycast. Extensions open source on GitHub.</p>
        </div>
      </div>

      <!-- Small card: Style Engine -->
      <div class="feature-card feature-small reveal reveal-d1">
        <div class="card-inner">
          <div class="feature-icon" style="background: rgba(244,114,182,0.1); border-color: rgba(244,114,182,0.2);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="color:#F472B6">
              <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="feature-tag mono" style="color:#F472B6;border-color:rgba(244,114,182,0.2);background:rgba(244,114,182,0.06)">Customizable</div>
          <h3 class="feature-title">Style Engine</h3>
          <p class="feature-desc">Define custom style presets. The Post Processor enforces your style on every output.</p>
        </div>
      </div>

      <!-- Small card: History -->
      <div class="feature-card feature-small reveal reveal-d2">
        <div class="card-inner">
          <div class="feature-icon" style="background: rgba(0,229,160,0.1); border-color: rgba(0,229,160,0.2);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="color:var(--teal)">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="feature-tag mono">All Tiers</div>
          <h3 class="feature-title">Prompt History</h3>
          <p class="feature-desc">Full history with search. Replay any previous optimization instantly. Cloud: unlimited storage.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 120px 24px;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .features-header {
    max-width: 640px;
    margin-bottom: 64px;
  }

  .section-tag {
    display: inline-flex;
    font-size: 11px;
    color: var(--teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 24px;
    padding: 5px 12px;
    border: 1px solid rgba(0,229,160,0.18);
    border-radius: 100px;
    background: rgba(0,229,160,0.05);
  }

  .section-title {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-primary);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--teal), #818CF8);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 16px;
  }

  .feature-large { grid-column: span 1; grid-row: span 2; }
  .feature-medium { grid-column: span 1; }
  .feature-small { grid-column: span 1; }

  .feature-card {
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
    cursor: default;
  }

  .feature-card:hover {
    border-color: rgba(0,229,160,0.18);
    transform: translateY(-4px);
  }

  .card-inner {
    padding: 28px;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1px solid rgba(0,229,160,0.2);
    background: rgba(0,229,160,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--teal);
    flex-shrink: 0;
    transition: transform 0.3s;
  }

  .feature-card:hover .feature-icon { transform: rotate(5deg) scale(1.05); }

  .feature-tag {
    font-size: 10px;
    color: var(--teal);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border: 1px solid rgba(0,229,160,0.2);
    border-radius: 100px;
    background: rgba(0,229,160,0.06);
    display: inline-flex;
    width: fit-content;
  }

  .feature-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.03em;
  }

  .feature-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .mock-menubar {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .mock-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: var(--base);
    border-radius: 8px;
    border: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
  }

  .mock-icon {
    color: var(--teal);
    font-size: 11px;
  }

  .mock-active {
    color: var(--teal);
    font-size: 8px;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
    .feature-large { grid-column: span 1; grid-row: span 1; }
  }
</style>
