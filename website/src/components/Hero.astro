---
import AppWindow from './AppWindow.astro';
---

<section id="hero" class="hero-section">
  <!-- Gradient bg -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hb-blob hb-1"></div>
    <div class="hb-blob hb-2"></div>
    <div class="hb-blob hb-3"></div>
    <div class="hb-grid"></div>
  </div>

  <div class="container hero-inner">
    <!-- Left: copy -->
    <div class="hero-left">
      <div class="badge teal" style="margin-bottom:32px" data-reveal>
        <span class="badge-dot"></span>
        RMPA v1.1 · macOS 14+ · Available Now
      </div>

      <h1 class="hero-h1" data-reveal data-reveal-d="1">
        <span class="h1-line">The AI doesn't</span>
        <span class="h1-line">hear what you</span>
        <span class="h1-line h1-accent">actually mean.</span>
      </h1>

      <p class="hero-body" data-reveal data-reveal-d="2">
        PromptCraft runs silently in your macOS menu bar.
        Every prompt you write passes through 7 precision stages
        before reaching any AI. The difference is measurable.
      </p>

      <div class="hero-ctas" data-reveal data-reveal-d="3">
        <a href="/download" class="btn btn-teal">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 2v9M3 8l5 5 5-5M1 14h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Free Download
        </a>
        <a href="/pricing" class="btn btn-outline">
          See Pricing
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="hero-proof" data-reveal data-reveal-d="4">
        <div class="proof-item">
          <span class="proof-num syne">340%</span>
          <span class="proof-label">avg clarity gain</span>
        </div>
        <div class="proof-sep"></div>
        <div class="proof-item">
          <span class="proof-num syne">7</span>
          <span class="proof-label">pipeline stages</span>
        </div>
        <div class="proof-sep"></div>
        <div class="proof-item">
          <span class="proof-num syne">&lt;200ms</span>
          <span class="proof-label">overhead</span>
        </div>
      </div>
    </div>

    <!-- Right: macOS window -->
    <div class="hero-right" data-reveal data-reveal-d="2">
      <div class="window-float" id="window-float">
        <!-- Glow behind window -->
        <div class="win-glow" aria-hidden="true"></div>
        <!-- Menu bar pointer -->
        <div class="win-pointer" aria-hidden="true">
          <svg viewBox="0 0 40 16" fill="none">
            <path d="M0 16 L20 0 L40 16" fill="var(--win-bg-2)"/>
          </svg>
        </div>
        <!-- The real app window -->
        <AppWindow />
        <!-- macOS menu bar above the window -->
        <div class="sim-menubar" aria-label="Simulated macOS menu bar" aria-hidden="true">
          <div class="smb-left">
            <span class="smb-apple">&#63743;</span>
            <span class="smb-item">Finder</span>
            <span class="smb-item">File</span>
            <span class="smb-item">Edit</span>
          </div>
          <div class="smb-right">
            <span class="smb-sys mono">14:07</span>
            <!-- Wifi -->
            <svg class="smb-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M8 11a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm0-3.5c1.38 0 2.62.56 3.53 1.47L13 7.5C11.73 6.18 9.96 5.36 8 5.36S4.27 6.18 3 7.5l1.47 1.47A5.02 5.02 0 018 7.5zm0-3.86c2.32 0 4.42.94 5.95 2.47l1.41-1.41A10.45 10.45 0 008 1.14C5.42 1.14 3.08 2.15 1.36 3.78l1.41 1.41A8.41 8.41 0 018 3.64z" opacity=".8"/></svg>
            <!-- Battery -->
            <svg class="smb-icon" viewBox="0 0 20 12" fill="none"><rect x="1" y="1" width="15" height="10" rx="2" stroke="currentColor" stroke-width="1.2"/><rect x="2.5" y="2.5" width="8" height="7" rx="1" fill="currentColor"/><path d="M17 4v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
            <!-- PromptCraft icon — glowing -->
            <div class="smb-pc-icon" id="smb-pc">
              <svg width="17" height="17" viewBox="0 0 22 22" fill="none">
                <circle cx="11" cy="11" r="2" fill="#00C896"/>
                <line x1="11" y1="2"  x2="11" y2="7"  stroke="#00C896" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="11" y1="15" x2="11" y2="20" stroke="#00C896" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="2"  y1="11" x2="7"  y2="11" stroke="#00C896" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="15" y1="11" x2="20" y2="11" stroke="#00C896" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating labels -->
      <div class="float-label fl-1 mono" aria-hidden="true">
        <span class="fl-dot"></span>
        7 stages active
      </div>
      <div class="float-label fl-2 mono" aria-hidden="true">
        <span class="fl-dot" style="background:#7B61FF"></span>
        claude-3-5-sonnet
      </div>
      <div class="float-label fl-3 mono" aria-hidden="true">
        <span class="fl-dot" style="background:#FF5441"></span>
        +340% clarity
      </div>
    </div>
  </div>

  <!-- Bottom logos -->
  <div class="hero-compat" data-reveal>
    <span class="mono" style="font-size:11px;color:var(--ink-4)">Works with</span>
    <div class="compat-logos">
      <span class="compat-item mono">Claude</span>
      <span class="compat-dot">·</span>
      <span class="compat-item mono">GPT-4o</span>
      <span class="compat-dot">·</span>
      <span class="compat-item mono">DeepSeek</span>
      <span class="compat-dot">·</span>
      <span class="compat-item mono">Gemini</span>
      <span class="compat-dot">·</span>
      <span class="compat-item mono">Llama</span>
      <span class="compat-dot">·</span>
      <span class="compat-item mono">Mistral</span>
      <span class="compat-dot">·</span>
      <span class="compat-item mono">Perplexity</span>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    padding-top: 64px; /* nav height */
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Background ──────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .hb-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.55;
  }
  .hb-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(0,200,150,0.18) 0%, transparent 70%);
    top: -100px; left: -150px;
    animation: blob-drift 14s ease-in-out infinite alternate;
  }
  .hb-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(79,63,240,0.1) 0%, transparent 70%);
    top: 20%; right: -100px;
    animation: blob-drift 18s ease-in-out infinite alternate-reverse;
  }
  .hb-3 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(245,166,35,0.07) 0%, transparent 70%);
    bottom: 10%; left: 30%;
    animation: blob-drift 22s ease-in-out infinite alternate;
  }
  @keyframes blob-drift {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(30px,20px) scale(1.08); }
  }

  .hb-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--border-2) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-2) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }

  /* ── Layout ──────────────────────── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
    flex: 1;
    padding-top: 80px;
    padding-bottom: 60px;
    position: relative; z-index: 1;
  }

  /* ── Left copy ───────────────────── */
  .hero-left { display: flex; flex-direction: column; }

  .hero-h1 {
    display: flex; flex-direction: column;
    font-size: clamp(38px, 4.5vw, 58px);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 24px;
  }
  .h1-accent {
    color: var(--teal-d);
    position: relative;
  }
  .h1-accent::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--teal) 0%, var(--teal-d) 100%);
    border-radius: 2px;
    opacity: 0.4;
  }

  .hero-body {
    font-size: 16px;
    line-height: 1.75;
    color: var(--ink-2);
    margin-bottom: 36px;
    max-width: 460px;
    font-weight: 400;
  }

  .hero-ctas {
    display: flex; gap: 12px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .hero-proof {
    display: flex; align-items: center; gap: 0;
    padding: 16px 0;
    border-top: 1px solid var(--border);
  }
  .proof-item {
    display: flex; flex-direction: column; gap: 2px;
    padding: 0 24px;
    flex: 1; align-items: center;
  }
  .proof-item:first-child { padding-left: 0; }
  .proof-item:last-child  { padding-right: 0; }
  .proof-num {
    font-size: 26px; font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--ink);
    line-height: 1;
  }
  .proof-label {
    font-size: 11px;
    color: var(--ink-3);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.04em;
  }
  .proof-sep { width: 1px; height: 32px; background: var(--border); }

  /* ── Right window ────────────────── */
  .hero-right {
    display: flex; justify-content: center;
    position: relative;
  }

  .window-float {
    position: relative;
    transform-style: preserve-3d;
    transition: transform .12s ease-out;
  }

  .win-glow {
    position: absolute;
    inset: -60px;
    background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(0,200,150,0.12), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .win-pointer {
    position: absolute;
    top: -14px;
    right: 72px;
    width: 40px;
    z-index: 2;
    filter: drop-shadow(0 -2px 4px rgba(0,0,0,0.15));
  }

  /* Reorder: menubar above window */
  .window-float { display: flex; flex-direction: column; gap: 0; }

  .sim-menubar {
    order: -1;
    background: rgba(28,28,30,0.97);
    border-radius: 10px 10px 0 0;
    border: 1px solid rgba(255,255,255,0.12);
    border-bottom: none;
    height: 26px;
    display: flex; align-items: center;
    justify-content: space-between;
    padding: 0 12px;
    position: relative; z-index: 1;
  }

  .mac-window { border-radius: 0 0 13px 13px !important; }

  .smb-left, .smb-right {
    display: flex; align-items: center; gap: 14px;
  }
  .smb-apple { font-size: 13px; color: rgba(255,255,255,0.85); line-height: 1; }
  .smb-item {
    font-family: -apple-system, sans-serif;
    font-size: 12px; font-weight: 500;
    color: rgba(255,255,255,0.85);
  }
  .smb-sys {
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.02em;
  }
  .smb-icon {
    width: 15px; height: 15px;
    color: rgba(255,255,255,0.7);
    flex-shrink: 0;
  }
  .smb-pc-icon {
    display: flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    border-radius: 5px;
    cursor: none;
    animation: pc-pop 3s ease-in-out 1.5s 2;
  }
  @keyframes pc-pop {
    0%,100% { filter: drop-shadow(0 0 0 transparent); }
    50%      { filter: drop-shadow(0 0 8px rgba(0,200,150,0.8)); }
  }

  /* Floating labels */
  .float-label {
    position: absolute;
    display: flex; align-items: center; gap: 6px;
    padding: 5px 10px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 11px;
    color: var(--ink-2);
    box-shadow: 0 2px 16px rgba(12,11,24,0.08);
    white-space: nowrap;
    z-index: 10;
    animation: fl-float 4s ease-in-out infinite alternate;
  }
  .fl-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--teal);
    flex-shrink: 0;
  }
  .fl-1 { left: -100px; top: 80px; animation-delay: 0s; }
  .fl-2 { right: -90px; top: 160px; animation-delay: 1.5s; }
  .fl-3 { left: -80px; bottom: 80px; animation-delay: 3s; }
  @keyframes fl-float {
    from { transform: translateY(0); }
    to   { transform: translateY(-6px); }
  }

  /* ── Compat logos ────────────────── */
  .hero-compat {
    display: flex; align-items: center;
    gap: 20px;
    padding: 20px 0 32px;
    border-top: 1px solid var(--border);
    margin: 0 40px;
    position: relative; z-index: 1;
  }
  .compat-logos {
    display: flex; align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .compat-item {
    font-size: 12px;
    color: var(--ink-3);
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .compat-dot { color: var(--border); font-size: 14px; }

  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; padding-top: 40px; gap: 40px; }
    .hero-right { order: -1; }
    .float-label { display: none; }
    .hero-compat { margin: 0 20px; }
  }

  @media (max-width: 480px) {
    .mac-window { width: 340px !important; }
    .win-title { display: none; }
  }
</style>

<script>
  // Mouse-reactive 3D tilt on the window
  const wf  = document.getElementById('window-float') as HTMLElement | null;
  const hero = document.getElementById('hero') as HTMLElement | null;

  if (wf && hero) {
    hero.addEventListener('mousemove', (e) => {
      const r  = hero.getBoundingClientRect();
      const cx = r.left + r.width  / 2;
      const cy = r.top  + r.height / 2;
      const rx = ((e.clientY - cy) / r.height) * 10;
      const ry = -((e.clientX - cx) / r.width)  * 12;
      wf.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg)`;
    }, { passive: true });

    hero.addEventListener('mouseleave', () => {
      wf.style.transform = 'perspective(1000px) rotateX(0) rotateY(0)';
    });
  }
</script>
