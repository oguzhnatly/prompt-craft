---
import AppWindow from './AppWindow.astro';
---

<section id="hero" aria-label="Product introduction">

  <!-- ── Two-column hero: copy left, app window right ── -->
  <div class="hero-main">
    <div class="wrap hm-grid">

      <!-- Copy column -->
      <div class="hm-copy">
        <div class="hmc-eyebrow" data-reveal>
          <span class="eyebrow">
            <span class="eyebrow-dot"></span>
            macOS menu bar · v1.1 · Apple Silicon + Intel
          </span>
        </div>

        <h1 class="hmc-h1" data-reveal data-d="1">
          Every prompt is optimized in seven stages<br>before any model sees it.
        </h1>

        <p class="hmc-body" data-reveal data-d="2">
          PromptCraft lives in your menu bar and silently engineers every prompt through a 7 stage pipeline.
          The model receives structured intent, preserved entities, context from your active app, and a style specific final prompt.
          Local with Ollama or cloud with major providers, all from the same interface.
        </p>

        <div class="hmc-ctas" data-reveal data-d="3">
          <a href="/download" class="btn btn-ink hmc-btn-main">
            <iconify-icon icon="lucide:download" style="font-size:15px;" aria-hidden="true"></iconify-icon>
            Download for Mac — Free
          </a>
          <a href="/pricing" class="btn btn-text hmc-btn-sub">
            Pro · $99 one-time
            <iconify-icon icon="lucide:arrow-right" style="font-size:14px;" aria-hidden="true"></iconify-icon>
          </a>
        </div>

        <!-- Metrics -->
        <div class="hmc-metrics" data-reveal data-d="4">
          <div class="hmc-metric">
            <span class="hmcm-n">340%</span>
            <span class="hmcm-l mono">avg prompt clarity gain</span>
          </div>
          <div class="hmc-sep" aria-hidden="true"></div>
          <div class="hmc-metric">
            <span class="hmcm-n">&lt;200ms</span>
            <span class="hmcm-l mono">pipeline overhead</span>
          </div>
          <div class="hmc-sep" aria-hidden="true"></div>
          <div class="hmc-metric">
            <span class="hmcm-n">7</span>
            <span class="hmcm-l mono">optimization stages</span>
          </div>
        </div>
      </div>

      <!-- App window column -->
      <div class="hm-window" data-reveal data-d="2" aria-label="PromptCraft app demo">
        <div class="hmw-frame">
          <AppWindow />
        </div>
      </div>

    </div>
  </div>

  <!-- ── AI provider logos ── -->
  <div class="hero-providers">
    <div class="wrap hp-inner">
      <span class="hp-label mono">Works with</span>
      <div class="hp-logos" role="list" aria-label="Supported AI providers">

        <div class="hp-logo" role="listitem" aria-label="Anthropic Claude">
          <svg class="hp-icon" viewBox="0 0 24 24" fill="#D97757">
            <path d="M17.338 4l-4.73 8.21L7.88 4H4l6.663 11.547L6.72 20h3.696l1.252-2.172.14.242L13.028 20H16.7l-3.937-6.82L19.282 4z"/>
          </svg>
          <span>Claude</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="OpenAI GPT-4o">
          <svg class="hp-icon" viewBox="0 0 24 24" fill="var(--ink)">
            <path d="M22.28 9.81a6 6 0 00-.52-4.92 6.07 6.07 0 00-6.5-2.91 6 6 0 00-4.5-2A6.07 6.07 0 005 3.52a6 6 0 00-4 3.63 6.07 6.07 0 00.75 7.1 6 6 0 00.52 4.92 6.07 6.07 0 006.5 2.91 6 6 0 004.5 2 6.07 6.07 0 005.76-4.21 6 6 0 004-3.63 6.07 6.07 0 00-.75-7.53zM13.5 21.5a4.51 4.51 0 01-2.88-1.04l.14-.08 4.77-2.76a.78.78 0 00.39-.68v-6.73l2.02 1.16a.07.07 0 010 .05v5.58a4.51 4.51 0 01-4.44 4.5zm-9.64-4.14a4.51 4.51 0 01-.54-3.02l.14.08 4.77 2.76a.78.78 0 00.78 0l5.83-3.37v2.32a.07.07 0 010 .06l-4.83 2.79a4.51 4.51 0 01-6.15-1.62zm-1.25-10.5a4.51 4.51 0 012.37-1.97v5.7a.78.78 0 00.39.67l5.83 3.37-2.02 1.17a.07.07 0 01-.07 0L4.42 12.4a4.51 4.51 0 01-1.81-5.54zm16.6 3.86l-5.83-3.37 2.02-1.16a.07.07 0 01.07 0l4.77 2.76a4.5 4.5 0 01-.7 8.12V11.3a.78.78 0 00-.33-.58zm2.01-3.03l-.14-.08-4.77-2.75a.78.78 0 00-.79 0L9.7 8.23V5.91a.07.07 0 010-.06L14.53 3.1a4.5 4.5 0 016.69 4.69zm-12.63 4.14l-2.02-1.17a.07.07 0 010-.05V4.99a4.5 4.5 0 017.37-3.46l-.14.08-4.77 2.76a.78.78 0 00-.39.68l-.05 6.72zm1.09-2.37l2.6-1.5 2.6 1.5v3l-2.6 1.5-2.6-1.5V9.46z"/>
          </svg>
          <span>GPT-4o</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Google Gemini">
          <svg class="hp-icon" viewBox="0 0 24 24">
            <defs>
              <linearGradient id="gem-g3" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#4285F4"/>
                <stop offset="50%" stop-color="#9B72CB"/>
                <stop offset="100%" stop-color="#D96570"/>
              </linearGradient>
            </defs>
            <path d="M12 2C6.9 8.5 6.9 15.5 12 22c5.1-6.5 5.1-13.5 0-20zM2 12c6.5 5.1 13.5 5.1 20 0C15.5 6.9 8.5 6.9 2 12z" fill="url(#gem-g3)"/>
          </svg>
          <span>Gemini</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="DeepSeek">
          <svg class="hp-icon" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="#4D6AFF" stroke-width="1.5"/>
            <circle cx="12" cy="12" r="4" fill="#4D6AFF"/>
          </svg>
          <span>DeepSeek</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Meta Llama 3">
          <svg class="hp-icon" viewBox="0 0 24 24" fill="#0081FB">
            <path d="M13.97 5.96c-1.42-1.45-3.33-2.12-5.2-1.74C5.9 4.8 4 7.1 4 9.84c0 1.44.4 2.87 1.22 4.05L12 22l6.78-8.11A7.48 7.48 0 0020 9.84c0-2.74-1.9-5.04-4.77-5.62a5.4 5.4 0 00-1.26-.26zm1.48 10.46L12 19.4l-3.45-2.98A5.47 5.47 0 016.5 9.84C6.5 7.88 7.82 6.2 9.5 6c1.06-.13 2.14.25 2.94.95.08.07.7.68.56.58.8-.7 1.88-1.08 2.94-.95 1.68.2 3 1.88 3 3.84a5.47 5.47 0 01-1.49 3.2v.8z"/>
          </svg>
          <span>Llama 3</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Mistral AI">
          <svg class="hp-icon" viewBox="0 0 24 24" fill="#FF7000">
            <rect x="3" y="3" width="4" height="4" rx=".5"/>
            <rect x="10" y="3" width="4" height="4" rx=".5"/>
            <rect x="17" y="3" width="4" height="4" rx=".5"/>
            <rect x="3" y="10" width="4" height="4" rx=".5"/>
            <rect x="17" y="10" width="4" height="4" rx=".5"/>
            <rect x="3" y="17" width="4" height="4" rx=".5"/>
            <rect x="10" y="17" width="4" height="4" rx=".5"/>
            <rect x="17" y="17" width="4" height="4" rx=".5"/>
          </svg>
          <span>Mistral</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Ollama local models">
          <svg class="hp-icon" viewBox="0 0 24 24" fill="var(--ink2)">
            <circle cx="12" cy="7" r="4"/>
            <path d="M8 12c-3 1-5 3-5 5v2h18v-2c0-2-2-4-5-5"/>
            <circle cx="9"  cy="9.5" r="1.2" fill="var(--bg)"/>
            <circle cx="15" cy="9.5" r="1.2" fill="var(--bg)"/>
          </svg>
          <span>Ollama</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="MiniMax">
          <iconify-icon class="hp-icon" icon="lucide:layers-3" style="color:#8b5cf6"></iconify-icon>
          <span>MiniMax</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Moonshot Kimi">
          <iconify-icon class="hp-icon" icon="lucide:moon-star" style="color:#4f46e5"></iconify-icon>
          <span>Kimi</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="xAI Grok">
          <iconify-icon class="hp-icon" icon="lucide:sparkles" style="color:#111827"></iconify-icon>
          <span>Grok</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Z AI GLM">
          <iconify-icon class="hp-icon" icon="lucide:atom" style="color:#16a34a"></iconify-icon>
          <span>GLM</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Arcee">
          <iconify-icon class="hp-icon" icon="lucide:hexagon" style="color:#0f766e"></iconify-icon>
          <span>Arcee</span>
        </div>

      </div>
    </div>
  </div>

</section>

<style>
  #hero { background: var(--bg); padding-top: 60px; }

  /* Two-column main grid */
  .hero-main {
    padding: 72px 0 36px;
    min-height: calc(100vh - 220px);
    display: flex; align-items: center;
  }

  .hm-grid {
    display: grid;
    grid-template-columns: 1fr 460px;
    gap: 72px;
    align-items: center;
    width: 100%;
  }

  /* Copy column */
  .hm-copy { display: flex; flex-direction: column; }
  .hmc-eyebrow { margin-bottom: 28px; }

  .hmc-h1 {
    font-size: clamp(38px, 4.8vw, 74px);
    font-weight: 700; letter-spacing: -0.055em; line-height: 1.03;
    color: var(--ink); margin-bottom: 22px;
    max-width: 720px;
  }

  .hmc-body {
    font-size: 16px; line-height: 1.74; color: var(--mid);
    max-width: 560px; margin-bottom: 30px;
  }

  .hmc-ctas { display: flex; align-items: center; gap: 4px; margin-bottom: 44px; flex-wrap: wrap; }
  .hmc-btn-main { padding: 13px 24px; font-size: 15px; border-radius: 9px; }
  .hmc-btn-sub  { padding: 13px 14px; font-size: 15px; color: var(--mid); }
  .hmc-btn-sub:hover { color: var(--ink); }

  /* Metrics */
  .hmc-metrics { display: flex; align-items: center; }
  .hmc-metric  { display: flex; flex-direction: column; gap: 3px; padding: 0 20px; }
  .hmc-metric:first-child { padding-left: 0; }
  .hmcm-n { font-size: 20px; font-weight: 700; letter-spacing: -0.04em; color: var(--ink); line-height: 1; }
  .hmcm-l { font-size: 9px; color: var(--dim); letter-spacing: 0.06em; text-transform: uppercase; }
  .hmc-sep { width: 1px; height: 26px; background: var(--bdr-hi); margin: 0 4px; }

  /* App window column */
  .hm-window {
    display: flex; justify-content: center; align-items: center;
  }
  .hmw-frame {
    filter: drop-shadow(0 20px 48px rgba(0,0,0,0.14)) drop-shadow(0 4px 8px rgba(0,0,0,0.06));
    transition: filter .3s;
  }
  .hmw-frame:hover {
    filter: drop-shadow(0 28px 64px rgba(0,0,0,0.18)) drop-shadow(0 8px 16px rgba(0,0,0,0.08));
  }

  /* Provider logos */
  .hero-providers { padding: 0 0 56px; border-top: 1px solid var(--bdr); }
  .hp-inner { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; padding-top: 28px; }
  .hp-label { font-size: 10px; color: var(--dim); letter-spacing: 0.1em; text-transform: uppercase; flex-shrink: 0; }
  .hp-logos { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
  .hp-logo {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 6px;
    font-size: 13px; font-weight: 500; color: var(--mid);
    background: var(--bg2); border: 1px solid var(--bdr);
    transition: border-color .13s, color .13s;
  }
  .hp-logo:hover { border-color: var(--bdr-hi); color: var(--ink); }
  .hp-icon { width: 16px; height: 16px; flex-shrink: 0; }

  @media (max-width: 1024px) {
    .hm-grid { grid-template-columns: 1fr 380px; gap: 40px; }
  }
  @media (max-width: 860px) {
    .hero-main { min-height: auto; padding: 48px 0 26px; }
    .hm-grid { grid-template-columns: 1fr; gap: 28px; }
    .hm-window { justify-content: flex-start; }
    .hmw-frame { transform: scale(0.88); transform-origin: left top; }
    .hmc-h1 { max-width: 100%; }
  }
</style>
