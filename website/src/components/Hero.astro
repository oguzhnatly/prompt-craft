---
import AppWindow from './AppWindow.astro';
---

<section id="hero" aria-label="Product introduction">

  <!-- ── Two-column hero: copy left, app window right ── -->
  <div class="hero-main">
    <div class="wrap hm-grid">

      <!-- Copy column -->
      <div class="hm-copy">
        <div class="hmc-eyebrow" data-reveal>
          <span class="eyebrow">
            <span class="eyebrow-dot"></span>
            macOS menu bar · v1.1 · Apple Silicon + Intel
          </span>
        </div>

        <h1 class="hmc-h1" data-reveal data-d="1">
          Every prompt is optimized in seven stages<br>before any model sees it.
        </h1>

        <p class="hmc-body" data-reveal data-d="2">
          PromptCraft lives in your menu bar and silently engineers every prompt through a 7 stage pipeline.
          The model receives structured intent, preserved entities, context from your active app, and a style specific final prompt.
          Local with Ollama or cloud with major providers, all from the same interface.
        </p>

        <div class="hmc-ctas" data-reveal data-d="3">
          <a href="/download" class="btn btn-ink hmc-btn-main">
            <iconify-icon icon="lucide:download" style="font-size:15px;" aria-hidden="true"></iconify-icon>
            Download for Mac — Free
          </a>
          <a href="/pricing" class="btn btn-text hmc-btn-sub">
            Pro · $99 one-time
            <iconify-icon icon="lucide:arrow-right" style="font-size:14px;" aria-hidden="true"></iconify-icon>
          </a>
        </div>

        <!-- Metrics -->
        <div class="hmc-metrics" data-reveal data-d="4">
          <div class="hmc-metric">
            <span class="hmcm-n">340%</span>
            <span class="hmcm-l mono">avg prompt clarity gain</span>
          </div>
          <div class="hmc-sep" aria-hidden="true"></div>
          <div class="hmc-metric">
            <span class="hmcm-n">&lt;200ms</span>
            <span class="hmcm-l mono">pipeline overhead</span>
          </div>
          <div class="hmc-sep" aria-hidden="true"></div>
          <div class="hmc-metric">
            <span class="hmcm-n">7</span>
            <span class="hmcm-l mono">optimization stages</span>
          </div>
        </div>
      </div>

      <!-- App window column -->
      <div class="hm-window" data-reveal data-d="2" aria-label="PromptCraft app demo">
        <div class="hmw-frame">
          <AppWindow />
        </div>
        <a href="/terms#refunds" class="hmw-refund-pill" aria-label="Refund policy details">
          <span class="hmw-refund-icon" aria-hidden="true">
            <iconify-icon icon="lucide:shield-check" style="font-size:13px;"></iconify-icon>
          </span>
          <span class="hmw-refund-copy">
            <strong>14 day no questions refund</strong>
            <span class="mono">first cloud subscription only</span>
          </span>
        </a>
      </div>

    </div>
  </div>

  <!-- ── AI provider logos ── -->
  <div class="hero-providers">
    <div class="wrap hp-inner">
      <div class="hp-row hp-row-top">
      <span class="hp-label mono">Works with</span>
      <div class="hp-logos hp-logos-icons" role="list" aria-label="Supported AI providers">

        <div class="hp-logo" role="listitem" aria-label="Anthropic Claude" title="Anthropic Claude">
          <iconify-icon class="hp-icon" icon="simple-icons:anthropic" style="color:#D97757"></iconify-icon>
          <span>Claude</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="OpenAI GPT-4o" title="OpenAI GPT-4o">
          <iconify-icon class="hp-icon" icon="simple-icons:openai" style="color:var(--ink)"></iconify-icon>
          <span>GPT-4o</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Google Gemini" title="Google Gemini">
          <iconify-icon class="hp-icon" icon="simple-icons:googlegemini" style="color:#4285F4"></iconify-icon>
          <span>Gemini</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="DeepSeek" title="DeepSeek">
          <img class="hp-icon hp-icon-img" src="https://www.deepseek.com/favicon.ico" alt="DeepSeek logo" />
          <span>DeepSeek</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Meta Llama 3" title="Meta Llama 3">
          <iconify-icon class="hp-icon" icon="simple-icons:meta" style="color:#0081FB"></iconify-icon>
          <span>Llama 3</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="OpenRouter" title="OpenRouter">
          <iconify-icon class="hp-icon" icon="simple-icons:openrouter" style="color:#4D7CFF"></iconify-icon>
          <span>OpenRouter</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Ollama local models" title="Ollama">
          <iconify-icon class="hp-icon" icon="simple-icons:ollama" style="color:var(--ink2)"></iconify-icon>
          <span>Ollama</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="MiniMax" title="MiniMax">
          <iconify-icon class="hp-icon" icon="simple-icons:minimax" style="color:#8b5cf6"></iconify-icon>
          <span>MiniMax</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Moonshot Kimi" title="Kimi">
          <iconify-icon class="hp-icon" icon="lucide:moon-star" style="color:#4f46e5"></iconify-icon>
          <span>Kimi</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Zhipu GLM" title="GLM">
          <iconify-icon class="hp-icon" icon="lucide:atom" style="color:#16a34a"></iconify-icon>
          <span>GLM</span>
        </div>

      </div>
      </div><!-- end hp-row works-with -->

      <div class="hp-divider"></div>

      <div class="hp-row">
      <span class="hp-label mono">Extensions</span>
      <div class="hp-logos" role="list" aria-label="Supported extensions">

        <div class="hp-logo" role="listitem" aria-label="Raycast">
          <iconify-icon class="hp-icon" icon="simple-icons:raycast" style="color:#FF6363"></iconify-icon>
          <span>Raycast</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Alfred">
          <iconify-icon class="hp-icon" icon="simple-icons:alfred" style="color:#5C2D91"></iconify-icon>
          <span>Alfred</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="Spotlight">
          <iconify-icon class="hp-icon" icon="lucide:search" style="color:var(--mid)"></iconify-icon>
          <span>Spotlight</span>
        </div>

        <div class="hp-logo" role="listitem" aria-label="macOS Shortcuts">
          <svg class="hp-icon hp-shortcuts" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="3" width="9" height="9" rx="2.4" fill="#5AA9FF"/>
            <rect x="12" y="12" width="9" height="9" rx="2.4" fill="#7B61FF"/>
            <rect x="12" y="3" width="9" height="9" rx="2.4" fill="#3F8CFF"/>
            <rect x="3" y="12" width="9" height="9" rx="2.4" fill="#9A6BFF"/>
            <path d="M10 7h4v4h-1.6V9.6H10z" fill="#FFFFFF" opacity=".9"/>
            <path d="M14 17h-4v-4h1.6v1.4H14z" fill="#FFFFFF" opacity=".9"/>
          </svg>
          <span>Shortcuts</span>
        </div>

      </div>
      </div><!-- end hp-row extensions -->
    </div>
  </div>

</section>

<style>
  #hero { background: var(--bg); padding-top: 60px; }

  /* Two-column main grid */
  .hero-main {
    padding: 72px 0 36px;
    min-height: calc(100vh - 220px);
    display: flex; align-items: center;
  }

  .hm-grid {
    display: grid;
    grid-template-columns: 1fr 460px;
    gap: 72px;
    align-items: center;
    width: 100%;
  }

  /* Copy column */
  .hm-copy { display: flex; flex-direction: column; }
  .hmc-eyebrow { margin-bottom: 28px; }

  .hmc-h1 {
    font-size: clamp(38px, 4.8vw, 74px);
    font-weight: 700; letter-spacing: -0.055em; line-height: 1.03;
    color: var(--ink); margin-bottom: 22px;
    max-width: 720px;
  }

  .hmc-body {
    font-size: 16px; line-height: 1.74; color: var(--mid);
    max-width: 560px; margin-bottom: 30px;
  }

  .hmc-ctas { display: flex; align-items: center; gap: 4px; margin-bottom: 44px; flex-wrap: wrap; }
  .hmc-btn-main { padding: 13px 24px; font-size: 15px; border-radius: 9px; }
  .hmc-btn-sub  { padding: 13px 14px; font-size: 15px; color: var(--mid); }
  .hmc-btn-sub:hover { color: var(--ink); }

  /* Metrics */
  .hmc-metrics { display: flex; align-items: center; }
  .hmc-metric  { display: flex; flex-direction: column; gap: 3px; padding: 0 20px; }
  .hmc-metric:first-child { padding-left: 0; }
  .hmcm-n { font-size: 20px; font-weight: 700; letter-spacing: -0.04em; color: var(--ink); line-height: 1; }
  .hmcm-l { font-size: 9px; color: var(--dim); letter-spacing: 0.06em; text-transform: uppercase; }
  .hmc-sep { width: 1px; height: 26px; background: var(--bdr-hi); margin: 0 4px; }

  /* App window column */
  .hm-window {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hmw-frame {
    filter: drop-shadow(0 20px 48px rgba(0,0,0,0.14)) drop-shadow(0 4px 8px rgba(0,0,0,0.06));
    transition: filter .3s;
  }
  .hmw-frame:hover {
    filter: drop-shadow(0 28px 64px rgba(0,0,0,0.18)) drop-shadow(0 8px 16px rgba(0,0,0,0.08));
  }
  .hmw-refund-pill {
    position: absolute;
    top: calc(100% + 44px);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 286px;
    padding: 9px 12px;
    border-radius: 12px;
    border: none;
    background: rgba(26,107,64,0.05);
    box-shadow: 0 8px 20px rgba(26,107,64,0.06);
    transition: transform .16s var(--spring), box-shadow .16s, background .16s;
  }
  .hmw-refund-icon {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #0f7a43;
    background: rgba(0,200,83,0.20);
    flex-shrink: 0;
  }
  .hmw-refund-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .hmw-refund-copy strong {
    font-size: 11px;
    line-height: 1.2;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #0f432a;
    white-space: nowrap;
  }
  .hmw-refund-copy span {
    font-size: 9px;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #3f6f56;
    white-space: nowrap;
  }
  .hmw-refund-pill:hover {
    transform: translateX(-50%) translateY(-1px);
    background: rgba(26,107,64,0.11);
    box-shadow: 0 12px 26px rgba(26,107,64,0.12);
  }

  /* Provider logos */
  .hero-providers { padding: 0 0 56px; border-top: 1px solid var(--bdr); }
  .hp-inner { display: flex; flex-direction: column; gap: 0; padding-top: 20px; }
  .hp-row { display: flex; align-items: center; gap: 24px; padding: 10px 0; flex-wrap: nowrap; }
  .hp-row-top { align-items: flex-start; padding-top: 12px; }
  .hp-divider { height: 1px; background: var(--bdr); }
  .hp-label { font-size: 10px; color: var(--dim); letter-spacing: 0.1em; text-transform: uppercase; flex-shrink: 0; white-space: nowrap; min-width: 96px; }
  .hp-logos { display: flex; align-items: center; flex-wrap: wrap; gap: 4px; flex: 1; }
  .hp-logo {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 6px;
    font-size: 13px; font-weight: 500; color: var(--mid);
    background: var(--bg2); border: 1px solid var(--bdr);
    transition: border-color .13s, color .13s;
    white-space: nowrap;
  }
  .hp-logo:hover { border-color: var(--bdr-hi); color: var(--ink); }
  .hp-icon { width: 16px; height: 16px; flex-shrink: 0; }

  /* Compact icon+text chips for Works With row (13 providers, wrap into 2 rows) */
  .hp-logos-icons { flex-wrap: wrap; gap: 5px; }
  .hp-logos-icons .hp-logo {
    padding: 4px 9px;
    font-size: 11px;
    height: auto;
    gap: 5px;
  }
  .hp-logos-icons .hp-icon { width: 13px; height: 13px; }
  .hp-icon-img {
    width: 13px;
    height: 13px;
    object-fit: contain;
    border-radius: 2px;
  }

  @media (max-width: 1024px) {
    .hm-grid { grid-template-columns: 1fr 380px; gap: 40px; }
  }
  @media (max-width: 860px) {
    .hero-main { min-height: auto; padding: 48px 0 26px; }
    .hm-grid { grid-template-columns: minmax(0, 1fr); gap: 28px; }
    .hm-copy { min-width: 0; width: 100%; }

    .hm-window {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
    }

    .hmw-frame {
      width: min(100%, 356px);
      transform: none;
      filter: drop-shadow(0 14px 30px rgba(0,0,0,0.14)) drop-shadow(0 4px 10px rgba(0,0,0,0.08));
    }
    .hmw-frame :global(.app-win) {
      width: 100% !important;
      max-width: 100%;
    }

    .hmw-refund-pill {
      position: static;
      min-width: 0;
      width: min(100%, 320px);
      left: auto;
      top: auto;
      transform: none;
      margin-top: 0;
      justify-content: center;
    }

    .hmw-refund-pill:hover { transform: translateY(-1px); }
    .hmw-refund-copy strong { font-size: 10px; }
    .hmw-refund-copy span { font-size: 8px; }

    .hmc-h1 {
      max-width: 100%;
      font-size: clamp(30px, 10.5vw, 42px);
      line-height: 1.06;
      overflow-wrap: anywhere;
    }
    .hmc-h1 br { display: none; }

    .hmc-metrics {
      flex-wrap: wrap;
      gap: 8px 0;
    }
  }
</style>
