---
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-blueprint">

  <!-- Hero ambient glow -->
  <div class="absolute inset-0 bg-hero-glow pointer-events-none"></div>

  <!-- Corner decoration marks -->
  <div class="absolute top-8 left-8 w-6 h-6 border-l border-t border-teal/20"></div>
  <div class="absolute top-8 right-8 w-6 h-6 border-r border-t border-teal/20"></div>
  <div class="absolute bottom-8 left-8 w-6 h-6 border-l border-b border-teal/20"></div>
  <div class="absolute bottom-8 right-8 w-6 h-6 border-r border-b border-teal/20"></div>

  <!-- Coordinate labels -->
  <div class="absolute top-8 left-1/2 -translate-x-1/2 font-mono text-[10px] text-teal/20 tracking-widest">0°N 0°E</div>

  <div class="max-w-6xl mx-auto px-6 pt-32 pb-24 w-full">

    <!-- Status badge -->
    <div class="flex justify-center mb-10" data-reveal>
      <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-teal/20 bg-teal/5 font-mono text-[11px] text-teal tracking-widest uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></span>
        RMPA v1.1 · 7-Stage Pipeline · Active
      </div>
    </div>

    <!-- Main headline -->
    <div class="text-center max-w-4xl mx-auto mb-8">
      <h1 class="text-[72px] leading-[1.0] font-black tracking-tighter text-ink mb-0" data-reveal data-reveal-delay="1">
        Stop typing.
      </h1>
      <h1 class="text-[72px] leading-[1.0] font-black tracking-tighter text-teal mb-6" data-reveal data-reveal-delay="2">
        Start engineering.
      </h1>
      <p class="text-[18px] leading-relaxed text-ink-secondary max-w-2xl mx-auto font-light" data-reveal data-reveal-delay="3">
        PromptCraft transforms casual, ambiguous requests into precision-grade AI directives.
        Recursive Meta Prompt Architecture. Seven deterministic stages. Zero verbosity drift.
      </p>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20" data-reveal data-reveal-delay="4">
      <a
        href="/download"
        class="group flex items-center gap-3 px-6 py-3.5 bg-teal text-void font-mono text-[14px] font-semibold rounded-lg hover:bg-teal-dim transition-all duration-200 hover:shadow-[0_0_32px_rgba(0,255,178,0.25)]"
      >
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
          <path d="M8 2v8M4 7l4 4 4-4M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download for macOS
        <span class="text-void/60 font-normal text-[12px]">Free</span>
      </a>
      <a
        href="/pricing"
        class="flex items-center gap-3 px-6 py-3.5 border border-border text-ink-secondary font-mono text-[14px] rounded-lg hover:border-teal/30 hover:text-ink transition-all duration-200"
      >
        Get Cloud Access
        <span class="font-normal text-[12px] text-teal/70">$12/mo</span>
      </a>
    </div>

    <!-- Live Demo Window -->
    <div class="relative max-w-4xl mx-auto" data-reveal data-reveal-delay="5">

      <!-- Window chrome -->
      <div class="rounded-xl border border-border bg-panel overflow-hidden shadow-[0_0_80px_rgba(0,0,0,0.6),0_0_40px_rgba(0,255,178,0.04)]">

        <!-- Title bar -->
        <div class="flex items-center justify-between px-5 py-3 border-b border-border bg-surface">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
          </div>
          <span class="font-mono text-[11px] text-ink-muted tracking-wider">promptcraft — optimization-pipeline</span>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></span>
            <span class="font-mono text-[10px] text-teal/60">PROCESSING</span>
          </div>
        </div>

        <!-- Demo content -->
        <div class="grid grid-cols-2 min-h-[360px]">

          <!-- Input panel -->
          <div class="p-6 border-r border-border relative overflow-hidden">
            <div class="font-mono text-[10px] text-teal/50 tracking-widest mb-4 uppercase">// Input · Raw Request</div>
            <div id="demo-input" class="font-mono text-[13px] text-ink-secondary leading-relaxed">
              <span id="typed-text" class="text-ink"></span><span id="cursor" class="text-teal animate-blink">|</span>
            </div>

            <!-- Scanline effect -->
            <div class="scanline opacity-30"></div>
          </div>

          <!-- Pipeline output panel -->
          <div class="p-6 bg-void/30 relative">
            <div class="font-mono text-[10px] text-teal/50 tracking-widest mb-4 uppercase">// Output · Engineered Directive</div>

            <!-- Pipeline stages -->
            <div class="space-y-3" id="pipeline-stages">
              {[
                { id: 'stage-1', step: '01', label: 'Intent Decomposer', color: 'text-teal', active: false },
                { id: 'stage-2', step: '02', label: 'Entity Extractor', color: 'text-blue-400', active: false },
                { id: 'stage-3', step: '03', label: 'Complexity Classifier', color: 'text-purple-400', active: false },
                { id: 'stage-4', step: '04', label: 'Context Engine', color: 'text-amber-400', active: false },
                { id: 'stage-5', step: '05', label: 'Prompt Assembler', color: 'text-pink-400', active: false },
                { id: 'stage-6', step: '06', label: 'Model Execution', color: 'text-orange-400', active: false },
                { id: 'stage-7', step: '07', label: 'Post Processor', color: 'text-teal', active: false },
              ].map(stage => (
                <div id={stage.id} class="flex items-center gap-3 opacity-20 transition-all duration-500">
                  <span class="font-mono text-[10px] text-ink-muted w-5">{stage.step}</span>
                  <div class="flex-1 h-px bg-border"></div>
                  <span class={`font-mono text-[10px] ${stage.color} tracking-wide`}>{stage.label}</span>
                  <div class="w-4 h-4 rounded border border-current flex items-center justify-center" id={`${stage.id}-check`}>
                    <svg class="w-2 h-2 opacity-0" viewBox="0 0 8 8" fill="currentColor">
                      <path d="M1 4l2 2 4-4"/>
                    </svg>
                  </div>
                </div>
              ))}
            </div>

            <!-- Output result -->
            <div id="output-result" class="mt-5 opacity-0 transition-opacity duration-700">
              <div class="font-mono text-[10px] text-teal/50 mb-2 tracking-widest uppercase">// Optimized Directive</div>
              <div id="output-text" class="font-mono text-[12px] text-ink-code leading-relaxed"></div>
            </div>
          </div>
        </div>

        <!-- Metrics bar -->
        <div class="flex items-center gap-8 px-6 py-3 border-t border-border bg-surface">
          <div class="flex items-center gap-2">
            <span class="font-mono text-[10px] text-ink-muted">Tier</span>
            <span class="font-mono text-[10px] text-teal" id="tier-output">COMPLEX</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-mono text-[10px] text-ink-muted">Intent count</span>
            <span class="font-mono text-[10px] text-ink" id="intent-output">3</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-mono text-[10px] text-ink-muted">Context injected</span>
            <span class="font-mono text-[10px] text-ink" id="context-output">2 entities</span>
          </div>
          <div class="ml-auto flex items-center gap-2">
            <span class="font-mono text-[10px] text-ink-muted">Latency</span>
            <span class="font-mono text-[10px] text-teal" id="latency-output">0ms</span>
          </div>
        </div>
      </div>

      <!-- Floating spec callouts -->
      <div class="absolute -right-48 top-12 hidden xl:block">
        <div class="font-mono text-[11px] text-ink-muted leading-relaxed space-y-1.5 border-l border-teal/20 pl-4">
          <div class="text-teal/60">SPEC</div>
          <div>7-stage pipeline</div>
          <div>Tier 1-4 calibration</div>
          <div>Context injection</div>
          <div>Zero verbosity drift</div>
          <div>Post-processing guard</div>
        </div>
      </div>
    </div>

    <!-- Social proof -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-8 mt-16" data-reveal>
      <div class="flex -space-x-2">
        {[1,2,3,4,5].map(i => (
          <div class="w-8 h-8 rounded-full border-2 border-void bg-panel flex items-center justify-center text-[11px] font-mono text-teal">
            {String.fromCharCode(64 + i)}
          </div>
        ))}
      </div>
      <p class="font-mono text-[12px] text-ink-muted">
        Used by engineers at <span class="text-ink">Anthropic, OpenAI, and Linear</span>
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="font-mono text-[10px] text-teal/30 tracking-widest uppercase">Scroll</span>
    <svg class="w-4 h-4 text-teal/30" viewBox="0 0 16 16" fill="none">
      <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<script>
  const examples = [
    {
      input: 'fix the login bug and also add better error messages',
      output: 'Resolve authentication failure for edge case: [SESSION_INVALID state]. Implement structured error taxonomy: distinguish between (1) credential mismatch, (2) session expiry, (3) rate-limit exceeded. Return actionable user-facing string per class. Preserve existing happy-path behavior.',
      tier: 'COMPLEX',
      intents: '2',
      context: '1 entity',
    },
    {
      input: 'write tests for the auth module',
      output: 'Generate comprehensive test suite for authentication module. Coverage requirements: (1) unit tests for token validation, (2) integration tests for session lifecycle, (3) edge cases: expired tokens, malformed JWTs, concurrent sessions. Use AAA pattern. Mock external dependencies.',
      tier: 'STANDARD',
      intents: '1',
      context: '2 entities',
    },
    {
      input: 'what does this function do',
      output: 'Explain the purpose, inputs, outputs, and side effects of the specified function. Include: parameter types, return value, error conditions, and a one-line summary suitable for documentation.',
      tier: 'SIMPLE',
      intents: '1',
      context: '0 entities',
    },
  ];

  let currentExample = 0;
  let charIndex = 0;
  let isTyping = false;
  let pipelineStep = 0;

  function resetPipeline() {
    for (let i = 1; i <= 7; i++) {
      const stage = document.getElementById(`stage-${i}`)!;
      const check = document.getElementById(`stage-${i}-check`)!;
      stage.style.opacity = '0.2';
      check.querySelector('svg')!.style.opacity = '0';
    }
    const outputEl = document.getElementById('output-result')!;
    outputEl.style.opacity = '0';
    document.getElementById('output-text')!.textContent = '';
    document.getElementById('latency-output')!.textContent = '0ms';
  }

  async function runPipeline(example: typeof examples[0]) {
    const tierEl = document.getElementById('tier-output')!;
    const intentEl = document.getElementById('intent-output')!;
    const contextEl = document.getElementById('context-output')!;
    const latencyEl = document.getElementById('latency-output')!;

    tierEl.textContent = example.tier;
    intentEl.textContent = example.intents;
    contextEl.textContent = example.context;

    let elapsed = 0;
    for (let i = 1; i <= 7; i++) {
      await new Promise(r => setTimeout(r, 280));
      elapsed += Math.floor(Math.random() * 40 + 20);
      const stage = document.getElementById(`stage-${i}`)!;
      const check = document.getElementById(`stage-${i}-check`)!;
      stage.style.opacity = '1';
      check.querySelector('svg')!.style.opacity = '1';
      latencyEl.textContent = `${elapsed}ms`;
    }

    await new Promise(r => setTimeout(r, 200));

    const outputEl = document.getElementById('output-result')!;
    const outputText = document.getElementById('output-text')!;
    outputEl.style.opacity = '1';

    // Type the output
    let outIndex = 0;
    const typeOutput = setInterval(() => {
      outputText.textContent = example.output.slice(0, outIndex);
      outIndex += 3;
      if (outIndex >= example.output.length) {
        outputText.textContent = example.output;
        clearInterval(typeOutput);
      }
    }, 12);
  }

  async function typeInput(text: string) {
    const el = document.getElementById('typed-text')!;
    el.textContent = '';

    for (let i = 0; i <= text.length; i++) {
      el.textContent = text.slice(0, i);
      await new Promise(r => setTimeout(r, 45 + Math.random() * 30));
    }
  }

  async function runDemo() {
    const example = examples[currentExample % examples.length];
    currentExample++;

    resetPipeline();
    await new Promise(r => setTimeout(r, 600));
    await typeInput(example.input);
    await new Promise(r => setTimeout(r, 400));
    await runPipeline(example);
    await new Promise(r => setTimeout(r, 4000));
    runDemo();
  }

  // Start demo after page load
  setTimeout(runDemo, 1200);
</script>
