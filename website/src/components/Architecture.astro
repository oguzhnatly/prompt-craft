---
---
<section id="architecture" class="section arch-section">
  <div class="container">
    <div class="arch-head">
      <div class="badge teal" data-reveal>
        <span class="badge-dot"></span>
        THE RMPA PIPELINE
      </div>
      <div class="arch-head-cols">
        <h2 class="arch-title syne" data-reveal data-reveal-d="1">
          Seven stages.<br>One perfect request.
        </h2>
        <p class="arch-desc" data-reveal data-reveal-d="2">
          Raw language is ambiguous. RMPA resolves every dimension of ambiguity
          before the AI model ever processes your request. The result is
          not just a better response — it is a structurally different level of output quality.
        </p>
      </div>
    </div>
  </div>

  <!-- Stage strip — horizontal scroll -->
  <div class="arch-scroll-wrapper" role="region" aria-label="RMPA pipeline stages">
    <div class="arch-strip" id="arch-strip">

      <article class="stage-card" data-stage="1" style="--ac:#00C896">
        <div class="sc-top">
          <div class="sc-num mono">01</div>
          <div class="sc-icon" style="background:rgba(0,200,150,0.1);color:#00C896">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M4 20c0-3.31 3.58-6 8-6s8 2.69 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
        </div>
        <h3 class="sc-name syne">Role Assignment</h3>
        <p class="sc-desc">Defines the AI's expert identity — the specific cognitive frame, authority level, and domain specialization it must adopt.</p>
        <div class="sc-example mono">"You are a senior systems architect with 15 years designing distributed systems at FAANG scale..."</div>
        <div class="sc-tag mono" style="color:#00C896;background:rgba(0,200,150,0.06);border-color:rgba(0,200,150,0.2)">R · Role</div>
      </article>

      <div class="stage-connector" aria-hidden="true">
        <svg viewBox="0 0 80 2" fill="none"><line x1="0" y1="1" x2="80" y2="1" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="4 3"/></svg>
        <div class="connector-arrow">→</div>
      </div>

      <article class="stage-card" data-stage="2" style="--ac:#4F3FF0">
        <div class="sc-top">
          <div class="sc-num mono">02</div>
          <div class="sc-icon" style="background:rgba(79,63,240,0.1);color:#4F3FF0">
            <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M7 8h10M7 12h7M7 16h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
        </div>
        <h3 class="sc-name syne">Context Injection</h3>
        <p class="sc-desc">Injects structured background so the model begins with complete situational awareness — no implicit assumptions.</p>
        <div class="sc-example mono">"Context: production API, 50k DAU, TypeScript codebase, existing auth uses Passport.js..."</div>
        <div class="sc-tag mono" style="color:#4F3FF0;background:rgba(79,63,240,0.06);border-color:rgba(79,63,240,0.2)">M · Meta</div>
      </article>

      <div class="stage-connector" aria-hidden="true">
        <svg viewBox="0 0 80 2" fill="none"><line x1="0" y1="1" x2="80" y2="1" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="4 3"/></svg>
        <div class="connector-arrow">→</div>
      </div>

      <article class="stage-card" data-stage="3" style="--ac:#FF5441">
        <div class="sc-top">
          <div class="sc-num mono">03</div>
          <div class="sc-icon" style="background:rgba(255,84,65,0.1);color:#FF5441">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 2L2 10v12h6V16h8v6h6V10L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <h3 class="sc-name syne">Constraint Binding</h3>
        <p class="sc-desc">Hard-binds the boundaries the AI must not exceed — word limits, scope restrictions, evidence requirements.</p>
        <div class="sc-example mono">"Constraints: max 400 words. No jargon. Evidence-based only. No hedging language."</div>
        <div class="sc-tag mono" style="color:#FF5441;background:rgba(255,84,65,0.06);border-color:rgba(255,84,65,0.2)">P · Precision</div>
      </article>

      <div class="stage-connector" aria-hidden="true">
        <svg viewBox="0 0 80 2" fill="none"><line x1="0" y1="1" x2="80" y2="1" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="4 3"/></svg>
        <div class="connector-arrow">→</div>
      </div>

      <article class="stage-card" data-stage="4" style="--ac:#F5A623">
        <div class="sc-top">
          <div class="sc-num mono">04</div>
          <div class="sc-icon" style="background:rgba(245,166,35,0.1);color:#F5A623">
            <svg viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 10h12M4 14h14M4 18h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
        </div>
        <h3 class="sc-name syne">Format Sculpting</h3>
        <p class="sc-desc">Specifies the exact structure of the response before the AI writes a single word — preventing formless dumps.</p>
        <div class="sc-example mono">"Format: ## header, 3-bullet overview, code block with comments, then a TL;DR"</div>
        <div class="sc-tag mono" style="color:#F5A623;background:rgba(245,166,35,0.06);border-color:rgba(245,166,35,0.2)">M · Meta</div>
      </article>

      <div class="stage-connector" aria-hidden="true">
        <svg viewBox="0 0 80 2" fill="none"><line x1="0" y1="1" x2="80" y2="1" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="4 3"/></svg>
        <div class="connector-arrow">→</div>
      </div>

      <article class="stage-card" data-stage="5" style="--ac:#00A3FF">
        <div class="sc-top">
          <div class="sc-num mono">05</div>
          <div class="sc-icon" style="background:rgba(0,163,255,0.1);color:#00A3FF">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="7" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="17" cy="7"  r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="17" cy="17" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M10 12h4M10 10.5L14 7.5M10 13.5l4 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
        </div>
        <h3 class="sc-name syne">Chain Reasoning</h3>
        <p class="sc-desc">Embeds step-by-step reasoning protocols that force analytical depth and visible logic before the conclusion.</p>
        <div class="sc-example mono">"Think step by step. Show your reasoning chain before the final answer."</div>
        <div class="sc-tag mono" style="color:#00A3FF;background:rgba(0,163,255,0.06);border-color:rgba(0,163,255,0.2)">P · Precision</div>
      </article>

      <div class="stage-connector" aria-hidden="true">
        <svg viewBox="0 0 80 2" fill="none"><line x1="0" y1="1" x2="80" y2="1" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="4 3"/></svg>
        <div class="connector-arrow">→</div>
      </div>

      <article class="stage-card" data-stage="6" style="--ac:#AF52DE">
        <div class="sc-top">
          <div class="sc-num mono">06</div>
          <div class="sc-icon" style="background:rgba(175,82,222,0.1);color:#AF52DE">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 3C7 3 3 7 3 12s4 9 9 9 9-4 9-9-4-9-9-9z" stroke="currentColor" stroke-width="1.5"/><path d="M9 10c0-1.66 1.34-3 3-3s3 1.34 3 3-1.34 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="17" r="1.5" fill="currentColor"/></svg>
          </div>
        </div>
        <h3 class="sc-name syne">Tone Calibration</h3>
        <p class="sc-desc">Locks the precise register — expert, approachable, technical, diplomatic — matched to the actual audience and context.</p>
        <div class="sc-example mono">"Tone: executive briefing. Assume deep technical literacy. No casual phrasing."</div>
        <div class="sc-tag mono" style="color:#AF52DE;background:rgba(175,82,222,0.06);border-color:rgba(175,82,222,0.2)">A · Align</div>
      </article>

      <div class="stage-connector" aria-hidden="true">
        <svg viewBox="0 0 80 2" fill="none"><line x1="0" y1="1" x2="80" y2="1" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="4 3"/></svg>
        <div class="connector-arrow">→</div>
      </div>

      <article class="stage-card" data-stage="7" style="--ac:#00C896">
        <div class="sc-top">
          <div class="sc-num mono">07</div>
          <div class="sc-icon" style="background:rgba(0,200,150,0.1);color:#00C896">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2.5 2.5L15 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <h3 class="sc-name syne">Output Validation</h3>
        <p class="sc-desc">Final gate — checks internal consistency, confirms all sub-questions are addressed, verifies no contradictions exist.</p>
        <div class="sc-example mono">"Verify the response addresses all sub-questions. Flag any contradictions before output."</div>
        <div class="sc-tag mono" style="color:#00C896;background:rgba(0,200,150,0.06);border-color:rgba(0,200,150,0.2)">A · Align</div>
      </article>

    </div>
  </div>

  <!-- Stats -->
  <div class="container">
    <div class="arch-stats" data-reveal>
      <div class="astat">
        <span class="astat-n syne" data-count="7">0</span>
        <span class="astat-l mono">stages</span>
      </div>
      <div class="astat-sep"></div>
      <div class="astat">
        <span class="astat-n syne" data-count="340">0</span>
        <span class="astat-l mono">% avg clarity gain</span>
      </div>
      <div class="astat-sep"></div>
      <div class="astat">
        <span class="astat-n syne">&lt;200</span>
        <span class="astat-l mono">ms overhead</span>
      </div>
      <div class="astat-sep"></div>
      <div class="astat">
        <span class="astat-n syne" data-count="3">0</span>
        <span class="astat-l mono">AI providers</span>
      </div>
    </div>
  </div>
</section>

<style>
  .arch-section { padding: 120px 0 80px; }

  .arch-head { margin-bottom: 56px; }
  .arch-head .badge { margin-bottom: 28px; }
  .arch-head-cols {
    display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
    align-items: start;
  }

  .arch-title {
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 800; letter-spacing: -0.04em;
    line-height: 1.1; color: var(--ink);
  }

  .arch-desc {
    font-size: 15px; line-height: 1.75;
    color: var(--ink-2); padding-top: 6px;
  }

  /* Scroll strip */
  .arch-scroll-wrapper {
    overflow-x: auto;
    padding: 24px 40px 32px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    cursor: grab;
  }
  .arch-scroll-wrapper:active { cursor: grabbing; }
  @media (max-width: 768px) { .arch-scroll-wrapper { padding: 16px 20px 24px; } }

  .arch-strip {
    display: flex;
    align-items: stretch;
    gap: 0;
    width: max-content;
  }

  /* Stage card */
  .stage-card {
    width: 240px; flex-shrink: 0;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 24px 20px 20px;
    display: flex; flex-direction: column; gap: 12px;
    transition: transform .3s var(--ease-spring), box-shadow .3s, border-color .25s;
    cursor: none;
    position: relative;
  }
  .stage-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(12,11,24,0.1);
    border-color: color-mix(in srgb, var(--ac) 40%, var(--border));
  }

  .sc-top { display: flex; align-items: center; justify-content: space-between; }

  .sc-num {
    font-size: 11px; color: var(--ink-3);
    letter-spacing: 0.1em;
  }

  .sc-icon {
    width: 36px; height: 36px;
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
  }
  .sc-icon svg { width: 18px; height: 18px; }

  .sc-name {
    font-size: 16px; font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink); line-height: 1.2;
  }

  .sc-desc {
    font-size: 12px; line-height: 1.65;
    color: var(--ink-3); flex: 1;
  }

  .sc-example {
    font-size: 10px; line-height: 1.5;
    color: var(--ink-2);
    background: var(--paper-2);
    border-radius: 6px;
    padding: 8px;
    border-left: 2px solid var(--ac);
  }

  .sc-tag {
    display: inline-flex; align-self: flex-start;
    font-size: 9px; letter-spacing: 0.08em;
    padding: 2px 8px; border-radius: 999px;
    border: 1px solid;
    font-weight: 600;
  }

  /* Connector */
  .stage-connector {
    display: flex; align-items: center; flex-direction: column;
    justify-content: center; gap: 4px;
    padding: 0 4px;
    flex-shrink: 0;
    align-self: center;
  }
  .stage-connector svg { width: 40px; opacity: 0.5; }
  .connector-arrow { font-size: 11px; color: var(--ink-4); }

  /* Stats */
  .arch-stats {
    display: flex; align-items: center;
    padding: 32px 0 0;
    border-top: 1px solid var(--border);
    margin-top: 20px;
    gap: 0;
  }
  .astat {
    display: flex; flex-direction: column; gap: 3px;
    flex: 1; align-items: center; padding: 0 20px;
  }
  .astat-n {
    font-size: 38px; font-weight: 800;
    letter-spacing: -0.05em;
    color: var(--teal-d); line-height: 1;
  }
  .astat-l { font-size: 11px; color: var(--ink-3); letter-spacing: 0.06em; }
  .astat-sep { width: 1px; height: 36px; background: var(--border); }

  @media (max-width: 768px) {
    .arch-head-cols { grid-template-columns: 1fr; gap: 20px; }
    .arch-stats { flex-wrap: wrap; gap: 20px; padding: 24px 0 0; }
    .astat { flex: 1 1 40%; padding: 0; align-items: flex-start; }
    .astat-sep { display: none; }
  }
</style>

<script>
  /* Drag scroll */
  const wrap = document.querySelector('.arch-scroll-wrapper') as HTMLElement;
  if (wrap) {
    let down = false, sx = 0, sl = 0;
    wrap.addEventListener('mousedown', e => { down = true; sx = e.pageX - wrap.offsetLeft; sl = wrap.scrollLeft; });
    wrap.addEventListener('mouseleave', () => { down = false; });
    wrap.addEventListener('mouseup',    () => { down = false; });
    wrap.addEventListener('mousemove', (e: MouseEvent) => {
      if (!down) return; e.preventDefault();
      wrap.scrollLeft = sl - (e.pageX - wrap.offsetLeft - sx) * 1.4;
    });
  }

  /* Count-up */
  const io2 = new IntersectionObserver(entries => {
    entries.forEach(en => {
      if (!en.isIntersecting) return;
      const el = en.target as HTMLElement;
      const target = parseInt(el.dataset.count!, 10);
      let v = 0; const step = Math.max(1, Math.ceil(target / 45));
      const t = setInterval(() => {
        v = Math.min(v + step, target);
        el.textContent = v.toString();
        if (v >= target) clearInterval(t);
      }, 28);
      io2.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-count]').forEach(el => io2.observe(el));
</script>
