---
// Architecture — horizontal RMPA pipeline as a circuit board
---

<section id="architecture" class="section arch-section">
  <div class="arch-head">
    <div class="tag teal">
      <span class="tag-dot"></span>
      THE RMPA PIPELINE
    </div>
    <h2 class="arch-title">
      Seven stages.<br>
      <span class="teal">One perfect request.</span>
    </h2>
    <p class="arch-sub">
      Raw language is ambiguous. RMPA resolves every dimension of ambiguity before the AI ever reads it.
    </p>
  </div>

  <!-- Horizontal scroll track -->
  <div class="arch-track-wrapper" role="region" aria-label="RMPA pipeline stages">
    <div class="arch-track" id="arch-track">
      <!-- Electron rail -->
      <div class="rail" aria-hidden="true">
        <svg class="rail-svg" id="rail-svg" viewBox="0 0 1400 60" preserveAspectRatio="none" fill="none">
          <path id="rail-path" d="M0 30 H1400" stroke="rgba(0,255,178,0.15)" stroke-width="1.5" stroke-dasharray="6 4"/>
          <!-- Electrons -->
          <circle class="electron" r="3" fill="var(--teal)" filter="url(#eglow)">
            <animateMotion dur="3s" repeatCount="indefinite" begin="0s">
              <mpath href="#rail-path"/>
            </animateMotion>
          </circle>
          <circle class="electron" r="2" fill="var(--teal)" opacity="0.6">
            <animateMotion dur="3s" repeatCount="indefinite" begin="1s">
              <mpath href="#rail-path"/>
            </animateMotion>
          </circle>
          <circle class="electron" r="1.5" fill="var(--teal)" opacity="0.4">
            <animateMotion dur="3s" repeatCount="indefinite" begin="2s">
              <mpath href="#rail-path"/>
            </animateMotion>
          </circle>
          <defs>
            <filter id="eglow" x="-200%" y="-200%" width="500%" height="500%">
              <feGaussianBlur stdDeviation="3" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
        </svg>
      </div>

      <!-- Stage cards -->
      <div class="stage-card" data-stage-idx="1">
        <div class="stage-number font-mono">01</div>
        <div class="stage-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 26c0-4.97 4.03-9 9-9s9 4.03 9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="stage-card-name">Role Assignment</h3>
        <p class="stage-card-desc">Defines the AI's expert identity — the specific cognitive frame from which it must reason.</p>
        <div class="stage-example font-mono">"You are a senior systems architect with 15 years..."</div>
        <div class="stage-badge font-mono">R</div>
      </div>

      <div class="stage-card" data-stage-idx="2">
        <div class="stage-number font-mono">02</div>
        <div class="stage-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <rect x="4" y="4" width="24" height="24" rx="4" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 12h12M10 17h8M10 22h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="stage-card-name">Context Injection</h3>
        <p class="stage-card-desc">Injects structured background so the model begins with full situational awareness.</p>
        <div class="stage-example font-mono">"The context is: production API, 50k users, TypeScript..."</div>
        <div class="stage-badge font-mono">M</div>
      </div>

      <div class="stage-card" data-stage-idx="3" style="--accent: #7B61FF">
        <div class="stage-number font-mono">03</div>
        <div class="stage-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <path d="M16 4L4 14v14h8V20h8v8h8V14L16 4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="stage-card-name">Constraint Binding</h3>
        <p class="stage-card-desc">Hard-binds the boundaries the AI must not exceed — length, scope, format, tone.</p>
        <div class="stage-example font-mono">"Limit: 400 words. No jargon. Evidence-based only."</div>
        <div class="stage-badge font-mono">P</div>
      </div>

      <div class="stage-card" data-stage-idx="4" style="--accent: #FFB830">
        <div class="stage-number font-mono">04</div>
        <div class="stage-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <path d="M6 8h20M6 14h14M6 20h17M6 26h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="stage-card-name">Format Sculpting</h3>
        <p class="stage-card-desc">Specifies the exact shape of the response before the AI writes a single word.</p>
        <div class="stage-example font-mono">"Structure: ## Header → bullet list → code block → summary"</div>
        <div class="stage-badge font-mono">M</div>
      </div>

      <div class="stage-card" data-stage-idx="5" style="--accent: #FF4D9B">
        <div class="stage-number font-mono">05</div>
        <div class="stage-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <circle cx="10" cy="16" r="3" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="22" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="22" cy="22" r="3" stroke="currentColor" stroke-width="1.5"/>
            <path d="M13 16h5M13 14.5l4.5-2.5M13 17.5l4.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="stage-card-name">Chain Reasoning</h3>
        <p class="stage-card-desc">Embeds step-by-step reasoning protocols that force analytical depth before conclusion.</p>
        <div class="stage-example font-mono">"Think step by step. Show your reasoning chain."</div>
        <div class="stage-badge font-mono">P</div>
      </div>

      <div class="stage-card" data-stage-idx="6" style="--accent: #00D4FF">
        <div class="stage-number font-mono">06</div>
        <div class="stage-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <path d="M16 4c6.63 0 12 5.37 12 12s-5.37 12-12 12S4 22.63 4 16 9.37 4 16 4z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 14c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="16" cy="22" r="1.5" fill="currentColor"/>
          </svg>
        </div>
        <h3 class="stage-card-name">Tone Calibration</h3>
        <p class="stage-card-desc">Locks the precise register — expert, approachable, technical, diplomatic — matching the audience.</p>
        <div class="stage-example font-mono">"Tone: executive briefing. Assume technical literacy."</div>
        <div class="stage-badge font-mono">A</div>
      </div>

      <div class="stage-card" data-stage-idx="7">
        <div class="stage-number font-mono">07</div>
        <div class="stage-icon">
          <svg viewBox="0 0 32 32" fill="none">
            <path d="M12 17l3 3 5-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="stage-card-name">Output Validation</h3>
        <p class="stage-card-desc">Final verification gate — checks internal consistency and confirms success criteria before dispatch.</p>
        <div class="stage-example font-mono">"Verify: addresses all sub-questions. No contradictions."</div>
        <div class="stage-badge font-mono">A</div>
      </div>

      <!-- RMPA legend -->
      <div class="arch-legend" aria-label="RMPA component legend">
        <div class="legend-item">
          <span class="legend-dot" style="background:var(--teal)"></span>
          <span class="font-mono">R — Role</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background:var(--indigo)"></span>
          <span class="font-mono">M — Meta-context</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background:var(--pink)"></span>
          <span class="font-mono">P — Precision</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background:#00D4FF"></span>
          <span class="font-mono">A — Alignment</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="arch-stats">
    <div class="stat-item">
      <span class="stat-num font-mono" data-count="7">0</span>
      <span class="stat-label font-mono">stages</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-num font-mono" data-count="340">0</span>
      <span class="stat-label font-mono">% avg clarity gain</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-num font-mono" data-count="3">0</span>
      <span class="stat-label font-mono">AI providers</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-num font-mono">&lt;200</span>
      <span class="stat-label font-mono">ms overhead</span>
    </div>
  </div>
</section>

<style>
  .arch-section {
    padding: 140px 0 80px;
    overflow: hidden;
  }

  .arch-head {
    max-width: 1200px;
    margin: 0 auto 60px;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap: 40px;
  }

  .arch-head .tag { grid-column: 1 / -1; justify-self: start; }

  .arch-title {
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0;
  }

  .arch-sub {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.7;
    padding-top: 8px;
    max-width: 420px;
  }

  /* ── Horizontal scroll ──────────── */
  .arch-track-wrapper {
    overflow-x: auto;
    overflow-y: visible;
    padding: 0 40px 32px;
    scrollbar-width: thin;
    scrollbar-color: var(--border-hi) transparent;
    cursor: grab;
  }
  .arch-track-wrapper:active { cursor: grabbing; }

  .arch-track {
    display: flex;
    align-items: stretch;
    gap: 0;
    width: max-content;
    min-width: 100%;
    position: relative;
    padding: 40px 0;
  }

  /* ── Electron rail ──────────────── */
  .rail {
    position: absolute;
    top: 50%;
    left: 0; right: 0;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 0;
  }
  .rail-svg {
    width: 100%;
    height: 60px;
    display: block;
  }

  /* ── Stage cards ────────────────── */
  .stage-card {
    --accent: #00FFB2;
    position: relative;
    width: 220px;
    flex-shrink: 0;
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 24px 20px 20px;
    margin: 0 12px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: transform 0.3s var(--ease-spring), border-color 0.3s, box-shadow 0.3s;
    cursor: none;
  }
  .stage-card:hover {
    transform: translateY(-8px);
    border-color: rgba(var(--accent),0.3);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.04) inset;
  }

  /* Connection dot on each side */
  .stage-card::before, .stage-card::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    transform: translateY(-50%);
    z-index: 2;
  }
  .stage-card::before { left: -4px; }
  .stage-card::after  { right: -4px; }

  .stage-number {
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.1em;
  }

  .stage-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }
  .stage-icon svg { width: 20px; height: 20px; }

  .stage-card-name {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-1);
    line-height: 1.2;
  }

  .stage-card-desc {
    font-size: 12px;
    line-height: 1.6;
    color: var(--text-2);
    flex: 1;
  }

  .stage-example {
    font-size: 10px;
    color: var(--text-3);
    line-height: 1.5;
    background: rgba(255,255,255,0.03);
    border-radius: 6px;
    padding: 8px;
    border-left: 2px solid var(--accent);
  }

  .stage-badge {
    position: absolute;
    top: 16px; right: 16px;
    font-size: 10px;
    color: var(--accent);
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    padding: 1px 5px;
  }

  /* Legend card */
  .arch-legend {
    width: 180px;
    flex-shrink: 0;
    margin: 0 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: center;
    padding: 24px 20px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    z-index: 1;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--text-2);
    letter-spacing: 0.04em;
  }
  .legend-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Stats bar ───────────────────── */
  .arch-stats {
    max-width: 1200px;
    margin: 40px auto 0;
    padding: 0 40px;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 48px;
  }
  .stat-item:first-child { padding-left: 0; }
  .stat-item:last-child  { padding-right: 0; }

  .stat-num {
    font-size: 36px;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .stat-label { font-size: 11px; color: var(--text-3); letter-spacing: 0.08em; }
  .stat-divider { width: 1px; height: 40px; background: var(--border); flex-shrink: 0; }

  @media (max-width: 768px) {
    .arch-head { grid-template-columns: 1fr; padding: 0 20px; gap: 24px; }
    .arch-track-wrapper { padding: 0 20px 24px; }
    .arch-stats { padding: 0 20px; flex-wrap: wrap; gap: 24px; }
    .stat-item { padding: 0; }
    .stat-divider { display: none; }
  }
</style>

<script>
  // Drag-to-scroll
  const track = document.querySelector('.arch-track-wrapper') as HTMLElement;
  if (track) {
    let isDown = false, startX = 0, scrollLeft = 0;
    track.addEventListener('mousedown', (e: MouseEvent) => { isDown = true; startX = e.pageX - track.offsetLeft; scrollLeft = track.scrollLeft; });
    track.addEventListener('mouseleave', () => { isDown = false; });
    track.addEventListener('mouseup', () => { isDown = false; });
    track.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDown) return;
      e.preventDefault();
      const x    = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });
  }

  // Count-up on scroll
  const counters = document.querySelectorAll('[data-count]') as NodeListOf<HTMLElement>;
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el   = entry.target as HTMLElement;
      const end  = parseInt(el.dataset.count!, 10);
      let current = 0;
      const step = Math.max(1, Math.ceil(end / 40));
      const tick = setInterval(() => {
        current = Math.min(current + step, end);
        el.textContent = current.toString();
        if (current >= end) clearInterval(tick);
      }, 30);
      io.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(c => io.observe(c));
</script>
