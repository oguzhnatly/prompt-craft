---
const proFeatures = [
  { text: 'All 7 pipeline stages, every request',      note: null },
  { text: 'Runs fully local — no data leaves your Mac', note: null },
  { text: '7 built-in optimization styles',             note: 'General, Engineering, Research, Content, Analysis, Academic, Creative' },
  { text: 'Custom style templates',                     note: 'Define and save your own prompt architecture' },
  { text: 'Unlimited clipboard history',                note: 'Every prompt and result stored locally, searchable' },
  { text: 'Any Ollama model (local, offline)',           note: 'llama3.2, mistral, deepseek, phi-3, qwen, and every future model' },
  { text: 'Global keyboard shortcut',                   note: 'Cmd+Shift+Space from any app, any window, any Space' },
  { text: 'Activate on 1 Mac',                   note: null },
  { text: 'All future updates',                         note: null },
];

const cloudFeatures = [
  { text: 'Everything in Pro',                          note: null },
  { text: 'Cloud routing: Claude, GPT-4o, Gemini',      note: 'No API key required' },
  { text: 'DeepSeek V3 and Mistral Large',              note: null },
  { text: 'Priority response queue',                    note: null },
  { text: 'Activate on 2 Macs',                   note: null },
  { text: 'Cancel any time',                            note: null },
];
---

<section id="pricing" aria-labelledby="pricing-heading">
  <div class="wrap">

    <div class="pr-header" data-reveal>
      <span class="eyebrow"><span class="eyebrow-dot"></span>Pricing</span>
      <h2 id="pricing-heading" class="pr-h2">
        $99 once.<br>No annual renewal trap.
      </h2>
      <p class="pr-sub">
        Pro is a one-time purchase. You own it, it updates forever, and you never get an
        invoice again. Cloud adds managed AI routing for people who don't want to manage API keys.
      </p>
    </div>

    <div class="pr-cards">

      <!-- Pro card -->
      <div class="pr-card pr-pro" data-reveal>
        <div class="prc-toprow">
          <div>
            <span class="prc-label mono">Pro</span>
            <p class="prc-sub">One-time · owns forever</p>
          </div>
          <span class="prc-popular">Most popular</span>
        </div>

        <div class="prc-price">
          <span class="prc-amt">$99</span>
          <div class="prc-price-note">
            <span>one-time payment</span>
            <span class="mono prc-tax">USD · no tax in most countries</span>
          </div>
        </div>

        <a href="https://buy.stripe.com/test_00w00l55neEv6itf354ow00" target="_blank" rel="noopener" class="btn btn-ink prc-cta">
          Buy Pro — $99
        </a>

        <ul class="prc-list" role="list">
          {proFeatures.map(f => (
            <li class="prc-item" role="listitem">
              <iconify-icon icon="lucide:check" class="prc-check" aria-hidden="true"></iconify-icon>
              <div>
                <span>{f.text}</span>
                {f.note && <span class="prc-note mono">{f.note}</span>}
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Cloud card -->
      <div class="pr-card pr-cloud" data-reveal data-d="2">
        <div class="prc-toprow">
          <div>
            <span class="prc-label prc-label-cloud mono">Cloud</span>
            <p class="prc-sub">Monthly · cancel any time</p>
          </div>
        </div>

        <div class="prc-price">
          <span class="prc-amt">$12</span>
          <div class="prc-price-note">
            <span>per month</span>
            <span class="mono prc-tax">no lock-in · cancel in settings</span>
          </div>
        </div>

        <a href="https://buy.stripe.com/test_14AdRbdBT8g7eOZ7AD4ow01" target="_blank" rel="noopener" class="btn btn-ghost prc-cta prc-cta-cloud">
          Start Cloud — $12/mo
        </a>

        <ul class="prc-list" role="list">
          {cloudFeatures.map(f => (
            <li class="prc-item prc-item-cloud" role="listitem">
              <iconify-icon icon="lucide:check" class="prc-check prc-check-cloud" aria-hidden="true"></iconify-icon>
              <div>
                <span>{f.text}</span>
                {f.note && <span class="prc-note mono">{f.note}</span>}
              </div>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="pr-refund" data-reveal>
      <iconify-icon icon="lucide:shield-check" style="font-size:16px;color:var(--acc);flex-shrink:0;" aria-hidden="true"></iconify-icon>
      14 day no questions refund applies only to your first Cloud subscription charge. Renewals and one time Pro purchases are final.
    </div>

  </div>
</section>

<style>
  #pricing { padding: 32px 0 80px; }

  .pr-header { margin-bottom: 44px; display: flex; flex-direction: column; gap: 16px; max-width: 600px; }
  .pr-h2 {
    font-size: clamp(28px, 4.5vw, 56px);
    font-weight: 700; letter-spacing: -0.055em; line-height: 1.06; color: var(--ink);
  }
  .pr-sub { font-size: 15px; line-height: 1.75; color: var(--mid); max-width: 480px; }

  .pr-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 800px; margin-bottom: 20px; }

  .pr-card {
    border: 1px solid var(--bdr); border-radius: 14px; padding: 36px;
    display: flex; flex-direction: column;
    transition: box-shadow .2s, transform .2s var(--spring);
  }
  .pr-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }
  .pr-pro  { background: var(--bg); border-color: var(--bdr-hi); }
  .pr-cloud{ background: var(--bg2); }

  .prc-toprow {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 12px; margin-bottom: 24px;
  }
  .prc-label { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--acc); display: block; margin-bottom: 4px; }
  .prc-label-cloud { color: #4A90FF; }
  .prc-sub { font-size: 12px; color: var(--dim); }
  .prc-popular {
    font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--bg); background: var(--ink); padding: 4px 9px; border-radius: 4px;
    flex-shrink: 0;
  }

  .prc-price { display: flex; align-items: baseline; gap: 12px; margin-bottom: 24px; }
  .prc-amt  { font-size: 56px; font-weight: 700; letter-spacing: -0.065em; line-height: 1; color: var(--ink); }
  .prc-price-note { display: flex; flex-direction: column; gap: 2px; font-size: 12px; color: var(--mid); }
  .prc-tax  { font-size: 10px; color: var(--dim); }

  .prc-cta { width: 100%; justify-content: center; margin-bottom: 28px; padding: 13px; font-size: 14px; border-radius: 9px; }
  .prc-cta-cloud { border-color: var(--bdr-hi); }

  .prc-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .prc-item { display: flex; align-items: flex-start; gap: 9px; font-size: 13px; color: var(--mid); }
  .prc-check { flex-shrink: 0; font-size: 14px; color: var(--acc); margin-top: 1px; }
  .prc-check-cloud { color: #4A90FF; }
  .prc-note { display: block; font-size: 10px; color: var(--dim); margin-top: 2px; }

  .pr-refund {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 12px; color: var(--mid);
    padding: 12px 18px; border-radius: 8px;
    background: var(--acc-low); border: 1px solid var(--acc-bdr);
  }

  @media (max-width: 700px) { .pr-cards { grid-template-columns: 1fr; max-width: 440px; } }
</style>
