---
// Pricing — clean, Apple-quality. Two tiers. Real Stripe links.
const PRO_LINK   = 'https://buy.stripe.com/test_00w00l55neEv6itf354ow00';
const CLOUD_LINK = 'https://buy.stripe.com/test_14AdRbdBT8g7eOZ7AD4ow01';
---

<section id="pricing" class="section pricing-section">
  <div class="pricing-inner">

    <div class="pricing-head">
      <div class="tag teal" style="margin-bottom:24px">
        <span class="tag-dot"></span>
        PRICING
      </div>
      <h2 class="pricing-title">
        Own it.<br>Or run it everywhere.
      </h2>
      <p class="pricing-sub">
        No per-request charges. No usage caps. No hidden costs.
      </p>
    </div>

    <div class="pricing-grid">

      <!-- Pro -->
      <div class="price-card" id="card-pro">
        <div class="card-top">
          <div class="card-plan font-mono">PRO</div>
          <div class="card-badge font-mono">LIFETIME</div>
        </div>

        <div class="card-price">
          <span class="price-amt">$99</span>
          <span class="price-freq font-mono">once</span>
        </div>

        <p class="card-desc">
          Full 7-stage RMPA pipeline. All three providers. Pay once, own it forever. 
          Includes 2 years of feature updates.
        </p>

        <ul class="card-features">
          <li>7-stage RMPA pipeline</li>
          <li>Claude + GPT-4o + DeepSeek</li>
          <li>Activate on up to 3 Macs</li>
          <li>Local processing only</li>
          <li>2 years of updates included</li>
        </ul>

        <a href={PRO_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-ghost card-cta" data-cursor="BUY">
          Buy Pro License
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>

        <div class="card-note font-mono">30-day money-back guarantee</div>
      </div>

      <!-- Cloud -->
      <div class="price-card price-card-featured" id="card-cloud">
        <!-- Glow border -->
        <div class="featured-glow" aria-hidden="true"></div>

        <div class="card-top">
          <div class="card-plan font-mono">CLOUD</div>
          <div class="card-badge card-badge-teal font-mono">MOST POPULAR</div>
        </div>

        <div class="card-price">
          <span class="price-amt">$12</span>
          <span class="price-freq font-mono">/month</span>
        </div>

        <p class="card-desc">
          Everything in Pro, plus cloud relay, cross-device sync, and persistent context memory. 
          Works on up to 5 machines simultaneously.
        </p>

        <ul class="card-features">
          <li>Everything in Pro</li>
          <li>Cloud relay (edge-deployed, &lt;200ms)</li>
          <li>Cross-device sync · 5 Macs</li>
          <li>Persistent context memory</li>
          <li>Priority model access</li>
        </ul>

        <a href={CLOUD_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-primary card-cta" data-cursor="SUBSCRIBE">
          Start Cloud
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>

        <div class="card-note font-mono">Cancel anytime. No lock-in.</div>
      </div>

    </div>

    <!-- Comparison footer -->
    <div class="pricing-compare">
      <div class="compare-row compare-header font-mono">
        <span></span>
        <span>Pro</span>
        <span>Cloud</span>
      </div>
      <div class="compare-row">
        <span>7-stage RMPA</span>
        <span class="check teal">✓</span>
        <span class="check teal">✓</span>
      </div>
      <div class="compare-row">
        <span>All 3 providers</span>
        <span class="check teal">✓</span>
        <span class="check teal">✓</span>
      </div>
      <div class="compare-row">
        <span>Machines</span>
        <span class="font-mono">3</span>
        <span class="font-mono">5</span>
      </div>
      <div class="compare-row">
        <span>Cloud relay</span>
        <span class="check muted">—</span>
        <span class="check teal">✓</span>
      </div>
      <div class="compare-row">
        <span>Context memory</span>
        <span class="check muted">—</span>
        <span class="check teal">✓</span>
      </div>
      <div class="compare-row">
        <span>Cross-device sync</span>
        <span class="check muted">—</span>
        <span class="check teal">✓</span>
      </div>
    </div>

  </div>
</section>

<style>
  .pricing-section { padding: 120px 0; }

  .pricing-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 60px;
  }

  .pricing-head { text-align: center; }
  .pricing-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 16px;
  }
  .pricing-sub {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.6;
  }

  /* ── Grid ──────────────────────── */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    width: 100%;
    align-items: start;
  }

  /* ── Cards ─────────────────────── */
  .price-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform 0.3s var(--ease-spring), border-color 0.3s;
    position: relative;
    overflow: hidden;
  }
  .price-card:hover { transform: translateY(-4px); }

  .price-card-featured {
    border-color: rgba(0,255,178,0.2);
    background: rgba(0,255,178,0.02);
  }

  .featured-glow {
    position: absolute;
    top: -80px; left: 50%;
    transform: translateX(-50%);
    width: 200px; height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,255,178,0.12), transparent 70%);
    pointer-events: none;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-plan {
    font-size: 12px;
    color: var(--text-3);
    letter-spacing: 0.15em;
  }

  .card-badge {
    font-size: 9px;
    color: var(--text-3);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 3px 10px;
    letter-spacing: 0.1em;
  }
  .card-badge-teal {
    color: var(--teal);
    background: rgba(0,255,178,0.06);
    border-color: rgba(0,255,178,0.15);
  }

  .card-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .price-amt {
    font-size: 56px;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: var(--text-1);
    line-height: 1;
    font-family: 'Space Grotesk', sans-serif;
  }
  .price-freq {
    font-size: 14px;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .card-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-2);
  }

  .card-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .card-features li {
    font-size: 14px;
    color: var(--text-2);
    padding-left: 20px;
    position: relative;
  }
  .card-features li::before {
    content: '';
    position: absolute;
    left: 0; top: 7px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(0,255,178,0.5);
  }

  .card-cta {
    width: 100%;
    justify-content: center;
  }

  .card-note {
    font-size: 11px;
    color: var(--text-3);
    text-align: center;
    letter-spacing: 0.04em;
  }

  /* ── Comparison ─────────────────── */
  .pricing-compare {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .compare-row {
    display: grid;
    grid-template-columns: 1fr 100px 100px;
    padding: 13px 24px;
    font-size: 13px;
    color: var(--text-2);
    border-bottom: 1px solid var(--border);
    align-items: center;
  }
  .compare-row:last-child { border-bottom: none; }
  .compare-row:hover { background: rgba(255,255,255,0.02); }

  .compare-header {
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(255,255,255,0.02);
  }
  .compare-header span:nth-child(2), .compare-header span:nth-child(3),
  .compare-row .check, .compare-row .font-mono { text-align: center; }

  .check.teal  { color: var(--teal);   }
  .check.muted { color: var(--text-3); }

  @media (max-width: 640px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .pricing-inner { padding: 0 20px; }
  }
</style>
