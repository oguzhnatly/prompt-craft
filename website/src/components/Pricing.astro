---
const PRO_URL   = 'https://buy.stripe.com/test_00w00l55neEv6itf354ow00';
const CLOUD_URL = 'https://buy.stripe.com/test_14AdRbdBT8g7eOZ7AD4ow01';
---

<section id="pricing" class="section pricing-section">
  <div class="container">
    <div class="pricing-head" data-reveal>
      <div class="badge teal" style="margin-bottom:20px">
        <span class="badge-dot"></span>
        PRICING
      </div>
      <h2 class="pricing-title syne">
        Own it or<br>run it in the cloud.
      </h2>
      <p class="pricing-sub">
        No usage-based billing. No seat fees. No surprises.
        Buy once or subscribe — both tiers get the full pipeline.
      </p>
    </div>

    <div class="pricing-grid" data-reveal data-reveal-d="2">

      <!-- Pro -->
      <div class="price-card">
        <div class="pc-top">
          <div class="badge" style="margin-bottom:16px">PRO</div>
          <div class="pc-price">
            <span class="pc-amount syne">$99</span>
            <div class="pc-freq">
              <span class="mono">one-time</span>
              <span class="pc-detail mono">2 years of updates included</span>
            </div>
          </div>
          <p class="pc-tagline">Full pipeline. All 7 stages. No subscription. Pay once, own it forever.</p>
        </div>

        <div class="pc-feats">
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Full RMPA pipeline — all 7 stages
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Use your own API keys (Claude, GPT-4o, DeepSeek)
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Up to 3 Macs
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Local context engine
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Custom styles + templates
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Lifetime license · 30-day refund
          </div>
        </div>

        <a href={PRO_URL} class="btn btn-outline pc-cta" target="_blank" rel="noopener">
          Buy Pro License
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <!-- Cloud -->
      <div class="price-card price-card-feat">
        <div class="pc-popular mono">MOST POPULAR</div>
        <div class="pc-top">
          <div class="badge teal" style="margin-bottom:16px"><span class="badge-dot"></span> CLOUD</div>
          <div class="pc-price">
            <span class="pc-amount syne" style="color:var(--teal-d)">$12</span>
            <div class="pc-freq">
              <span class="mono">/month</span>
              <span class="pc-detail mono">cancel anytime</span>
            </div>
          </div>
          <p class="pc-tagline">Everything in Pro, plus context memory, cross-device sync, and zero-config cloud relay.</p>
        </div>

        <div class="pc-feats">
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Everything in Pro
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Cloudflare edge proxy — no API keys needed
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Persistent cross-device context memory
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Up to 5 Macs
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Priority access to new models
          </div>
          <div class="pc-feat">
            <svg class="pf-check" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6.5" stroke="var(--teal-d)" stroke-width="1.2"/><polyline points="4,7 6.2,9.2 10,5" stroke="var(--teal-d)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            14-day free trial · cancel anytime
          </div>
        </div>

        <a href={CLOUD_URL} class="btn btn-accent pc-cta" target="_blank" rel="noopener">
          Start Free Trial
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>

        <p class="pc-trial-note mono">14 days free · no credit card required</p>
      </div>

    </div>

    <!-- Compare note -->
    <div class="pricing-compare" data-reveal data-reveal-d="3">
      <p class="mono">
        Not sure?
        <a href="/download">Try the 14-day trial</a> — full access, no card, no commitment.
      </p>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 100px 0;
    background: var(--paper);
  }

  .pricing-head { text-align: center; margin-bottom: 56px; }
  .pricing-title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800; letter-spacing: -0.045em;
    line-height: 1.1; color: var(--ink);
    margin-bottom: 16px;
  }
  .pricing-sub {
    font-size: 16px; line-height: 1.65;
    color: var(--ink-2); max-width: 480px;
    margin: 0 auto;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto 32px;
  }

  .price-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: 36px 32px;
    display: flex; flex-direction: column;
    gap: 28px;
    position: relative;
    transition: box-shadow .3s, transform .3s var(--ease-spring);
    cursor: none;
  }
  .price-card:hover {
    box-shadow: 0 8px 40px rgba(12,11,24,0.08);
    transform: translateY(-3px);
  }

  .price-card-feat {
    border-color: rgba(0,200,150,0.3);
    background: linear-gradient(160deg, rgba(0,200,150,0.03) 0%, white 40%);
    box-shadow: 0 0 0 1px rgba(0,200,150,0.1) inset;
  }
  .price-card-feat:hover { box-shadow: 0 12px 50px rgba(0,200,150,0.12), 0 0 0 1px rgba(0,200,150,0.1) inset; }

  .pc-popular {
    position: absolute;
    top: -11px; left: 50%; transform: translateX(-50%);
    padding: 3px 14px;
    background: var(--teal);
    color: white;
    border-radius: 999px;
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .pc-top { display: flex; flex-direction: column; }

  .pc-price {
    display: flex; align-items: flex-end;
    gap: 10px; margin-bottom: 12px;
  }
  .pc-amount {
    font-size: 56px; font-weight: 800;
    letter-spacing: -0.05em; line-height: 1;
    color: var(--ink);
  }
  .pc-freq {
    display: flex; flex-direction: column; gap: 2px;
    padding-bottom: 4px;
  }
  .pc-freq span { font-size: 13px; color: var(--ink-3); }
  .pc-detail { font-size: 10px !important; color: var(--ink-4) !important; }

  .pc-tagline { font-size: 14px; color: var(--ink-2); line-height: 1.6; }

  .pc-feats { display: flex; flex-direction: column; gap: 12px; flex: 1; }
  .pc-feat {
    display: flex; align-items: flex-start;
    gap: 10px;
    font-size: 13px; color: var(--ink-2); line-height: 1.4;
  }
  .pf-check { width: 14px; height: 14px; flex-shrink: 0; margin-top: 1px; }

  .pc-cta { width: 100%; justify-content: center; border-radius: var(--r-md); }
  .pc-trial-note { font-size: 11px; color: var(--ink-4); text-align: center; margin-top: -16px; }

  .pricing-compare {
    text-align: center;
    font-size: 14px; color: var(--ink-3);
    padding-top: 12px;
  }
  .pricing-compare a { color: var(--teal-d); font-weight: 500; }
  .pricing-compare a:hover { text-decoration: underline; }

  @media (max-width: 680px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 420px; }
    .price-card { padding: 28px 24px; }
    .pc-amount { font-size: 44px; }
  }
</style>
