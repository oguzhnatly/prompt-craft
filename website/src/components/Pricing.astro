---
const tiers = [
  {
    id: 'pro',
    name: 'Pro',
    price: '$99',
    period: 'once',
    tag: 'Lifetime License',
    desc: 'Full pipeline. All 7 stages. No subscription. Pay once, own it forever with 2 years of updates.',
    cta: 'Buy Pro License',
    ctaHref: 'https://buy.stripe.com/test_00w00l55neEv6itf354ow00',
    featured: false,
    accent: 'rgba(255,255,255,0.1)',
    features: [
      'Full 7-stage RMPA pipeline',
      'Unlimited local optimizations',
      'Claude, GPT-4o, DeepSeek, Ollama',
      'Alfred + Raycast extensions',
      'Custom style presets',
      '30-day prompt history',
      'Global keyboard shortcut',
      '2 years of free updates',
    ],
  },
  {
    id: 'cloud',
    name: 'Cloud',
    price: '$12',
    period: '/mo',
    tag: 'Most Powerful',
    desc: 'Everything in Pro, plus persistent context memory, cross-device sync, and a zero-config cloud relay.',
    cta: 'Start Cloud',
    ctaHref: 'https://buy.stripe.com/test_14AdRbdBT8g7eOZ7AD4ow01',
    featured: true,
    accent: 'rgba(0,229,160,0.12)',
    features: [
      'Everything in Pro',
      'Persistent context memory',
      'Entity learning across sessions',
      'Cross-device sync',
      'Managed cloud relay (no API keys)',
      '1,000 optimizations per day',
      'Priority model routing',
      'Unlimited prompt history',
    ],
  },
];
---

<section id="pricing" class="pricing-section ambient-top">
  <div class="container">

    <div class="pricing-header">
      <div class="section-tag reveal">
        <span class="mono">Pricing</span>
      </div>
      <h2 class="section-title reveal reveal-d1">
        Own it or<br />
        <span class="gradient-text">run it in the cloud.</span>
      </h2>
      <p class="section-desc reveal reveal-d2">
        No usage-based billing. No surprise invoices.
        Buy once or subscribe month to month.
      </p>
    </div>

    <div class="pricing-grid">
      {tiers.map((tier, i) => (
        <div
          class={`pricing-card reveal reveal-d${i + 1} ${tier.featured ? 'pricing-featured' : ''}`}
          style={`--card-accent: ${tier.accent}`}
          id={`pricing-card-${tier.id}`}
        >
          {tier.featured && (
            <div class="featured-badge mono">Most Popular</div>
          )}

          <!-- Corner brackets -->
          {tier.featured && (
            <>
              <div class="pc-tl"></div>
              <div class="pc-tr"></div>
              <div class="pc-bl"></div>
              <div class="pc-br"></div>
            </>
          )}

          <div class="card-content">
            <div class="tier-header">
              <div>
                <div class="tier-name-row">
                  <span class="tier-name mono">{tier.name}</span>
                  <span class="tier-tag mono">{tier.tag}</span>
                </div>
                <div class="tier-price-row">
                  <span class="tier-price">{tier.price}</span>
                  <span class="tier-period mono">{tier.period}</span>
                </div>
              </div>
            </div>

            <p class="tier-desc">{tier.desc}</p>

            <a
              href={tier.ctaHref}
              target="_blank"
              rel="noopener noreferrer"
              class={`tier-cta ${tier.featured ? 'tier-cta-featured' : 'tier-cta-default'}`}
            >
              {tier.cta}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 7h10M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            <ul class="tier-features">
              {tier.features.map(feat => (
                <li class="tier-feature">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3.5 3.5L12 2.5" stroke="var(--teal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="pricing-note reveal">
      <span class="mono">macOS 14+ required · 30-day money-back guarantee · All prices in USD</span>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 120px 24px;
    background: var(--base);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 64px;
  }

  .section-tag {
    display: inline-flex;
    font-size: 11px;
    color: var(--teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 24px;
    padding: 5px 12px;
    border: 1px solid rgba(0,229,160,0.18);
    border-radius: 100px;
    background: rgba(0,229,160,0.05);
  }

  .section-title {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--teal), #818CF8);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .section-desc {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 820px;
    margin: 0 auto;
  }

  .pricing-card {
    position: relative;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--surface);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
  }

  .pricing-card:hover {
    transform: translateY(-6px);
  }

  .pricing-featured {
    border-color: rgba(0,229,160,0.25);
    background: linear-gradient(160deg, rgba(0,229,160,0.05) 0%, var(--surface) 60%);
    box-shadow: 0 0 0 1px rgba(0,229,160,0.1), 0 20px 80px rgba(0,229,160,0.06);
  }

  .pricing-featured:hover {
    box-shadow: 0 0 0 1px rgba(0,229,160,0.2), 0 30px 100px rgba(0,229,160,0.1);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 16px;
    background: var(--teal);
    color: #050507;
    font-size: 10px;
    font-weight: 700;
    border-radius: 100px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Corner brackets for featured */
  .pc-tl, .pc-tr, .pc-bl, .pc-br {
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: rgba(0,229,160,0.3);
    border-style: solid;
  }
  .pc-tl { top: 8px; left: 8px; border-width: 1px 0 0 1px; border-radius: 2px 0 0 0; }
  .pc-tr { top: 8px; right: 8px; border-width: 1px 1px 0 0; border-radius: 0 2px 0 0; }
  .pc-bl { bottom: 8px; left: 8px; border-width: 0 0 1px 1px; border-radius: 0 0 0 2px; }
  .pc-br { bottom: 8px; right: 8px; border-width: 0 1px 1px 0; border-radius: 0 0 2px 0; }

  .card-content {
    padding: 36px 32px;
  }

  .tier-header {
    margin-bottom: 16px;
  }

  .tier-name-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .tier-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .tier-tag {
    font-size: 10px;
    color: var(--teal);
    padding: 3px 9px;
    border: 1px solid rgba(0,229,160,0.2);
    border-radius: 100px;
    background: rgba(0,229,160,0.06);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .tier-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .tier-price {
    font-size: 56px;
    font-weight: 900;
    color: var(--text-primary);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .tier-period {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .tier-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .tier-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px;
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 28px;
    transition: all 0.25s ease;
  }

  .tier-cta-featured {
    background: var(--teal);
    color: #050507;
  }

  .tier-cta-featured:hover {
    background: var(--teal-dim);
    box-shadow: 0 0 32px rgba(0,229,160,0.3);
    transform: translateY(-1px);
  }

  .tier-cta-default {
    border: 1px solid var(--border-bright);
    color: var(--text-secondary);
    background: transparent;
  }

  .tier-cta-default:hover {
    border-color: rgba(0,229,160,0.25);
    color: var(--text-primary);
    background: rgba(0,229,160,0.03);
  }

  .tier-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .tier-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .tier-feature svg { flex-shrink: 0; margin-top: 1px; }

  .pricing-note {
    text-align: center;
    margin-top: 32px;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  @media (max-width: 640px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // 3D tilt on pricing cards
  document.querySelectorAll('.pricing-card').forEach(card => {
    const el = card as HTMLElement;
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      el.style.transform = `translateY(-6px) rotateY(${x * 6}deg) rotateX(${-y * 4}deg)`;
    });
    el.addEventListener('mouseleave', () => {
      el.style.transform = '';
    });
  });
</script>
