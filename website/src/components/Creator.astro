---
// Creator — who built it, and why they're qualified to
---

<section id="creator" class="section creator-section">
  <div class="creator-inner">

    <div class="creator-card">
      <!-- Left: bio -->
      <div class="creator-bio">
        <div class="tag teal" style="margin-bottom: 28px;">
          <span class="tag-dot"></span>
          BUILT BY
        </div>

        <div class="creator-ident">
          <div class="creator-avatar" aria-label="Oguzhan Atalay avatar">
            <svg viewBox="0 0 80 80" fill="none">
              <circle cx="40" cy="40" r="39" stroke="rgba(0,255,178,0.2)" stroke-width="1"/>
              <circle cx="40" cy="32" r="14" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <path d="M16 68c0-13.25 10.75-24 24-24s24 10.75 24 24" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" stroke-linecap="round"/>
              <!-- Teal accent ring -->
              <circle cx="40" cy="40" r="36" stroke="var(--teal)" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.3"/>
            </svg>
          </div>
          <div class="creator-name-block">
            <h2 class="creator-name">Oguzhan Atalay</h2>
            <div class="creator-title font-mono">Senior Full Stack Engineer</div>
            <div class="creator-location font-mono">📍 Lisbon, Portugal</div>
          </div>
        </div>

        <p class="creator-bio-text">
          Built PromptCraft after spending years watching engineers ship mediocre AI integrations 
          not because the models were bad, but because the prompts were. 
          PromptCraft is the infrastructure layer that was missing.
        </p>

        <div class="creator-links">
          <a href="https://github.com/oguzhnatly" target="_blank" rel="noopener noreferrer" class="creator-link" data-cursor="GITHUB">
            <svg viewBox="0 0 20 20" fill="none">
              <path d="M10 2C5.58 2 2 5.58 2 10c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0018 10c0-4.42-3.58-8-8-8z" fill="currentColor"/>
            </svg>
            @oguzhnatly
          </a>
          <a href="https://twitter.com/oguzhnatly" target="_blank" rel="noopener noreferrer" class="creator-link" data-cursor="TWITTER">
            <svg viewBox="0 0 20 20" fill="none">
              <path d="M2.5 2.5l15 15M2.5 17.5l5.5-5.5M17.5 2.5L12 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M16.9 2.5H12.5l-9 14.5H7.9l9-14.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
            @oguzhnatly
          </a>
        </div>

        <a href="https://github.com/oguzhnatly/prompt-craft/blob/main/docs/RMPA_WHITEPAPER.md" target="_blank" rel="noopener noreferrer" class="whitepaper-link" data-cursor="READ">
          <div class="wp-icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none">
              <rect x="3" y="2" width="14" height="16" rx="2" stroke="var(--teal)" stroke-width="1.5"/>
              <path d="M7 7h6M7 11h4" stroke="var(--teal)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <div class="wp-title font-mono">RMPA Whitepaper</div>
            <div class="wp-sub">The architecture behind the pipeline →</div>
          </div>
        </a>
      </div>

      <!-- Right: stats + stack -->
      <div class="creator-right">
        <div class="creator-stats">
          <div class="cs-item">
            <div class="cs-num font-mono" data-count="265">0</div>
            <div class="cs-label font-mono">GitHub stars</div>
            <div class="cs-sub">flutter_carplay</div>
          </div>
          <div class="cs-item">
            <div class="cs-num font-mono" data-count="5">0</div>
            <div class="cs-label font-mono">Years shipping</div>
            <div class="cs-sub">production software</div>
          </div>
          <div class="cs-item">
            <div class="cs-num font-mono" data-count="123">0</div>
            <div class="cs-label font-mono">Tests passing</div>
            <div class="cs-sub">PromptCraft v1.1.0</div>
          </div>
          <div class="cs-item">
            <div class="cs-num font-mono" data-count="7">0</div>
            <div class="cs-label font-mono">Pipeline stages</div>
            <div class="cs-sub">RMPA v1.1</div>
          </div>
        </div>

        <div class="creator-stack">
          <div class="stack-label font-mono">STACK</div>
          <div class="stack-items">
            <span class="stack-tag">Swift / SwiftUI</span>
            <span class="stack-tag">TypeScript</span>
            <span class="stack-tag">Cloudflare Workers</span>
            <span class="stack-tag">React / Next.js</span>
            <span class="stack-tag">Flutter</span>
            <span class="stack-tag">FastAPI</span>
            <span class="stack-tag">Astro</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .creator-section { padding: 120px 0; }

  .creator-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .creator-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--surface);
    border: 1px solid var(--border-hi);
    border-radius: 24px;
    overflow: hidden;
  }

  /* Bio side */
  .creator-bio {
    padding: 48px;
    border-right: 1px solid var(--border);
  }

  .creator-ident {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .creator-avatar {
    width: 72px; height: 72px;
    flex-shrink: 0;
    position: relative;
  }
  .creator-avatar svg { width: 100%; height: 100%; }

  .creator-name {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-1);
    margin-bottom: 4px;
  }
  .creator-title {
    font-size: 11px;
    color: var(--teal);
    letter-spacing: 0.06em;
    margin-bottom: 2px;
  }
  .creator-location { font-size: 10px; color: var(--text-3); letter-spacing: 0.04em; }

  .creator-bio-text {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-2);
    margin-bottom: 28px;
  }

  .creator-links {
    display: flex;
    gap: 16px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .creator-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.2s;
  }
  .creator-link:hover { color: var(--text-1); }
  .creator-link svg { width: 16px; height: 16px; }

  .whitepaper-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: rgba(0,255,178,0.04);
    border: 1px solid rgba(0,255,178,0.12);
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .whitepaper-link:hover {
    background: rgba(0,255,178,0.07);
    border-color: rgba(0,255,178,0.2);
  }
  .wp-icon { width: 36px; height: 36px; flex-shrink: 0; display:flex; align-items:center; justify-content:center; }
  .wp-icon svg { width:20px; height:20px; }
  .wp-title { font-size: 12px; color: var(--teal); letter-spacing: 0.06em; margin-bottom: 3px; }
  .wp-sub   { font-size: 12px; color: var(--text-2); }

  /* Stats + stack side */
  .creator-right { padding: 48px; display: flex; flex-direction: column; gap: 40px; }

  .creator-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  .cs-item { display: flex; flex-direction: column; gap: 4px; }

  .cs-num {
    font-size: 40px;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .cs-label {
    font-size: 11px;
    color: var(--text-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .cs-sub { font-size: 11px; color: var(--text-3); }

  .creator-stack { display: flex; flex-direction: column; gap: 12px; }

  .stack-label {
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .stack-items { display: flex; flex-wrap: wrap; gap: 8px; }

  .stack-tag {
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-2);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 10px;
  }

  @media (max-width: 768px) {
    .creator-card { grid-template-columns: 1fr; }
    .creator-bio { border-right: none; border-bottom: 1px solid var(--border); padding: 32px; }
    .creator-right { padding: 32px; }
    .creator-inner { padding: 0 20px; }
  }
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el  = entry.target as HTMLElement;
      const end = parseInt(el.dataset.count!, 10);
      let cur   = 0;
      const step = Math.max(1, Math.ceil(end / 40));
      const t = setInterval(() => {
        cur = Math.min(cur + step, end);
        el.textContent = cur.toString();
        if (cur >= end) clearInterval(t);
      }, 30);
      obs.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-count]').forEach(el => obs.observe(el));
</script>
