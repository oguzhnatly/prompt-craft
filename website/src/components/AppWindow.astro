---
// Pixel-perfect replica of the real PromptCraft macOS popover (420×580)
// Based directly on MainPopoverView.swift source
---

<div class="mac-window" id="app-window" role="img" aria-label="PromptCraft macOS app window">
  <!-- ── Title bar ── -->
  <div class="win-titlebar">
    <div class="traffic-lights" aria-hidden="true">
      <span class="tl tl-r" title="Close"></span>
      <span class="tl tl-y" title="Minimize"></span>
      <span class="tl tl-g" title="Maximize"></span>
    </div>
    <span class="win-title mono">PromptCraft</span>
    <div class="win-actions" aria-hidden="true">
      <button class="win-btn" tabindex="-1" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M8 2C4.69 2 2 4.69 2 8s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 2.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm0 8c-1.65 0-3.11-.84-4-2.12.02-.99 2.67-1.53 4-1.53 1.33 0 3.98.54 4 1.53A4.99 4.99 0 018 12.5z" fill="currentColor"/>
        </svg>
      </button>
      <button class="win-btn" tabindex="-1" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M8 2a6 6 0 100 12A6 6 0 008 2zm0 2a4 4 0 110 8A4 4 0 018 4zm.75 2h-1.5v3.25L9.1 10.6l1.06-1.06-1.41-1.41V6z" fill="currentColor" opacity=".6"/>
        </svg>
      </button>
      <button class="win-btn" tabindex="-1" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M8.5 2.5c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm.75 9h-1.5V7h1.5v4.5zm0-6h-1.5v-1.5h1.5V5.5z" fill="currentColor" opacity=".6"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="win-divider"></div>

  <!-- ── Input area ── -->
  <div class="win-input-wrap">
    <div class="win-input" id="win-input-el">
      <div class="win-input-text mono" id="win-type-text" aria-live="polite"></div>
      <span class="win-cursor" id="win-cursor" aria-hidden="true"></span>
    </div>
    <div class="win-input-footer">
      <span class="mono" id="win-char-count">0 characters</span>
    </div>
  </div>

  <!-- ── Style pills ── -->
  <div class="win-styles">
    <div class="win-styles-scroll">
      <button class="wp wp-active" tabindex="-1" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 16 16" fill="none"><path d="M8 2L2 14h12L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        General
      </button>
      <button class="wp" tabindex="-1" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M5 8h6M5 5h6M5 11h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        Engineering
      </button>
      <button class="wp" tabindex="-1" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M5.5 8.5L7 10l3.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Research
      </button>
      <button class="wp" tabindex="-1" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 16 16" fill="none"><path d="M3 4h10M3 8h7M3 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Content
      </button>
      <button class="wp wp-plus" tabindex="-1" aria-hidden="true">+</button>
    </div>
    <div class="win-verbosity mono" id="win-verb">
      <span class="verb-dot"></span>
      <span id="win-verb-text">Concise</span>
    </div>
  </div>

  <!-- ── Optimize button ── -->
  <div class="win-optimize-wrap">
    <button class="win-optimize" id="win-opt-btn" tabindex="-1" aria-hidden="true">
      <span id="win-opt-label">Optimize</span>
      <span class="mono win-shortcut" id="win-shortcut">⌘↩</span>
    </button>
  </div>

  <!-- ── Output area ── -->
  <div class="win-output-wrap">
    <div class="win-output" id="win-output-el">
      <div class="win-output-empty" id="win-empty-state">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M3 6a2 2 0 012-2h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6z" stroke="currentColor" stroke-width="1.5"/></svg>
        <span>Your optimized prompt will appear here</span>
      </div>
      <div class="win-output-text mono" id="win-output-text" aria-live="polite" style="display:none"></div>
      <div class="win-output-actions" id="win-output-actions" style="display:none">
        <button class="win-small-btn" tabindex="-1" aria-hidden="true">
          <svg width="11" height="11" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M3 11V3h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Copy
        </button>
        <button class="win-small-btn" tabindex="-1" aria-hidden="true">
          <svg width="11" height="11" viewBox="0 0 16 16" fill="none"><path d="M8 3v8M4 8l4 4 4-4M2 14h12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Export
        </button>
        <button class="win-small-btn win-small-btn-clear" tabindex="-1" aria-hidden="true">
          <svg width="10" height="10" viewBox="0 0 16 16" fill="none"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="win-divider"></div>

  <!-- ── Footer ── -->
  <div class="win-footer">
    <span class="mono win-f-shortcut">⌘⇧Space to toggle</span>
    <span class="win-f-trial mono" id="win-trial-pill">
      <svg width="8" height="8" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.2"/><path d="M5 3v2.5L6.5 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      14 days left
    </span>
    <span class="win-f-privacy mono">
      <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v5c0 3.31 2.45 6.41 6 7.16C11.55 15.41 14 12.31 14 9V4L8 1z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
      Local & Private
    </span>
  </div>
</div>

<style>
  .mac-window {
    width: 420px;
    background: var(--win-bg);
    border-radius: 13px;
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow:
      0 0 0 0.5px rgba(0,0,0,0.4),
      0 8px 24px rgba(0,0,0,0.25),
      0 24px 80px rgba(0,0,0,0.18),
      0 60px 120px rgba(0,0,0,0.12);
    overflow: hidden;
    color: var(--win-text);
    user-select: none;
    font-size: 13px;
  }

  /* Title bar */
  .win-titlebar {
    display: flex; align-items: center;
    height: 44px; padding: 0 14px;
    background: var(--win-bg-2);
    gap: 10px;
  }
  .traffic-lights { display: flex; gap: 7px; }
  .tl {
    width: 12px; height: 12px; border-radius: 50%;
    flex-shrink: 0;
  }
  .tl-r { background: #FF5F57; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.3); }
  .tl-y { background: #FEBC2E; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.3); }
  .tl-g { background: #28C840; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.3); }

  .win-title {
    flex: 1; text-align: center;
    font-size: 13px; font-weight: 500; letter-spacing: -0.01em;
    color: var(--win-text);
  }

  .win-actions { display: flex; gap: 2px; }
  .win-btn {
    width: 28px; height: 28px;
    border-radius: 7px;
    background: transparent; border: none;
    display: flex; align-items: center; justify-content: center;
    color: var(--win-text-2);
    transition: background .15s, color .15s;
    cursor: none;
  }
  .win-btn:hover { background: rgba(255,255,255,0.08); color: var(--win-text); }

  /* Divider */
  .win-divider { height: 1px; background: var(--win-border); }

  /* Input */
  .win-input-wrap {
    padding: 10px 14px 6px;
  }
  .win-input {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 9px 10px;
    min-height: 80px;
    position: relative;
    box-shadow: inset 0 1px 3px rgba(0,0,0,0.25);
  }
  .win-input-text {
    font-size: 12px;
    line-height: 1.6;
    color: var(--win-text);
    min-height: 60px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .win-cursor {
    display: inline-block;
    width: 2px; height: 14px;
    background: var(--win-blue);
    vertical-align: text-bottom;
    margin-left: 1px;
    animation: blink-cur .9s step-end infinite;
  }
  @keyframes blink-cur { 0%,100%{opacity:1} 50%{opacity:0} }

  .win-input-footer {
    padding: 3px 2px 0;
  }
  .win-input-footer span {
    font-size: 10px;
    color: var(--win-text-3);
    letter-spacing: 0.03em;
  }

  /* Styles */
  .win-styles {
    padding: 0 14px 6px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .win-styles-scroll {
    display: flex; gap: 6px;
    overflow-x: auto;
    scrollbar-width: none;
    flex: 1;
  }
  .win-styles-scroll::-webkit-scrollbar { display: none; }

  .wp {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    border: 0.5px solid rgba(255,255,255,0.1);
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; font-weight: 500;
    color: var(--win-text-2);
    white-space: nowrap;
    cursor: none;
    transition: background .15s, color .15s;
  }
  .wp:hover { background: rgba(255,255,255,0.1); color: var(--win-text); }
  .wp-active {
    background: var(--win-blue);
    border-color: transparent;
    color: #fff;
  }
  .wp-plus {
    width: 24px; padding: 4px; justify-content: center;
    font-size: 14px; line-height: 1;
  }

  .win-verbosity {
    display: flex; align-items: center; gap: 5px;
    padding: 3px 9px;
    border-radius: 999px;
    background: rgba(10,132,255,0.1);
    border: 0.5px solid rgba(10,132,255,0.2);
    font-size: 10px; font-weight: 500;
    color: var(--win-blue);
    white-space: nowrap;
    flex-shrink: 0;
    cursor: none;
  }
  .verb-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--win-blue);
    flex-shrink: 0;
  }

  /* Optimize button */
  .win-optimize-wrap {
    padding: 4px 14px 8px;
  }
  .win-optimize {
    width: 100%;
    display: flex; align-items: center; justify-content: center;
    gap: 8px;
    height: 36px;
    border-radius: 8px;
    background: var(--win-blue);
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 600;
    color: #fff;
    cursor: none;
    position: relative;
    overflow: hidden;
    transition: background .15s;
  }
  .win-optimize:hover { background: #0A7BE8; }
  .win-shortcut {
    font-size: 11px;
    opacity: 0.7;
    letter-spacing: 0.02em;
  }

  /* Output */
  .win-output-wrap {
    padding: 0 14px 8px;
    flex: 1;
  }
  .win-output {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    min-height: 120px;
    max-height: 140px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 1px 3px rgba(0,0,0,0.25);
  }
  .win-output-empty {
    display: flex; flex-direction: column;
    align-items: center; gap: 8px;
    color: var(--win-text-3);
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
  }
  .win-output-text {
    width: 100%;
    padding: 9px 10px;
    font-size: 11px;
    line-height: 1.6;
    color: var(--win-text);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .win-output-text::-webkit-scrollbar { display: none; }

  .win-output-actions {
    position: absolute; bottom: 8px; right: 8px;
    display: flex; gap: 4px;
  }
  .win-small-btn {
    display: inline-flex; align-items: center; gap: 3px;
    padding: 3px 8px;
    border-radius: 5px;
    background: rgba(255,255,255,0.07);
    border: 0.5px solid rgba(255,255,255,0.1);
    font-family: 'DM Mono', monospace;
    font-size: 10px; color: var(--win-text-2);
    cursor: none;
    transition: background .15s, color .15s;
  }
  .win-small-btn:hover { background: rgba(255,255,255,0.12); color: var(--win-text); }
  .win-small-btn-clear { padding: 3px 5px; }

  /* Footer */
  .win-footer {
    display: flex; align-items: center; gap: 0;
    height: 36px; padding: 0 14px;
    background: var(--win-bg-2);
  }
  .win-f-shortcut {
    font-size: 10px; color: var(--win-text-3);
    flex: 0; white-space: nowrap;
  }
  .win-f-trial {
    display: flex; align-items: center; gap: 4px;
    font-size: 10px; padding: 2px 7px;
    border-radius: 999px;
    background: rgba(255,160,0,0.1);
    border: 0.5px solid rgba(255,160,0,0.2);
    color: #FFAB00;
    margin: 0 auto;
  }
  .win-f-privacy {
    display: flex; align-items: center; gap: 4px;
    font-size: 10px; color: var(--win-text-3);
    white-space: nowrap;
  }
</style>

<script>
  // Live typing demo inside the app window
  const demos = [
    {
      input: 'Tell me about climate change',
      output: 'You are a climate scientist with expertise in IPCC assessment reports.\n\nTask: Provide a precise, evidence-based analysis of current climate change trajectory, including 3 key metrics, 2 feedback loops, and 5 ranked individual interventions by global impact.\n\nFormat: Start with a one-sentence summary, then structured sections. Cite confidence levels.',
    },
    {
      input: 'Write code for user login',
      output: 'You are a senior backend engineer specializing in authentication security.\n\nTask: Implement a complete user authentication flow with JWT tokens, bcrypt hashing, rate limiting, and CSRF protection.\n\nConstraints: TypeScript, Express.js, PostgreSQL. Include error handling, input validation, and unit test stubs.',
    },
    {
      input: 'How do I improve my productivity',
      output: 'You are an organizational psychologist specializing in cognitive performance and behavioral science.\n\nTask: Design a personalized productivity framework grounded in peer-reviewed research, addressing focus, energy management, and habit formation.\n\nDeliverables: 30-60-90 day implementation plan with measurable success criteria.',
    },
  ];

  const inputEl      = document.getElementById('win-type-text')!;
  const cursorEl     = document.getElementById('win-cursor')!;
  const outputEmpty  = document.getElementById('win-empty-state')!;
  const outputText   = document.getElementById('win-output-text')!;
  const outputActs   = document.getElementById('win-output-actions')!;
  const charCount    = document.getElementById('win-char-count')!;
  const optBtn       = document.getElementById('win-opt-btn')!;
  const optLabel     = document.getElementById('win-opt-label')!;
  const verbText     = document.getElementById('win-verb-text')!;

  let dIdx = 0;

  function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

  async function runWindowDemo() {
    const demo = demos[dIdx++ % demos.length];

    // Reset
    inputEl.textContent = '';
    outputText.textContent = '';
    outputText.style.display = 'none';
    outputActs.style.display = 'none';
    outputEmpty.style.display = 'flex';
    charCount.textContent = '0 characters';
    optLabel.textContent = 'Optimize';
    optBtn.style.background = 'var(--win-blue)';
    cursorEl.style.display = 'inline-block';

    // Type input
    for (const ch of demo.input) {
      inputEl.textContent += ch;
      charCount.textContent = inputEl.textContent.length + ' characters';
      await sleep(45);
    }
    await sleep(600);
    cursorEl.style.display = 'none';

    // Processing state
    optLabel.textContent = 'Optimizing...';
    optBtn.style.background = '#E17900';

    // Animate stages
    for (let i = 1; i <= 7; i++) {
      await sleep(260);
    }

    // Show output
    optLabel.textContent = 'Optimize';
    optBtn.style.background = 'var(--win-blue)';
    outputEmpty.style.display = 'none';
    outputText.style.display = 'block';
    outputActs.style.display = 'flex';

    for (const ch of demo.output) {
      outputText.textContent += ch;
      await sleep(9);
    }

    await sleep(3500);

    // Clear
    inputEl.textContent = '';
    outputText.textContent = '';
    outputText.style.display = 'none';
    outputActs.style.display = 'none';
    outputEmpty.style.display = 'flex';
    charCount.textContent = '0 characters';
    cursorEl.style.display = 'inline-block';

    await sleep(800);
    runWindowDemo();
  }

  setTimeout(runWindowDemo, 1200);
</script>
