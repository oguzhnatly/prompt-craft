---
// 100% accurate HTML replica of the real PromptCraft macOS app
// Source: MainPopoverView.swift — every value extracted directly
// App size: 420×580, light mode default, dark mode via toggle
---

<div class="app-win" id="app-win" role="img" aria-label="PromptCraft macOS app — interactive demo">

  <!-- ── Header bar (height:44) ── -->
  <div class="aw-header">
    <span class="aw-title">PromptCraft</span>
    <div class="aw-header-btns">
      <!-- clock.arrow.circlepath -->
      <button class="aw-icon-btn" id="aw-history-btn" title="History" aria-label="Open history">
        <svg viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2"/>
          <path d="M8 4.5v4L10.5 10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 3.5c.5-1 1.2-1.8 2-2.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity=".5"/>
        </svg>
      </button>
      <!-- sun/moon theme toggle -->
      <button class="aw-icon-btn aw-theme-btn" id="aw-theme-btn" title="Toggle appearance" aria-label="Toggle light/dark mode">
        <!-- Moon: visible in light mode (click to go dark) -->
        <svg class="aw-theme-moon" viewBox="0 0 16 16" fill="none">
          <path d="M13.5 9A5.5 5.5 0 017 2.5a.5.5 0 00-.6-.6A6.5 6.5 0 1013.6 9.6a.5.5 0 00-.1-.6z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <!-- Sun: visible in dark mode (click to go light) -->
        <svg class="aw-theme-sun" viewBox="0 0 16 16" fill="none" style="display:none">
          <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.2"/>
          <path d="M8 1.5v1.3M8 13.2v1.3M1.5 8h1.3M13.2 8h1.3M3.4 3.4l.9.9M11.7 11.7l.9.9M12.6 3.4l-.9.9M4.3 11.7l-.9.9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="aw-sep"></div>

  <div class="aw-screen aw-screen-history" id="aw-history-screen" hidden>
    <div class="aw-screen-header">
      <button class="aw-screen-back" id="aw-history-back" aria-label="Back to main view">
        <iconify-icon icon="lucide:chevron-left" style="font-size:12px;"></iconify-icon>
        <span>History</span>
      </button>
    </div>
    <div class="aw-screen-body aw-history-body">
      <div class="aw-history-top">
        <div class="aw-history-meta" id="aw-history-meta">0 optimizations</div>
        <div class="aw-history-search-wrap">
          <iconify-icon icon="lucide:search" style="font-size:12px;color:var(--aw-desc);"></iconify-icon>
          <input id="aw-history-search" class="aw-history-search" type="text" placeholder="Search history..." />
          <button class="aw-history-search-clear" id="aw-history-search-clear" aria-label="Clear search" hidden>
            <iconify-icon icon="lucide:x-circle" style="font-size:12px;"></iconify-icon>
          </button>
        </div>
        <div class="aw-history-filters" id="aw-history-filters">
          <button class="aw-history-filter active" data-filter="all">All</button>
          <button class="aw-history-filter" data-filter="favorites">Favorites</button>
          <button class="aw-history-filter" data-filter="general">General</button>
          <button class="aw-history-filter" data-filter="engineering">Engineering</button>
          <button class="aw-history-filter" data-filter="research">Research</button>
          <button class="aw-history-filter" data-filter="content">Content</button>
          <button class="aw-history-filter" data-filter="analysis">Analysis</button>
        </div>
      </div>
      <div class="aw-history-group-label mono">Today</div>
      <div class="aw-history-list-full" id="aw-history-list"></div>
      <button class="aw-history-clear-all" id="aw-history-clear-all">Clear All History</button>
    </div>
  </div>

  <!-- ── Input area ── -->
  <div class="aw-input-section">
    <div class="aw-input-well" id="input-well">
      <div class="aw-input-text mono" id="aw-input-text" aria-live="polite"></div>
      <div class="aw-placeholder" id="aw-placeholder">Type or paste your messy prompt here...</div>
      <span class="aw-cursor" id="aw-cursor" aria-hidden="true"></span>
      <button class="aw-clear" id="aw-clear" style="display:none" tabindex="-1" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" class="aw-clear-circle"/><path d="M5.5 5.5l5 5M10.5 5.5l-5 5" class="aw-clear-x" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <span class="aw-char-count mono" id="aw-chars">0 characters</span>
  </div>

  <!-- ── Style selector ── -->
  <div class="aw-styles-wrap">
    <div class="aw-styles-scroll" id="aw-styles">
      <button class="aw-pill aw-templates-pill" tabindex="-1" aria-hidden="true">
        <svg viewBox="0 0 13 13" fill="none"><rect x="1.5" y="1.5" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.1"/><circle cx="9.5" cy="9.5" r="3" class="aw-tmpl-dot" stroke="currentColor" stroke-width="1"/><path d="M8 9.5h3M9.5 8v3" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
        Templates
      </button>
      <button class="aw-pill aw-pill-active aw-pill-optimize" data-pill="general" tabindex="-1" aria-hidden="true" title="Optimize" aria-label="Optimize">
        <svg viewBox="0 0 13 13" fill="none">
          <path d="M6.5 1L7.4 4.2H10.8L8.2 6.3L9.1 9.5L6.5 7.4L3.9 9.5L4.8 6.3L2.2 4.2H5.6Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round" fill="none"/>
          <circle cx="10.5" cy="2.5" r="1" fill="currentColor" opacity=".6"/>
          <circle cx="2" cy="11" r="0.7" fill="currentColor" opacity=".4"/>
        </svg>
      </button>
      <button class="aw-pill" data-pill="engineering" tabindex="-1" aria-hidden="true">
        <svg viewBox="0 0 13 13" fill="none"><path d="M9 4L5 11M4 7h5.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><rect x="1" y="1" width="4" height="4" rx="1" stroke="currentColor" stroke-width="1.1"/></svg>
        Engineering
      </button>
      <button class="aw-pill" data-pill="research" tabindex="-1" aria-hidden="true">
        <svg viewBox="0 0 13 13" fill="none"><circle cx="5.5" cy="5.5" r="3.5" stroke="currentColor" stroke-width="1.2"/><path d="M8.5 8.5L11.5 11.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        Research
      </button>
      <button class="aw-pill" data-pill="content" tabindex="-1" aria-hidden="true">
        <svg viewBox="0 0 13 13" fill="none"><path d="M2 3h9M2 6h7M2 9h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        Content
      </button>
      <button class="aw-pill" data-pill="analysis" tabindex="-1" aria-hidden="true">
        <svg viewBox="0 0 13 13" fill="none"><path d="M2 10L5 7l2.5 2L11 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Analysis
      </button>
      <button class="aw-pill aw-plus-pill" tabindex="-1" aria-hidden="true">+</button>
    </div>
    <p class="aw-style-desc" id="aw-style-desc">Balanced general-purpose optimization</p>
  </div>

  <!-- ── Verbosity chip + Optimize button ── -->
  <div class="aw-action-wrap">
    <button class="aw-verbosity" id="aw-verb" title="Change verbosity" aria-label="Change verbosity">
      <span class="aw-verb-dot" id="aw-verb-dot"></span>
      <span id="aw-verb-label">Concise</span>
      <span class="aw-verb-caret">▾</span>
    </button>
    <button class="aw-optimize" id="aw-optimize" tabindex="-1" aria-hidden="true">
      <span id="aw-opt-label">Optimize</span>
      <span class="aw-cmd">⌘↩</span>
    </button>
  </div>

  <!-- ── Output area ── -->
  <div class="aw-output-section">
    <div class="aw-output-well" id="aw-output-well">
      <div class="aw-empty-state" id="aw-empty">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M3 21l1.65-3.8a9 9 0 113.4 2.9L3 21" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" opacity=".4"/>
          <path d="M7.5 12h9M7.5 8h6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity=".4"/>
        </svg>
        <span>Your optimized prompt will appear here</span>
      </div>
      <div class="aw-output-text mono" id="aw-output-text" style="display:none" aria-live="polite"></div>
    </div>

    <div class="aw-output-row" id="aw-output-row" style="visibility:hidden">
      <span class="aw-clipboard-tag mono" id="aw-clipboard-tag" style="display:none">
        <svg width="10" height="10" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M3 11V3h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        On clipboard
      </span>
      <div class="aw-row-right">
        <button class="aw-act-btn aw-act-btn-disabled" id="aw-download-btn" title="Download coming soon" aria-label="Download coming soon" aria-disabled="true">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 3v9M4 9l4 4 4-4M2 14h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="aw-act-btn" id="aw-copy-btn" title="Copy output" aria-label="Copy output">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M3 11V3h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </button>
        <button class="aw-act-btn aw-act-close" id="aw-clear-out-btn" title="Clear output" aria-label="Clear output">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" class="aw-close-circle"/><path d="M5.5 5.5l5 5M10.5 5.5l-5 5" class="aw-close-x" stroke-width="1.3" stroke-linecap="round"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="aw-sep"></div>

  <!-- ── Footer bar (height:44) ── -->
  <div class="aw-footer">
    <span class="aw-footer-shortcut">⌘⇧Space to toggle</span>
    <div class="aw-footer-right">
      <div class="aw-trial-pill">
        <svg width="9" height="9" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.1"/><path d="M6 3.5v3L7.5 8" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
        Trial: 14 days left
      </div>
      <button class="aw-privacy-btn" tabindex="-1" aria-hidden="true">
        <svg width="9" height="9" viewBox="0 0 12 12" fill="none"><path d="M6 1L1.5 3v4c0 2.5 1.8 4.8 4.5 5.4C8.7 11.8 10.5 9.5 10.5 7V3L6 1z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/></svg>
        Local &amp; Private
      </button>
    </div>
  </div>
</div>

<style is:global>
  /* ── Theme tokens (light = default) ──────────── */
  .app-win {
    --aw-bg:           #F0EDE8;
    --aw-win-bdr:      rgba(0,0,0,0.13);
    --aw-sep:          rgba(0,0,0,0.09);
    --aw-title:        rgba(0,0,0,0.86);
    --aw-icon:         rgba(0,0,0,0.42);
    --aw-icon-hbg:     rgba(0,0,0,0.06);
    --aw-icon-h:       rgba(0,0,0,0.72);
    --aw-well:         rgba(255,255,255,0.72);
    --aw-well-bdr:     rgba(0,0,0,0.10);
    --aw-inset1:       rgba(0,0,0,0.05);
    --aw-inset2:       rgba(255,255,255,0.55);
    --aw-text:         rgba(0,0,0,0.86);
    --aw-ph:           rgba(0,0,0,0.28);
    --aw-chars:        rgba(0,0,0,0.28);
    --aw-pill-bg:      rgba(0,0,0,0.06);
    --aw-pill-bdr:     rgba(0,0,0,0.10);
    --aw-pill-text:    rgba(0,0,0,0.74);
    --aw-pill-h:       rgba(0,0,0,0.10);
    --aw-desc:         rgba(0,0,0,0.40);
    --aw-out-text:     rgba(0,0,0,0.84);
    --aw-empty:        rgba(0,0,0,0.26);
    --aw-foot-key:     rgba(0,0,0,0.28);
    --aw-trial-bg:     rgba(0,0,0,0.06);
    --aw-trial-text:   rgba(0,0,0,0.48);
    --aw-priv:         rgba(0,0,0,0.28);
    --aw-act:          rgba(0,0,0,0.38);
    --aw-act-hbg:      rgba(0,0,0,0.06);
    --aw-act-h:        rgba(0,0,0,0.70);
    --aw-clear-circle: rgba(0,0,0,0.12);
    --aw-clear-x:      rgba(0,0,0,0.52);
    --aw-close-circle: rgba(0,0,0,0.07);
    --aw-close-x:      rgba(0,0,0,0.40);
    --aw-tmpl-dot-bg:  rgba(240,237,232,1);

    --aw-history-header-bdr: rgba(0,0,0,0.12);
    --aw-history-text: rgba(0,0,0,0.88);
    --aw-history-meta: rgba(0,0,0,0.48);
    --aw-history-search-bg: #F7F7F7;
    --aw-history-search-bdr: rgba(0,0,0,0.11);
    --aw-history-search-ph: rgba(0,0,0,0.38);
    --aw-history-chip-bg: #F4F4F6;
    --aw-history-chip-bdr: #D3D3D7;
    --aw-history-chip-text: #2F2F33;
    --aw-history-row-hover: rgba(0,0,0,0.04);
    --aw-history-danger: #CC3A32;

    --aw-export-bg: #EFEBE8;
    --aw-export-bdr: #D0CCCA;
    --aw-export-shadow: rgba(0,0,0,0.18);
    --aw-export-group-bg: #F6F4F2;
    --aw-export-group-bdr: #D6D2CF;
    --aw-export-head-bg: rgba(0,0,0,0.03);
    --aw-export-head-text: #9A9692;
    --aw-export-row-text: #222;
    --aw-export-row-hover: #F1EFED;
  }

  /* ── Dark mode overrides ─────────────────────── */
  .app-win.dark {
    --aw-bg:           #1C1C1E;
    --aw-win-bdr:      rgba(255,255,255,0.12);
    --aw-sep:          rgba(84,84,88,0.65);
    --aw-title:        rgba(255,255,255,0.92);
    --aw-icon:         rgba(235,235,245,0.60);
    --aw-icon-hbg:     rgba(255,255,255,0.08);
    --aw-icon-h:       rgba(255,255,255,0.85);
    --aw-well:         rgba(44,44,46,0.60);
    --aw-well-bdr:     rgba(84,84,88,0.65);
    --aw-inset1:       rgba(0,0,0,0.35);
    --aw-inset2:       rgba(255,255,255,0.03);
    --aw-text:         rgba(255,255,255,0.92);
    --aw-ph:           rgba(235,235,245,0.30);
    --aw-chars:        rgba(235,235,245,0.28);
    --aw-pill-bg:      #2C2C2E;
    --aw-pill-bdr:     rgba(84,84,88,0.65);
    --aw-pill-text:    rgba(235,235,245,0.85);
    --aw-pill-h:       rgba(58,58,60,0.9);
    --aw-desc:         rgba(235,235,245,0.40);
    --aw-out-text:     rgba(255,255,255,0.92);
    --aw-empty:        rgba(235,235,245,0.30);
    --aw-foot-key:     rgba(235,235,245,0.28);
    --aw-trial-bg:     rgba(84,84,88,0.18);
    --aw-trial-text:   rgba(235,235,245,0.50);
    --aw-priv:         rgba(235,235,245,0.28);
    --aw-act:          rgba(235,235,245,0.45);
    --aw-act-hbg:      rgba(255,255,255,0.06);
    --aw-act-h:        rgba(235,235,245,0.85);
    --aw-clear-circle: rgba(235,235,245,0.30);
    --aw-clear-x:      rgba(0,0,0,0.50);
    --aw-close-circle: rgba(235,235,245,0.18);
    --aw-close-x:      rgba(235,235,245,0.50);
    --aw-tmpl-dot-bg:  rgba(28,28,30,1);

    --aw-history-header-bdr: rgba(84,84,88,0.65);
    --aw-history-text: rgba(255,255,255,0.94);
    --aw-history-meta: rgba(235,235,245,0.62);
    --aw-history-search-bg: rgba(44,44,46,0.92);
    --aw-history-search-bdr: rgba(84,84,88,0.65);
    --aw-history-search-ph: rgba(235,235,245,0.35);
    --aw-history-chip-bg: #2C2C2E;
    --aw-history-chip-bdr: rgba(84,84,88,0.65);
    --aw-history-chip-text: rgba(235,235,245,0.88);
    --aw-history-row-hover: rgba(255,255,255,0.06);
    --aw-history-danger: #FF5E57;

    --aw-export-bg: #262628;
    --aw-export-bdr: rgba(84,84,88,0.72);
    --aw-export-shadow: rgba(0,0,0,0.50);
    --aw-export-group-bg: #2F2F31;
    --aw-export-group-bdr: rgba(84,84,88,0.80);
    --aw-export-head-bg: rgba(255,255,255,0.04);
    --aw-export-head-text: rgba(235,235,245,0.45);
    --aw-export-row-text: rgba(255,255,255,0.92);
    --aw-export-row-hover: #39393C;
  }

  /* ── Window container ────────────────────────── */
  .app-win {
    width: 420px;
    height: 580px;
    background: var(--aw-bg);
    border-radius: 12px;
    border: 1px solid var(--aw-win-bdr);
    box-shadow:
      0 0 0 0.5px rgba(0,0,0,0.14),
      0 4px 6px rgba(0,0,0,0.07),
      0 12px 28px rgba(0,0,0,0.10),
      0 32px 80px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: -apple-system, 'SF Pro Text', 'Helvetica Neue', sans-serif;
    color: var(--aw-text);
    position: relative;
    user-select: none;
    transition: background .22s, border-color .22s, color .22s, box-shadow .22s;
  }

  /* ── Separator ───────────────────────────────── */
  .aw-sep {
    height: 1px;
    background: var(--aw-sep);
    flex-shrink: 0;
    transition: background .22s;
  }

  /* ── Header ──────────────────────────────────── */
  .aw-header {
    height: 44px;
    display: flex; align-items: center;
    padding: 0 16px;
    flex-shrink: 0;
  }
  .aw-title {
    font-size: 15px; font-weight: 600;
    color: var(--aw-title);
    flex: 1;
    letter-spacing: -0.01em;
    transition: color .22s;
  }
  .aw-header-btns { display: flex; gap: 0; }
  .aw-icon-btn {
    width: 32px; height: 32px;
    background: transparent; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    border-radius: 6px;
    color: var(--aw-icon);
    transition: background .12s, color .12s;
    padding: 0;
  }
  .aw-icon-btn svg { width: 14px; height: 14px; }
  .aw-icon-btn:hover { background: var(--aw-icon-hbg); color: var(--aw-icon-h); }

  .aw-screen {
    position: absolute;
    inset: 0;
    z-index: 40;
    background: var(--aw-bg);
    display: flex;
    flex-direction: column;
  }
  .aw-screen[hidden] { display: none !important; }
  .aw-screen-header {
    height: 44px;
    padding: 0 16px;
    display: flex;
    align-items: center;
    border-bottom: 0.5px solid var(--aw-history-header-bdr);
  }
  .aw-screen-back {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: none;
    background: transparent;
    color: var(--aw-history-text);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    padding: 0;
  }
  .aw-screen-back iconify-icon { font-size: 12px !important; }

  .aw-screen-history {
    opacity: 0;
    transform: translateX(16px);
    transition: opacity .2s ease, transform .24s cubic-bezier(.2,.9,.25,1);
  }
  .aw-screen-history.is-open {
    opacity: 1;
    transform: translateX(0);
  }

  .aw-screen-body {
    flex: 1;
    overflow: auto;
    padding: 8px 16px 10px;
  }

  .aw-history-top { margin-bottom: 8px; }
  .aw-history-meta {
    font-size: 11px;
    color: var(--aw-history-meta);
    margin-bottom: 6px;
  }
  .aw-history-search-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px;
    border-radius: 8px;
    background: var(--aw-history-search-bg);
    border: 0.5px solid var(--aw-history-search-bdr);
    margin-bottom: 10px;
  }
  .aw-history-search {
    border: none;
    outline: none;
    background: transparent;
    color: var(--aw-history-text);
    font-size: 13px;
    width: 100%;
    font-family: -apple-system, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  }
  .aw-history-search::placeholder { color: var(--aw-history-search-ph); }
  .aw-history-search-clear {
    border: none;
    background: transparent;
    color: var(--aw-history-search-ph);
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
  }
  .aw-history-filters {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    padding: 0 0 4px;
    scrollbar-width: none;
  }
  .aw-history-filters::-webkit-scrollbar { display: none; }
  .aw-history-filter {
    border: 0.5px solid var(--aw-history-chip-bdr);
    background: var(--aw-history-chip-bg);
