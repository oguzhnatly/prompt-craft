---
---
<section class="section cta-section">
  <div class="container">
    <div class="cta-inner" data-reveal>
      <div class="cta-bg-blob" aria-hidden="true"></div>

      <div class="badge teal" style="margin-bottom:28px">
        <span class="badge-dot"></span>
        AVAILABLE NOW
      </div>

      <h2 class="cta-h syne">
        Stop sending the AI<br>the wrong question.
      </h2>

      <p class="cta-sub">
        PromptCraft runs silently, costs nothing upfront, and
        makes every AI interaction measurably better.
        The 14-day trial requires no card.
      </p>

      <div class="cta-btns">
        <a href="/download" class="btn btn-teal">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 2v9M3 8l5 5 5-5M1 14h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Download Free
        </a>
        <a href="/pricing" class="btn btn-outline">
          Compare Plans
        </a>
      </div>

      <div class="cta-specs mono">
        <span>macOS 14+</span>
        <span class="cta-dot">·</span>
        <span>Developer ID Signed</span>
        <span class="cta-dot">·</span>
        <span>14-day trial</span>
        <span class="cta-dot">·</span>
        <span>No card required</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 100px 0;
    background: var(--paper-2);
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .cta-bg-blob {
    position: absolute;
    width: 500px; height: 300px;
    background: radial-gradient(ellipse, rgba(0,200,150,0.12), transparent 70%);
    top: -80px; left: 50%; transform: translateX(-50%);
    filter: blur(60px);
    pointer-events: none; z-index: 0;
  }

  .cta-h {
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 800; letter-spacing: -0.045em;
    line-height: 1.1; color: var(--ink);
    margin-bottom: 20px;
    position: relative; z-index: 1;
  }

  .cta-sub {
    font-size: 16px; line-height: 1.7;
    color: var(--ink-2); margin-bottom: 36px;
    position: relative; z-index: 1;
  }

  .cta-btns {
    display: flex; gap: 12px;
    justify-content: center; flex-wrap: wrap;
    margin-bottom: 24px;
    position: relative; z-index: 1;
  }

  .cta-specs {
    font-size: 11px; color: var(--ink-4);
    display: flex; align-items: center;
    justify-content: center; gap: 10px;
    flex-wrap: wrap;
    position: relative; z-index: 1;
  }
  .cta-dot { opacity: 0.4; }
</style>
