---
---
<section id="final-cta" aria-labelledby="cta-heading">
  <div class="wrap cta-inner">
    <div class="cta-text" data-reveal>
      <h2 id="cta-heading" class="cta-h2">
        Stop writing context.<br>Start getting answers.
      </h2>
      <p class="cta-sub">
        macOS 14 Sonoma or later. Apple Silicon and Intel. 14-day free trial.
        No account, no credit card, no setup. License key by email after purchase.
      </p>
      <div class="cta-btns">
        <a href="/download" class="btn btn-ink cta-btn-main">
          <iconify-icon icon="lucide:download" style="font-size:15px;" aria-hidden="true"></iconify-icon>
          Download for Mac — Free
        </a>
        <a href="/pricing" class="btn btn-ghost">
          All pricing options
          <iconify-icon icon="lucide:arrow-right" style="font-size:14px;" aria-hidden="true"></iconify-icon>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #final-cta {
    padding: 100px 0 120px;
    background: var(--bg2);
    border-top: 1px solid var(--bdr);
  }
  .cta-inner { display: flex; justify-content: flex-start; }
  .cta-text  { max-width: 640px; display: flex; flex-direction: column; gap: 0; }
  .cta-h2 {
    font-size: clamp(36px, 5.5vw, 68px);
    font-weight: 700; letter-spacing: -0.055em; line-height: 1.03;
    color: var(--ink); margin-bottom: 20px;
  }
  .cta-sub  { font-size: 15px; color: var(--mid); line-height: 1.75; max-width: 460px; margin-bottom: 36px; }
  .cta-btns { display: flex; gap: 8px; flex-wrap: wrap; }
  .cta-btn-main { padding: 14px 28px; font-size: 15px; border-radius: 9px; }
</style>
