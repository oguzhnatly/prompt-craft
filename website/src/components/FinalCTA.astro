---
// FinalCTA — the close
---

<section id="cta" class="section cta-section">
  <div class="cta-inner">
    <!-- Corner marks -->
    <span class="corner-mark cm-tl" aria-hidden="true"></span>
    <span class="corner-mark cm-tr" aria-hidden="true"></span>
    <span class="corner-mark cm-bl" aria-hidden="true"></span>
    <span class="corner-mark cm-br" aria-hidden="true"></span>

    <!-- Glow -->
    <div class="cta-glow" aria-hidden="true"></div>

    <div class="tag teal" style="margin-bottom:32px">
      <span class="tag-dot"></span>
      FREE DOWNLOAD · macOS 14+
    </div>

    <h2 class="cta-headline">
      Stop guessing.<br>
      <span class="cta-teal">Start engineering.</span>
    </h2>

    <p class="cta-sub">
      Every AI response your team produces could be better.<br>
      PromptCraft makes sure it is.
    </p>

    <div class="cta-actions">
      <a href="/download" class="btn btn-primary cta-btn" data-cursor="DOWNLOAD">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M9 2v11M4 9l5 5 5-5M1 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download for macOS
      </a>
      <a href="/pricing" class="btn btn-ghost cta-btn" data-cursor="PRICING">
        View pricing
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="cta-specs font-mono">
      <span>Developer ID Signed</span>
      <span class="cta-dot">·</span>
      <span>Notarized by Apple</span>
      <span class="cta-dot">·</span>
      <span>No App Store required</span>
      <span class="cta-dot">·</span>
      <span>macOS 14 Sonoma+</span>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 120px 40px;
  }

  .cta-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    padding: 80px 60px;
    background: var(--surface);
    border: 1px solid rgba(0,255,178,0.1);
    border-radius: 24px;
    overflow: hidden;
  }

  /* Corner marks */
  .corner-mark {
    position: absolute;
    width: 20px; height: 20px;
    border-color: var(--teal);
    border-style: solid;
    opacity: 0.4;
  }
  .cm-tl { top: 16px; left: 16px;  border-width: 1px 0 0 1px; }
  .cm-tr { top: 16px; right: 16px; border-width: 1px 1px 0 0; }
  .cm-bl { bottom: 16px; left: 16px;  border-width: 0 0 1px 1px; }
  .cm-br { bottom: 16px; right: 16px; border-width: 0 1px 1px 0; }

  .cta-glow {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 400px; height: 300px;
    background: radial-gradient(ellipse at 50% 0%, rgba(0,255,178,0.08), transparent 70%);
    pointer-events: none;
  }

  .cta-headline {
    font-size: clamp(36px, 5vw, 58px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }
  .cta-teal { color: var(--teal); }

  .cta-sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-2);
    margin-bottom: 40px;
    position: relative;
    z-index: 1;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 28px;
    position: relative;
    z-index: 1;
    flex-wrap: wrap;
  }

  .cta-btn { min-width: 200px; justify-content: center; }

  .cta-specs {
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }
  .cta-dot { opacity: 0.3; }

  @media (max-width: 640px) {
    .cta-inner { padding: 48px 24px; }
    .cta-section { padding: 80px 20px; }
  }
</style>
