---
---
<header id="site-nav" role="banner">
  <div class="wrap nav-inner">

    <a href="/" class="nav-logo" aria-label="PromptCraft">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="2.8" fill="var(--acc)"/>
        <path d="M12 2v8M12 14v8M2 12h8M14 12h8" stroke="var(--acc)" stroke-width="2.2" stroke-linecap="round"/>
        <circle cx="12" cy="12" r="7" stroke="var(--acc)" stroke-width="0.8" opacity=".25" stroke-dasharray="2.5 3.5"/>
      </svg>
      <span>PromptCraft</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      <a href="/#pipeline">How it works</a>
      <a href="/#features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/docs">Docs</a>
    </nav>

    <div class="nav-actions">
      <a href="/download" class="btn btn-ink nav-dl">
        Download for Mac
        <span class="nav-dl-free">Free</span>
      </a>
    </div>

    <!-- Mobile toggle -->
    <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile">
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- Mobile nav -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    <div class="nm-links">
      <a href="/#pipeline">How it works</a>
      <a href="/#features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/docs">Docs</a>
      <a href="/download" class="nm-dl">Download for Mac — Free</a>
    </div>
  </div>
</header>

<style>
  #site-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid transparent;
    transition: border-color .2s, box-shadow .2s;
  }
  #site-nav.scrolled {
    border-bottom-color: var(--bdr);
    box-shadow: 0 1px 16px rgba(0,0,0,0.04);
  }

  .nav-inner {
    height: 60px;
    display: flex; align-items: center;
    gap: 32px;
  }

  .nav-logo {
    display: flex; align-items: center; gap: 9px;
    font-size: 15px; font-weight: 700; letter-spacing: -0.025em;
    color: var(--ink); flex-shrink: 0;
    transition: opacity .15s;
  }
  .nav-logo:hover { opacity: 0.7; }

  .nav-links {
    display: flex; align-items: center; gap: 4px;
    flex: 1; justify-content: center;
  }
  .nav-links a {
    font-size: 14px; font-weight: 500; color: var(--mid);
    padding: 6px 12px; border-radius: 6px;
    transition: color .13s, background .13s;
  }
  .nav-links a:hover { color: var(--ink); background: var(--bg2); }

  .nav-actions { flex-shrink: 0; }

  .nav-dl {
    padding: 8px 18px; font-size: 13px; border-radius: 8px;
    gap: 8px;
  }
  .nav-dl-free {
    font-size: 10px; font-weight: 600; letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--acc-hi); opacity: .8;
  }

  .nav-toggle {
    display: none;
    flex-direction: column; gap: 5px;
    background: none; border: none; padding: 4px;
    margin-left: auto;
  }
  .nav-toggle span {
    display: block; width: 20px; height: 1.5px;
    background: var(--ink); border-radius: 2px;
    transition: transform .2s, opacity .2s;
  }

  .nav-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-actions { display: none; }
    .nav-toggle { display: flex; }

    .nav-mobile {
      display: block;
      background: var(--bg);
      border-top: 1px solid var(--bdr);
      max-height: 0; overflow: hidden;
      transition: max-height .3s var(--out);
    }
    .nav-mobile.open { max-height: 300px; }

    .nm-links {
      display: flex; flex-direction: column; gap: 0;
      padding: 8px 20px 20px;
    }
    .nm-links a {
      font-size: 16px; font-weight: 500; color: var(--mid);
      padding: 12px 0;
      border-bottom: 1px solid var(--bdr);
      transition: color .13s;
    }
    .nm-links a:hover { color: var(--ink); }
    .nm-dl {
      border-bottom: none !important;
      color: var(--acc) !important;
      font-weight: 600 !important;
      padding-top: 16px !important;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const mobile = document.getElementById('nav-mobile')!;
  let open = false;

  toggle.addEventListener('click', () => {
    open = !open;
    mobile.classList.toggle('open', open);
    mobile.setAttribute('aria-hidden', String(!open));
    toggle.setAttribute('aria-expanded', String(open));
  });

  // Close on link click
  mobile.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    open = false;
    mobile.classList.remove('open');
    mobile.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
  }));
</script>
