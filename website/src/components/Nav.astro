---
---
<nav id="nav">
  <div class="ni">
    <a href="/" class="nlogo" aria-label="PromptCraft">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <circle cx="10" cy="10" r="1.5" fill="#00FFA3"/>
        <line x1="10" y1="2" x2="10" y2="7" stroke="#00FFA3" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="10" y1="13" x2="10" y2="18" stroke="#00FFA3" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2" y1="10" x2="7" y2="10" stroke="#00FFA3" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="13" y1="10" x2="18" y2="10" stroke="#00FFA3" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="4.3" y1="4.3" x2="7.2" y2="7.2" stroke="rgba(0,255,163,.35)" stroke-width="1" stroke-linecap="round"/>
        <line x1="12.8" y1="12.8" x2="15.7" y2="15.7" stroke="rgba(0,255,163,.35)" stroke-width="1" stroke-linecap="round"/>
        <line x1="15.7" y1="4.3" x2="12.8" y2="7.2" stroke="rgba(0,255,163,.35)" stroke-width="1" stroke-linecap="round"/>
        <line x1="7.2" y1="12.8" x2="4.3" y2="15.7" stroke="rgba(0,255,163,.35)" stroke-width="1" stroke-linecap="round"/>
      </svg>
      <span class="nl-name">Prompt<strong>Craft</strong></span>
    </a>

    <div class="nlinks">
      <a href="#architecture">Pipeline</a>
      <a href="#features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/docs">Docs</a>
    </div>

    <div class="nright">
      <a href="/download" class="ndl">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1v8M2 7l4.5 4.5L11 7M.5 11.5h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Download
      </a>
      <a href="/pricing" class="btn btn-mint mag" style="padding:8px 18px;font-size:13px;border-radius:8px">
        Get started
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5.5h8M5.5 1.5l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</nav>

<style>
  #nav {
    position: fixed; top: 0; left: 0; right: 0;
    height: 58px; z-index: 500;
    padding: 0 32px;
    display: flex; align-items: center;
    transition: background .35s, border-color .35s, backdrop-filter .35s;
    border-bottom: 1px solid transparent;
  }
  #nav.on {
    background: rgba(6,4,15,.88);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom-color: var(--border);
  }

  .ni {
    width: 100%; max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; gap: 40px;
  }

  .nlogo {
    display: flex; align-items: center; gap: 9px;
    text-decoration: none; color: var(--t1);
    font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 400;
    letter-spacing: -.01em; flex-shrink: 0;
  }
  .nlogo strong { font-weight: 700; }

  .nlinks {
    display: flex; gap: 28px; flex: 1; justify-content: center;
  }
  .nlinks a {
    text-decoration: none;
    font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 500;
    color: var(--t3); letter-spacing: -.005em;
    transition: color .2s;
  }
  .nlinks a:hover { color: var(--t1); }

  .nright { display: flex; align-items: center; gap: 16px; flex-shrink: 0; }

  .ndl {
    display: flex; align-items: center; gap: 5px;
    text-decoration: none;
    font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 500;
    color: var(--t3); transition: color .2s;
  }
  .ndl:hover { color: var(--t1); }

  @media (max-width: 720px) {
    .nlinks { display: none; }
    #nav { padding: 0 20px; }
  }
</style>

<script>
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => { nav.classList.toggle('on', scrollY > 24); }, { passive: true });
</script>
