---
---
<nav id="nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
        <circle cx="14" cy="14" r="12" stroke="var(--teal)" stroke-width="1" stroke-dasharray="3 2" opacity="0.45"/>
        <circle cx="14" cy="14" r="7" stroke="var(--teal)" stroke-width="0.75" opacity="0.25"/>
        <line x1="14" y1="3" x2="14" y2="7" stroke="var(--teal)" stroke-width="1.5"/>
        <line x1="14" y1="21" x2="14" y2="25" stroke="var(--teal)" stroke-width="1.5"/>
        <line x1="3" y1="14" x2="7" y2="14" stroke="var(--teal)" stroke-width="1.5"/>
        <line x1="21" y1="14" x2="25" y2="14" stroke="var(--teal)" stroke-width="1.5"/>
        <circle cx="14" cy="14" r="2.5" fill="var(--teal)"/>
      </svg>
      <span class="logo-text">Prompt<span class="logo-accent">Craft</span></span>
    </a>

    <div class="nav-links">
      <a href="/#pipeline">Pipeline</a>
      <a href="/#features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/docs">Docs</a>
    </div>

    <div class="nav-actions">
      <a href="/download" class="nav-download">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
          <path d="M6.5 1.5v7M3 6l3.5 3.5L10 6M1 11.5h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download
      </a>
      <a href="/pricing" class="nav-cta">
        Get Cloud
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 24px;
    transition: all 0.3s ease;
  }

  nav.scrolled {
    background: rgba(5,5,7,0.85);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1120px;
    margin: 0 auto;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.3px;
  }

  .logo-accent { color: var(--teal); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text-primary); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-download {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .nav-download:hover { color: var(--text-primary); }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 18px;
    background: var(--teal);
    color: #050507;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .nav-cta:hover {
    background: var(--teal-dim);
    box-shadow: 0 0 24px rgba(0,229,160,0.3);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-download { display: none; }
  }
</style>

<script>
  const nav = document.getElementById('nav')!;
  const onScroll = () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
