---
const links = [
  { label: 'Features', href: '/#features' },
  { label: 'Pipeline', href: '/#pipeline' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Docs', href: '/docs' },
];
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-8 h-8 relative">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <!-- Outer ring -->
          <circle cx="16" cy="16" r="14" stroke="#00FFB2" stroke-width="1.5" stroke-dasharray="4 2" opacity="0.4" />
          <!-- Inner precision cross -->
          <line x1="16" y1="4" x2="16" y2="8" stroke="#00FFB2" stroke-width="1.5" />
          <line x1="16" y1="24" x2="16" y2="28" stroke="#00FFB2" stroke-width="1.5" />
          <line x1="4" y1="16" x2="8" y2="16" stroke="#00FFB2" stroke-width="1.5" />
          <line x1="24" y1="16" x2="28" y2="16" stroke="#00FFB2" stroke-width="1.5" />
          <!-- Center dot -->
          <circle cx="16" cy="16" r="3" fill="#00FFB2" opacity="0.9" />
          <circle cx="16" cy="16" r="6" stroke="#00FFB2" stroke-width="1" opacity="0.3" />
        </svg>
      </div>
      <span class="font-mono text-[15px] font-semibold tracking-tight text-ink">
        Prompt<span class="text-teal">Craft</span>
      </span>
    </a>

    <!-- Links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class="font-mono text-[13px] text-ink-secondary hover:text-ink tracking-wide transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-4">
      <a
        href="/download"
        class="hidden md:inline-flex items-center gap-2 font-mono text-[13px] text-ink-secondary hover:text-ink transition-colors"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none">
          <path d="M7 1v8M3 6l4 4 4-4M1 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download
      </a>
      <a
        href="/pricing"
        class="inline-flex items-center gap-2 px-4 py-2 font-mono text-[13px] font-medium bg-teal text-void rounded-md hover:bg-teal-dim transition-colors duration-200"
      >
        Get Cloud
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
          <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav.style.background = 'rgba(7,8,11,0.92)';
      nav.style.backdropFilter = 'blur(20px)';
      nav.style.borderBottom = '1px solid rgba(30,33,48,0.8)';
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.borderBottom = 'none';
    }
  });
</script>
