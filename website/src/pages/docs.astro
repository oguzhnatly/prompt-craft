<script>
  const sections = Array.from(document.querySelectorAll('section.db-section[id]'));
  const links = Array.from(document.querySelectorAll('.ds-link'));
  const TOP_OFFSET = 112;

  function setActive(id) {
    links.forEach((link) => {
      const href = link.getAttribute('href');
      link.classList.toggle('active', href === '#' + id);
    });
  }

  function updateActiveFromScroll() {
    if (!sections.length) return;

    const scrollProbe = window.scrollY + TOP_OFFSET;
    let activeId = sections[0].id;

    for (const section of sections) {
      if (section.offsetTop <= scrollProbe) activeId = section.id;
      else break;
    }

    const nearBottom = window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 4;
    if (nearBottom) activeId = sections[sections.length - 1].id;

    setActive(activeId);
  }

  window.addEventListener('scroll', updateActiveFromScroll, { passive: true });
  window.addEventListener('resize', updateActiveFromScroll);
  window.addEventListener('hashchange', updateActiveFromScroll);

  links.forEach((link) => {
    link.addEventListener('click', () => {
      requestAnimationFrame(() => setTimeout(updateActiveFromScroll, 0));
    });
  });

  updateActiveFromScroll();
</script>
