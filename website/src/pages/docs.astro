    .ds-head { display: none; }
    .db-styles-grid { grid-template-columns: 1fr; }
    .db-verb-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const sections = document.querySelectorAll<HTMLElement>('section.db-section[id]');
  const links = document.querySelectorAll<HTMLAnchorElement>('.ds-link');

  function setActive(id: string) {
    links.forEach(l => {
      const href = l.getAttribute('href');
      if (href === '#' + id) l.classList.add('active');
      else l.classList.remove('active');
    });
  }

  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(e => {
        if (e.isIntersecting) setActive((e.target as HTMLElement).id);
      });
    },
    { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
  );

  sections.forEach(s => observer.observe(s));
  // Set initial active state based on scroll position
  if (sections.length > 0) setActive(sections[0].id);
</script>
