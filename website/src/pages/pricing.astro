---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Pricing — PromptCraft"
  description="PromptCraft Pro is $99 one-time. Cloud adds managed AI routing for $12/month. First Cloud subscription charge has a 14 day no questions refund window."
>
  <Nav />
  <main style="padding-top:84px; min-height:80vh;">
    <Pricing />
    <div class="wrap faq-wrap">
      <section class="faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="faq-h">Frequently asked</h2>
        <div class="faq-list">
          {[
            ['Do I need an API key?', 'For Pro with Ollama: no. For Pro with a cloud provider like Claude or GPT-4o: yes, you bring your own API key and configure it in Settings. Cloud tier users get access to all providers without managing any keys — we handle the API billing at cost.'],
            ['What happens when I reach the machine limit?', 'Pro activates on 1 Mac. If you need to move to a new machine, open Settings to Deactivate on the old one first, then activate on the new Mac using the same license key.'],
            ['How does the refund policy work?', 'Cloud only: your first subscription charge is refundable within 14 days of the initial subscription date with no questions asked. Renewal charges are not refundable. Pro one time purchases are final. Email hello@promptcraft.app with your order number.'],
            ['Will future updates cost extra?', 'No. Pro includes all updates, including major version upgrades. You paid once; the app improves forever.'],
            ['Can I use it offline?', 'Yes, with Ollama. The entire pipeline runs locally and Ollama responds locally. The only requirement for offline use is that Ollama is installed and a model is pulled.'],
            ['Is my data stored anywhere?', 'No. Prompts, results, and clipboard history are stored only in your local app sandbox on your Mac. Nothing leaves your device unless you explicitly send a request to an AI provider.'],
          ].map(([q, a]) => (
            <div class="faq-item" role="button" tabindex="0" aria-expanded="false">
              <div class="faq-q">
                <span>{q}</span>
                <svg class="faq-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="faq-a">
                <p>{a}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .faq-wrap { padding-bottom: 80px; }
  .faq      { max-width: 720px; }
  .faq-h    { font-size: 26px; font-weight: 800; letter-spacing: -0.04em; color: var(--snow); margin-bottom: 24px; }

  .faq-list { display: flex; flex-direction: column; border-top: 1px solid var(--bdr); }

  .faq-item {
    border-bottom: 1px solid var(--bdr);
    cursor: pointer; transition: background .15s;
  }
  .faq-item:hover { background: rgba(255,255,255,0.015); }

  .faq-q {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 18px 0; font-size: 15px; font-weight: 600; color: var(--snow);
    letter-spacing: -0.02em;
  }
  .faq-chevron { color: var(--mute); transition: transform .25s var(--spring), color .15s; flex-shrink: 0; }
  .faq-item.open .faq-chevron { transform: rotate(180deg); color: var(--g); }

  .faq-a { overflow: hidden; height: 0; transition: height .3s var(--out); }
  .faq-a p { font-size: 14px; line-height: 1.8; color: var(--mute); padding-bottom: 18px; max-width: 640px; }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const ans = item.querySelector<HTMLElement>('.faq-a')!;
    let open  = false;
    const toggle = () => {
      open = !open;
      item.classList.toggle('open', open);
      item.setAttribute('aria-expanded', String(open));
      ans.style.height = open ? ans.scrollHeight + 'px' : '0';
    };
    item.addEventListener('click', toggle);
    item.addEventListener('keydown', e => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault(); toggle();
      }
    });
  });
</script>
