---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Download PromptCraft for macOS"
  description="Download PromptCraft — the macOS menu bar app that engineers every prompt before it reaches any AI. Free 14-day trial. No account required."
>
  <Nav />
  <main class="dl-page">
    <div class="wrap">

      <header class="dl-head" data-r>
        <div class="dl-logo-head" aria-hidden="true">
          <svg viewBox="0 0 64 64" fill="none">
            <rect x="2" y="2" width="60" height="60" rx="14" fill="url(#dl-head-bg)" stroke="rgba(26,107,64,0.18)"/>
            <circle cx="32" cy="32" r="5" fill="#1A6B40"/>
            <path d="M32 13v13M32 38v13M13 32h13M38 32h13" stroke="#1A6B40" stroke-width="3" stroke-linecap="round"/>
            <circle cx="32" cy="32" r="14" stroke="#1A6B40" stroke-width="1.2" opacity=".25" stroke-dasharray="3 4"/>
            <defs>
              <linearGradient id="dl-head-bg" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
                <stop stop-color="#FFFFFF"/>
                <stop offset="1" stop-color="#F2F9F4"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <span class="lbl g"><span class="ldot"></span>Download</span>
        <h1 class="dl-h1">PromptCraft for macOS</h1>
        <p class="dl-sub">
          Signed and notarized build for macOS 14+ with Apple Silicon and Intel support.
        </p>
        <div class="dl-signals" data-r>
          <span class="dl-signal mono">Developer ID signed</span>
          <span class="dl-signal mono">Apple notarized</span>
          <span class="dl-signal mono">Universal binary</span>
        </div>
      </header>

      <!-- Download card -->
      <div class="dl-card" data-r>
        <div class="dlc-left">
          <div class="dlc-icon">
            <svg viewBox="0 0 64 64" fill="none">
              <rect x="2" y="2" width="60" height="60" rx="14" fill="url(#dl-card-bg)" stroke="rgba(26,107,64,0.18)"/>
              <circle cx="32" cy="32" r="5" fill="#1A6B40"/>
              <path d="M32 13v13M32 38v13M13 32h13M38 32h13" stroke="#1A6B40" stroke-width="3" stroke-linecap="round"/>
              <circle cx="32" cy="32" r="14" stroke="#1A6B40" stroke-width="1.2" opacity=".25" stroke-dasharray="3 4"/>
              <defs>
                <linearGradient id="dl-card-bg" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#FFFFFF"/>
                  <stop offset="1" stop-color="#F2F9F4"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div>
            <p class="dlc-name">PromptCraft</p>
            <p class="dlc-meta mono">v1.1.0 &nbsp;·&nbsp; macOS 14+ &nbsp;·&nbsp; ~12 MB</p>
          </div>
        </div>
        <a href="https://github.com/oguzhnatly/prompt-craft/releases" target="_blank" rel="noopener" class="btn btn-g dlc-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1v9M2 7l5 5 5-5M1 13h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Download .dmg
        </a>
      </div>

      <!-- Install steps -->
      <section class="dl-steps" aria-labelledby="install-heading">
        <h2 id="install-heading" class="dl-steps-h">Up and running in 60 seconds</h2>
        <div class="dl-step-list">
          {[
            {
              n: '01',
              title: 'Open the .dmg and drag to Applications',
              body: 'Mount the disk image and drag PromptCraft.app to your Applications folder. Eject the disk image when done.',
            },
            {
              n: '02',
              title: 'Launch — Gatekeeper will clear it',
              body: 'The app is signed with a Developer ID certificate and notarized by Apple. macOS Gatekeeper will clear it on first launch. If prompted, click Open in System Settings.',
            },
            {
              n: '03',
              title: 'Grant Accessibility permission',
              body: 'PromptCraft needs one Accessibility permission to read selected text from your active application and enable the global Cmd+Shift+Space shortcut. Grant it once in System Settings to Privacy & Security to Accessibility. It cannot be revoked per-app after granted — you choose to add it yourself.',
            },
            {
              n: '04',
              title: 'Press Cmd+Shift+Space from anywhere',
              body: 'The app is now running silently in your menu bar. Press Cmd+Shift+Space from any application, on any desktop Space, to open PromptCraft. Type a rough idea, press Optimize, copy the result. Done.',
            },
          ].map(s => (
            <div class="dl-step" data-r>
              <span class="dls-n mono">{s.n}</span>
              <div>
                <p class="dls-title">{s.title}</p>
                <p class="dls-body">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- System requirements -->
      <section class="dl-req" data-r aria-labelledby="req-heading">
        <h2 id="req-heading" class="dl-req-h">System requirements</h2>
        <div class="dl-req-grid">
          {[
            ['macOS version', 'macOS 14 Sonoma or later'],
            ['Architecture', 'Apple Silicon (M1/M2/M3/M4) and Intel'],
            ['RAM', '4 GB minimum, 8 GB recommended'],
            ['Disk space', '~12 MB for the app'],
            ['AI provider', 'Ollama (local), or internet access for cloud models'],
            ['Permission', 'Accessibility (one-time grant, read-only)'],
          ].map(([k, v]) => (
            <div class="dl-req-row">
              <span class="dl-req-k mono">{k}</span>
              <span class="dl-req-v">{v}</span>
            </div>
          ))}
        </div>
      </section>

    </div>
  </main>
  <Footer />
</Base>

<style>
  .dl-page { padding-top: 100px; padding-bottom: 80px; min-height: 90vh; background: var(--bg); }

  .dl-head { margin-bottom: 42px; display: flex; flex-direction: column; gap: 14px; }
  .dl-logo-head { width: 68px; height: 68px; }
  .dl-logo-head svg { width: 100%; height: 100%; }
  .dl-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .dl-signal {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--acc);
    background: rgba(26,107,64,0.08);
    border: 1px solid rgba(26,107,64,0.16);
    border-radius: 999px;
    padding: 5px 9px;
  }
  .dl-h1   { font-size: clamp(32px, 5vw, 64px); font-weight: 800; letter-spacing: -0.05em; color: var(--ink); line-height: 1.02; }
  .dl-sub  { font-size: 15px; color: var(--mid); max-width: 660px; line-height: 1.6; }

  .dl-card {
    background: var(--bg2); border: 1px solid var(--bdr);
    border-radius: 14px; padding: 24px 26px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
    margin-bottom: 52px;
    transition: border-color .2s, box-shadow .2s;
  }
  .dl-card:hover { border-color: rgba(26,107,64,0.2); box-shadow: 0 8px 30px rgba(26,107,64,0.07); }
  .dlc-left { display: flex; align-items: center; gap: 16px; }
  .dlc-icon { width: 64px; height: 64px; flex-shrink: 0; }
  .dlc-icon svg { width: 100%; height: 100%; }
  .dlc-name { font-size: 18px; font-weight: 700; letter-spacing: -0.03em; color: var(--ink); }
  .dlc-meta { font-size: 11px; color: var(--mid); margin-top: 4px; }
  .dlc-btn  { flex-shrink: 0; padding: 13px 24px; font-size: 14px; border-radius: 10px; }

  .dl-steps-h { font-size: 22px; font-weight: 700; letter-spacing: -0.035em; color: var(--ink); margin-bottom: 24px; }

  .dl-step-list { display: flex; flex-direction: column; border-top: 1px solid var(--bdr); margin-bottom: 56px; }
  .dl-step {
    display: grid; grid-template-columns: 56px 1fr; gap: 0 24px;
    padding: 26px 0; border-bottom: 1px solid var(--bdr);
  }
  .dls-n     { font-size: 10px; font-weight: 600; letter-spacing: 0.08em; color: var(--mid); padding-top: 4px; transition: color .15s; }
  .dl-step:hover .dls-n { color: var(--acc); }
  .dls-title { font-size: 16px; font-weight: 700; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 8px; }
  .dls-body  { font-size: 14px; line-height: 1.75; color: var(--mid); max-width: 640px; }

  .dl-req-h { font-size: 22px; font-weight: 700; letter-spacing: -0.035em; color: var(--ink); margin-bottom: 20px; }
  .dl-req-grid {
    display: flex; flex-direction: column;
    background: var(--bg2); border-radius: 10px; border: 1px solid var(--bdr);
    overflow: hidden;
  }
  .dl-req-row {
    display: grid; grid-template-columns: 180px 1fr;
    padding: 14px 20px; border-bottom: 1px solid var(--bdr);
    align-items: center; gap: 16px;
  }
  .dl-req-row:last-child { border-bottom: none; }
  .dl-req-k  { font-size: 12px; color: var(--mid); }
  .dl-req-v  { font-size: 14px; color: var(--ink); }

  @media (max-width: 640px) {
    .dl-card { flex-direction: column; align-items: flex-start; }
    .dl-req-row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
