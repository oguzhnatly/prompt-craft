---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'PromptCraft — Precision Prompt Engineering',
  description = 'The macOS menu bar app that transforms raw prompts through 7 engineered stages before they reach any AI.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#09090F" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200;12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Fira+Code:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <!-- Precision crosshair cursor -->
  <svg id="pc-cursor" viewBox="0 0 32 32" fill="none" aria-hidden="true" focusable="false">
    <circle cx="16" cy="16" r="2.5" fill="var(--g)" class="cc-center"/>
    <line x1="16" y1="2"  x2="16" y2="10" stroke="var(--g)" stroke-width="1.5" stroke-linecap="round" class="cc-arm"/>
    <line x1="16" y1="22" x2="16" y2="30" stroke="var(--g)" stroke-width="1.5" stroke-linecap="round" class="cc-arm"/>
    <line x1="2"  y1="16" x2="10" y2="16" stroke="var(--g)" stroke-width="1.5" stroke-linecap="round" class="cc-arm"/>
    <line x1="22" y1="16" x2="30" y2="16" stroke="var(--g)" stroke-width="1.5" stroke-linecap="round" class="cc-arm"/>
    <circle cx="16" cy="16" r="7" stroke="var(--g)" stroke-width="1" stroke-dasharray="2 3" class="cc-ring" opacity="0.4"/>
  </svg>
  <!-- Cursor trail container -->
  <div id="cursor-trail" aria-hidden="true"></div>

  <slot />

  <style is:global>
    :root {
      --void:   #09090F;
      --ink-1:  #111118;
      --ink-2:  #18181F;
      --ink-3:  #222230;
      --dim:    #2E2E40;
      --mute:   #6B6B85;
      --pale:   #A3A3B5;
      --snow:   #F0EFFA;
      --g:      #00E676;      /* green accent — brand */
      --g-dim:  #00A854;
      --r:      #FF3B30;      /* coral/red */
      --b:      #4A90FF;      /* blue */
      --y:      #FFD60A;      /* gold */
      --p:      #BF5AF2;      /* purple */
      --border: rgba(255,255,255,0.07);
      --border-hi: rgba(255,255,255,0.13);

      --font-display: 'Bricolage Grotesque', system-ui, sans-serif;
      --font-mono:    'Fira Code', 'JetBrains Mono', monospace;

      --r-xs: 6px;
      --r-sm: 10px;
      --r-md: 16px;
      --r-lg: 22px;
      --r-xl: 32px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      background: var(--void);
      color: var(--snow);
      font-family: var(--font-display);
      -webkit-font-smoothing: antialiased;
      cursor: none;
      overflow-x: hidden;
    }

    body { background: var(--void); overflow-x: hidden; }
    a    { color: inherit; text-decoration: none; }
    ::selection { background: rgba(0,230,118,0.18); color: var(--g); }
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--dim); border-radius: 4px; }

    /* ── Custom Cursor ─────────────────────────── */
    #pc-cursor {
      position: fixed;
      width: 32px; height: 32px;
      pointer-events: none;
      z-index: 99999;
      transform: translate(-50%,-50%);
      transition: width .12s, height .12s;
      filter: drop-shadow(0 0 4px rgba(0,230,118,0.5));
    }
    body.ch #pc-cursor {
      width: 44px; height: 44px;
      filter: drop-shadow(0 0 8px rgba(0,230,118,0.7));
    }
    body.ch .cc-center { fill: var(--snow); }
    body.ch .cc-ring   { opacity: 0.7; stroke: var(--snow); stroke-dasharray: none; }

    #cursor-trail { position: fixed; inset: 0; pointer-events: none; z-index: 99998; }
    .ct-dot {
      position: absolute;
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--g);
      transform: translate(-50%,-50%);
      animation: ct-fade .6s ease-out forwards;
    }
    @keyframes ct-fade { from { opacity: 0.5; transform: translate(-50%,-50%) scale(1); } to { opacity: 0; transform: translate(-50%,-50%) scale(0); } }

    /* ── Typography ────────────────────────────── */
    .mono { font-family: var(--font-mono); }

    /* ── Label/badge ───────────────────────────── */
    .label {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 11px;
      border-radius: 999px;
      border: 1px solid var(--border-hi);
      font-family: var(--font-mono);
      font-size: 10px; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--mute);
    }
    .label.g { border-color: rgba(0,230,118,0.25); color: var(--g); background: rgba(0,230,118,0.06); }
    .ldot { width: 5px; height: 5px; border-radius: 50%; background: var(--g); animation: ldot-pulse 2.2s ease-in-out infinite; }
    @keyframes ldot-pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* ── Buttons ───────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 24px;
      border-radius: var(--r-sm);
      font-family: var(--font-display);
      font-size: 14px; font-weight: 600;
      letter-spacing: -0.01em;
      border: none; cursor: none;
      text-decoration: none;
      transition: transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, background .15s;
      position: relative; overflow: hidden;
    }
    .btn::after {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(circle at var(--px,50%) var(--py,50%), rgba(255,255,255,0.1), transparent 60%);
      opacity: 0; transition: opacity .2s;
    }
    .btn:hover::after { opacity: 1; }

    .btn-g {
      background: var(--g); color: var(--void);
      box-shadow: 0 1px 0 var(--g-dim);
    }
    .btn-g:hover {
      background: #26FF87;
      box-shadow: 0 4px 0 var(--g-dim), 0 8px 32px rgba(0,230,118,0.3);
      transform: translateY(-2px);
    }

    .btn-outline {
      background: transparent; color: var(--pale);
      border: 1px solid var(--border-hi);
    }
    .btn-outline:hover {
      background: rgba(255,255,255,0.05);
      border-color: rgba(255,255,255,0.25);
      color: var(--snow);
      transform: translateY(-2px);
    }

    .btn-dim {
      background: var(--ink-3); color: var(--pale);
    }
    .btn-dim:hover {
      background: var(--dim);
      color: var(--snow);
      transform: translateY(-2px);
    }

    /* ── Container ─────────────────────────────── */
    .wrap {
      width: 100%; max-width: 1180px;
      margin: 0 auto; padding: 0 40px;
    }
    @media (max-width: 768px) { .wrap { padding: 0 20px; } }

    /* ── Divider ────────────────────────────────── */
    hr.rule { border: none; border-top: 1px solid var(--border); }

    /* ── Reveal ─────────────────────────────────── */
    [data-r] {
      opacity: 0; transform: translateY(28px);
      transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1);
    }
    [data-r].on { opacity: 1; transform: none; }
    [data-r-d="1"] { transition-delay: .08s; }
    [data-r-d="2"] { transition-delay: .16s; }
    [data-r-d="3"] { transition-delay: .24s; }
    [data-r-d="4"] { transition-delay: .32s; }
    [data-r-d="5"] { transition-delay: .40s; }
  </style>

  <script>
    /* ── Cursor ────────────────────────────────────── */
    const cur  = document.getElementById('pc-cursor') as SVGElement;
    const trail = document.getElementById('cursor-trail')!;
    let cx = 0, cy = 0, dots: HTMLElement[] = [];
    const MAX_TRAIL = 8;

    document.addEventListener('mousemove', e => {
      cx = e.clientX; cy = e.clientY;
      cur.style.left = cx + 'px';
      cur.style.top  = cy + 'px';

      // Trail dot
      const d = document.createElement('div');
      d.className = 'ct-dot';
      d.style.left = cx + 'px';
      d.style.top  = cy + 'px';
      trail.appendChild(d);
      dots.push(d);
      if (dots.length > MAX_TRAIL) {
        const old = dots.shift()!;
        old.remove();
      }
      setTimeout(() => { d.remove(); dots = dots.filter(x => x !== d); }, 600);
    }, { passive: true });

    // Hover state
    document.querySelectorAll('a,button,[data-h]').forEach(el => {
      el.addEventListener('mouseenter', () => document.body.classList.add('ch'));
      el.addEventListener('mouseleave', () => document.body.classList.remove('ch'));
    });

    // Magnetic buttons
    document.querySelectorAll('.btn').forEach(b => {
      b.addEventListener('mousemove', (e: Event) => {
        const ev = e as MouseEvent;
        const r  = (b as HTMLElement).getBoundingClientRect();
        const x  = (ev.clientX - r.left - r.width/2) * 0.20;
        const y  = (ev.clientY - r.top  - r.height/2) * 0.20;
        const px = ((ev.clientX - r.left) / r.width  * 100).toFixed(0);
        const py = ((ev.clientY - r.top)  / r.height * 100).toFixed(0);
        (b as HTMLElement).style.transform = `translate(${x}px,${y}px) translateY(-2px)`;
        (b as HTMLElement).style.setProperty('--px', px + '%');
        (b as HTMLElement).style.setProperty('--py', py + '%');
      });
      b.addEventListener('mouseleave', () => { (b as HTMLElement).style.transform = ''; });
    });

    /* ── Reveal ──────────────────────────────────── */
    const ro = new IntersectionObserver(es => es.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('on'); ro.unobserve(e.target); }
    }), { threshold: 0.1 });
    document.querySelectorAll('[data-r]').forEach(el => ro.observe(el));
  </script>
</body>
</html>
